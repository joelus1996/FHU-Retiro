	<div style="display:none" class="f_error_mensaje">
	    <span class="close_f"></span>
		<div class="f_textoInterno"></div>
	</div>
    <jsp:include page="../../include/footer.jsp" />

    <script type="text/javascript">

        var count = 0;
        function enabledAddon() {
            //console.log(count)
            if (count > 5) {
                $('#plus').prop('disabled', false)
            } else {
                $('#plus, #btn_mobile_chau_chamba_kabala').prop('checked', false).prop('disabled', true)
            }
        }

        $(document).ready(function () {
            //2 $.mobile.defaultPageTransition = 'none';
            var $limiteJugadas = $('#kabalaJugadas').val();
			var $overcomeJugadas = $('#kabalaOvercomeJugadas').val();
			var bets=0;
			if($overcomeJugadas==1)	{
				desplegarModal('Máximo '+ $limiteJugadas +' jugadas'); 
				taggingPopupError('Máximo '+$limiteJugadas+' jugadas');
			}

			var btnAgregarBoletoKabala = null;

            $(document).delegate('#btn_mobile_agregar_boleto_kabala', 'click', function() {
	        	btnAgregarBoletoKabala = this;
				// Se valida si el usuario tiene documentos pendientes de confirmación, el parámetro que recibe
				// es una function que se realizará en caso no tenga docs pendientes de confirmacion
				mainValidatePendingsDocsForAproval('interfaceBetTouchScreenAgregarBoletoKabala');
			});
	
			function interfaceBetTouchScreenAgregarBoletoKabala () {
				//document.forms["game_kabala_add_bet"].submit()
            	if(bets==0){
                	 desplegarModal('No ha realizado ninguna jugada');
                	 taggingPopupError('No ha realizado ninguna jugada');
                	 datalayerErrores('Elige 6 números o más','Paso 1','Jugar','No ha realizado ninguna jugada');
            	}	
            	else {  
					 document.forms["game_kabala_add_bet"].submit(); 
					 datalayerTinkaJugada(this,'Elige 6 números o más','Button','Jugar');  
            	} 
			}
			
			window.addEventListener("message", function(event) {
			    if (event.data === "interfaceBetTouchScreenAgregarBoletoKabala") {
			    	interfaceBetTouchScreenAgregarBoletoKabala(); 
			    }
			}); 


            var countballs = 0;
            
            $(document).delegate('#clean', 'click', function () {
                $("input[type=checkbox]:checked").each(function () {
                    $(this).attr('checked', false);
                });
                count = 0;
                bets=0;
                enabledAddon();
                datalayerTinkaJugada(this,'Elige 6 números o más','Button','Jugar');  
            });

            $(document).delegate('#azar', 'click', function () {
            	$(".f_error_mensaje").hide();
                $("input[type=checkbox]:checked").each(function () {
                    ///$(this).prop('checked', false)
                	$(this).click();
					$(this).attr('checked', false);
                });
                var count_random_kabala = 0;
                var array_random = [];
                while(count_random_kabala<6){  
		            var number =Math.round(1+(Math.random()*(45-1)));
		            if(array_random.indexOf(number) == -1) {
		                array_random.push(number);                        
		                count_random_kabala ++;
		                $("#kb_chk_"+number).click();///
                        ///$("#div_kb_chk_"+number).addClass("button_select");
                        $("#kb_chk_"+number).attr('checked', true);                                               
		              } 
		        }
                /*while (count_random_kabala < 6) {
                    var number = Math.round(1 + (Math.random() * (40 - 1)));
                    if (array_random.indexOf(number) == -1) {
                        array_random[count_random_kabala] = number;
                        count_random_kabala++
                    }
                }
                for (var i = 0; i < array_random.length; i++) {
                    $("#kb_chk_" + array_random[i]).attr('checked', true)
                }
                $("#mg_chk_" + Math.round(1 + (Math.random() * (5 - 1)))).attr('checked', true);
                */
                count = 6;
                bets=bin_newton(6);
                enabledAddon();
                datalayerTinkaJugada(this,'Elige 6 números o más','Button','Jugar');
            });

            function bin_newton(cantidad) {
		        var deduct_1 = 1;
		        var deduct_2 = 1;
		        var count_2 = cantidad - 6;
		        variable = factorial(cantidad) / (720 * (factorial(count_2)));
		        return variable
		    }
		 
			function factorial(cantidad) {
			        if (cantidad < 0)return 0; else if (cantidad > 1)return cantidad * factorial(cantidad - 1);
			        return 1
			}
			
            $(".close_f").on("click",function(){
				$(".f_error_mensaje").hide();
			});
            
            var aux = 0;
		  	$(' .checkboxes-ball input').on( 'change', function() {
		  		$(".f_error_mensaje").hide();
		  		var $this = $( this );
		  		if ($this.is(':checked')){
		  			$this.closest('label').addClass('checkedlabel');
		  			countballs++;		  			
		  			if (countballs > 6) {
		  				var jugadas = bin_newton(countballs);
		  				if (jugadas>$limiteJugadas) {		  						
		  					$this.prop('checked',false);
		  					desplegarModal('Máximo '+$limiteJugadas+' jugadas');
		  					taggingPopupError('Máximo '+$limiteJugadas+' jugadas');
		  				} else {
		  					bets=bin_newton(countballs);
				  		}
		  			} else if (countballs > 5) {
	  					bets=bin_newton(countballs);
			  		}
		  		}	
				else {
				    countballs--;
				    if(countballs>=6) bets=bin_newton(countballs);
				    else bets=0;
				    $this.closest('label').removeClass('checkedlabel');		    
				}	  		
		  	});
            
            $(document).undelegate('input[type=checkbox]', 'change')
            $(document).delegate('input[name=kb]', 'change', function (event) {
                if ($(this).attr('id').substring(0, 2) == 'kb') {
                    if ($(this).prop("checked")) {
                        count++;
                        if (count > 12) {
                            $(this).prop('checked', false);
                            count--
                        }
                    } else {
                        count--
                    }
                }
                enabledAddon()
            });

           $(document).delegate('#game_kabala_show_menu', 'click', function () {
                window.location.href = 'game_kabala_show_menu.html'
           });

           function desplegarModal(mensaje){
				$(".f_error_mensaje").show();
				$(".f_textoInterno").html(mensaje);				
			}

            $(document).delegate('#plus', 'change', function (e) {
                var $chauChamba = $('#btn_mobile_chau_chamba_kabala');
                $(this).prop('checked') ? $chauChamba.prop('disabled', false) : $chauChamba.prop('disabled', true).prop('checked', false)
            });
        });

    </script>
    

</body>
</html>