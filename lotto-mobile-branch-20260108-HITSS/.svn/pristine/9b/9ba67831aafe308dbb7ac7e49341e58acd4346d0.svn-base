                            </div>
                            <c:if test="${plusBoolean && chauchambaBoolean}">
                                <div class="sub-body-game">
                                    <div class="optional">
                                        <h5>OPCIONAL:</h5>
                                    </div>
                                    <p>Marca la casilla S/1.00 adicional</p>
                                    <div class="box-checkbox"> 
                                        <input type="checkbox" name="chau_chamba" id="btn_mobile_chau_chamba_kabala" value="Chau Chamba" />
                                        <label for="btn_mobile_chau_chamba_kabala"><img src="layer-view-image/v2/logo-chauchamba.png" alt="kabala"  style="height: 54px" /></label>
                                    </div>
                                    <p>Gana S/. 5,000 mensuales por 20 ańos</p>
