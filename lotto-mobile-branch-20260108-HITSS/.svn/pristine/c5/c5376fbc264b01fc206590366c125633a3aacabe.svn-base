package pe.com.intralot.loto.layer.model.pojo;

import javax.persistence.Column;
import javax.persistence.Entity;
import javax.persistence.Id;
import javax.persistence.Table;

@Entity
@Table(name = "PORTALDATA.TB_UBICACION_TERMINAL")
public class UbicacionTerminal {
	@Id
	@Column(name = "UB_ID")
	private Integer id;
	
	@Column(name = "DEP_ID")
	private String departmentId;

	@Column(name = "PRO_ID")
	private String provinceId;

	@Column(name = "DIS_ID")
	private String districtId;

	@Column(name = "UB_DIRE")
	private String address;

	@Column(name = "UB_X")
	private String length;
	
	@Column(name = "UB_Y")
	private String latitude;

	@Column(name = "UB_REFERENCIA")
	private String reference;
	
	@Column(name = "UB_TERMINAL")
	private int term;
	
	@Column(name = "UB_TIPOGEO")
	private String typeGeo;
	
	@Column(name = "UB_MODO")
	private String modo;
	
	@Column(name = "UB_STATUS")
	private String status;
	
	@Column(name = "UB_TERMINAL_ATRIS")
	private String termAtris;
	
	@Column(name = "UB_TERMINAL_CORONIS")
	private String termCoronis;

	@Column(name = "UB_NOMPOS")
	private String luckyPoint;
	
	@Column(name = "UB_NOMDIS")
	private String districtPoint;
	
	
	public Integer getId() {
		return id;
	}

	public void setId(Integer id) {
		this.id = id;
	}

	public String getDepartmentId() {
		return departmentId;
	}

	public void setDepartmentId(String departmentId) {
		this.departmentId = departmentId;
	}

	public String getProvinceId() {
		return provinceId;
	}

	public void setProvinceId(String provinceId) {
		this.provinceId = provinceId;
	}

	public String getDistrictId() {
		return districtId;
	}

	public void setDistrictId(String districtId) {
		this.districtId = districtId;
	}

	public String getAddress() {
		return address;
	}

	public void setAddress(String address) {
		this.address = address;
	}

	public String getLength() {
		return length;
	}

	public void setLength(String length) {
		this.length = length;
	}

	public String getLatitude() {
		return latitude;
	}

	public void setLatitude(String latitude) {
		this.latitude = latitude;
	}

	public String getReference() {
		return reference;
	}

	public void setReference(String reference) {
		this.reference = reference;
	}

	public int getTerm() {
		return term;
	}

	public void setTerm(int term) {
		this.term = term;
	}

	public String getTypeGeo() {
		return typeGeo;
	}

	public void setTypeGeo(String typeGeo) {
		this.typeGeo = typeGeo;
	}

	public String getModo() {
		return modo;
	}

	public void setModo(String modo) {
		this.modo = modo;
	}

	public String getStatus() {
		return status;
	}

	public void setStatus(String status) {
		this.status = status;
	}

	public String getTermAtris() {
		return termAtris;
	}

	public void setTermAtris(String termAtris) {
		this.termAtris = termAtris;
	}

	public String getTermCoronis() {
		return termCoronis;
	}

	public void setTermCoronis(String termCoronis) {
		this.termCoronis = termCoronis;
	}

	public String getLuckyPoint() {
		return luckyPoint;
	}

	public void setLuckyPoint(String luckyPoint) {
		this.luckyPoint = luckyPoint;
	}

	public String getDistrictPoint() {
		return districtPoint;
	}

	public void setDistrictPoint(String districtPoint) {
		this.districtPoint = districtPoint;
	}
	
	
	
}
