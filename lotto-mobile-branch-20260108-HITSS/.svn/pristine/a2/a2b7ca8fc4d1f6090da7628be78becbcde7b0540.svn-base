body {
	background: rgb(197, 204, 211);
	font-family: Arial;

	padding: 0;
	-webkit-user-select: none;
	-webkit-text-size-adjust: none;
}

/***** List (base) ******/
ul {
	color: black;
	background: #fff;
	font: 12px Arial;
	padding: 0;
	margin: 15px 10px 17px 0;
	border-radius: 8px;
	list-style-type: none;
}

ul.listContent{
	border: 1px solid #B4B4B4;
	border-top: 0px;
}

/* FONDO DEL CONTENEDOR GENERAL DE LA PAGINA */
ul.listContentCuadro{
	background: #ffffff;
    background-image: -webkit-gradient(linear, left top, left bottom, from(#ffffff), to(#d9d9d9) );
	background-image: -webkit-linear-gradient(#ffffff, #d9d9d9);
	background-image: -moz-linear-gradient(#ffffff, #d9d9d9);
	background-image: -ms-linear-gradient(#ffffff, #d9d9d9);
	background-image: -o-linear-gradient(#ffffff, #d9d9d9);
	background-image: linear-gradient(#ffffff, #d9d9d9);
}

/* FONDO DEL MENU INFERIOR */
ul.listContentMenu{
	font-size: 17px;
	background: #e1e2df;
    background-image: -webkit-gradient(linear, left top, left bottom, from(#e1e2df), to(#f1f1f0) );
	background-image: -webkit-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -moz-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -ms-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -o-linear-gradient(#e1e2df, #f1f1f0);
	background-image: linear-gradient(#e1e2df, #f1f1f0);
}

/* universal arrows */
ul li.arrow {
	color: #666;
	border-top: 1px solid #B4B4B4;
	list-style-type: none;
	padding: 10px 10px 10px 10px;
	background-position: right center;
	background-repeat: no-repeat;
}

/* universal links on list */
ul li a,li.img a+a {
	color: #000;
	text-decoration: none;
	text-overflow: ellipsis;
	white-space: nowrap;
	overflow: hidden;
	/*
	display: block;
	padding: 12px 10px 12px 10px;
	*/
	-webkit-tap-highlight-color: rgba(0, 0, 0, 0)
}


/* standard mini-label */
ul li small {
	color: #369;
	font: 17px Helvetica;
	text-align: right;
	text-overflow: ellipsis;
	white-space: nowrap;
	overflow: hidden;
	display: block;
	width: 23%;
	float: right;
	padding: 7px 0 0 0
}

/* BARRA SUPERIOR INTRALOT */
.ui-bar-c {
	border: 1px solid #FA8F07;
	color: #fff;
	font-weight: bold;
	text-shadow: 0 1px 0 #eee;
	background: #FA8F07;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#FA8F07), to(#f28704) );
	background-image: -webkit-linear-gradient(#FA8F07, #f28704);
	background-image: -moz-linear-gradient(#FA8F07, #f28704);
	background-image: -ms-linear-gradient(#FA8F07, #f28704);
	background-image: -o-linear-gradient(#FA8F07, #f28704);
	background-image: linear-gradient(#FA8F07, #f28704);
}

/* BARRA JUEGO */
.ui-bar-b {
	border: 0px solid #ffbd00;
	color: #fff;
	font-weight: bold;
	text-shadow: 0 -1px 1px #86278c;
	background: #fef103;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#fef103), to(#ffbd00) );
	background-image: -webkit-linear-gradient(#fef103, #ffbd00);
	background-image: -moz-linear-gradient(#fef103, #ffbd00);
	background-image: -ms-linear-gradient(#fef103, #ffbd00);
	background-image: -o-linear-gradient(#fef103, #ffbd00);
	background-image: linear-gradient(#fef103, #ffbd00);
}

/* FONDO DE PAGINA */
.ui-body-c,.ui-dialog.ui-overlay-c {
	border: 1px solid #b3b3b3;
	color: #333;
	text-shadow: 0 1px 0 #fff;
	background: #0498e3;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#0498e3), to(#3653a1) );
	background-image: -webkit-linear-gradient(#0498e3, #3653a1);
	background-image: -moz-linear-gradient(#0498e3, #3653a1);
	background-image: -ms-linear-gradient(#0498e3, #3653a1);
	background-image: -o-linear-gradient(#0498e3, #3653a1);
	background-image: linear-gradient(#0498e3, #3653a1);
}

/* BOTON 1 */
.ui-btn-up-d {
	background: #c9140b;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#c9140b), to(#831311) );
	background-image: -webkit-linear-gradient(#c9140b, #831311);
	background-image: -moz-linear-gradient(#c9140b, #831311);
	background-image: -ms-linear-gradient(#c6140b, #831311);
	background-image: -o-linear-gradient(#c9140b, #831311);
	background-image: linear-gradient(#c9140b, #831311);
    background: linear-gradient(#c9140b, #831311) repeat scroll 0 0 #2567AB;
    border: 0px solid #c9140b;
    color: #FFFFFF;
    font-weight: bold;
    text-shadow: 0 -1px 1px #c9140b;
}

/* BOTON 1*/
.ui-btn-hover-d {
	background: #c9140b;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#c9140b), to(#831311) );
	background-image: -webkit-linear-gradient(#c9140b, #831311);
	background-image: -moz-linear-gradient(#c9140b, #831311);
	background-image: -ms-linear-gradient(#c6140b, #831311);
	background-image: -o-linear-gradient(#c9140b, #831311);
	background-image: linear-gradient(#c9140b, #831311);
    background: linear-gradient(#c9140b, #831311) repeat scroll 0 0 #2567AB;
    border: 0px solid #c9140b;
    color: #FFFFFF;
    font-weight: bold;
    text-shadow: 0 -1px 1px #c9140b;
}

/* BOTON 2 */
.ui-btn-up-e {
	background: #87278b;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#87278b), to(#68206c) );
	background-image: -webkit-linear-gradient(#87278b, #68206c);
	background-image: -moz-linear-gradient(#87278b, #68206c);
	background-image: -ms-linear-gradient(#c6140b, #68206c);
	background-image: -o-linear-gradient(#87278b, #68206c);
	background-image: linear-gradient(#87278b, #68206c);
    background: linear-gradient(#87278b, #68206c) repeat scroll 0 0 #2567AB;
    border: 0px solid #87278b;
    color: #FFFFFF;
    font-weight: bold;
    text-shadow: 0 -1px 1px #87278b;
}

/* BOTON 2*/
.ui-btn-hover-e {
	background: #87278b;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#87278b), to(#68206c) );
	background-image: -webkit-linear-gradient(#87278b, #68206c);
	background-image: -moz-linear-gradient(#87278b, #68206c);
	background-image: -ms-linear-gradient(#c6140b, #68206c);
	background-image: -o-linear-gradient(#87278b, #68206c);
	background-image: linear-gradient(#87278b, #68206c);
    background: linear-gradient(#87278b, #68206c) repeat scroll 0 0 #2567AB;
    border: 0px solid #87278b;
