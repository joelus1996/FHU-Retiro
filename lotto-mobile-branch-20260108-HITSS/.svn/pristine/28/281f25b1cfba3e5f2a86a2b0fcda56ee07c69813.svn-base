package pe.com.intralot.loto.layer.dto.client;

import java.util.List;

public class ClientBalanceDataDTO {
	private Double total;
	private List<ClientBalanceDTO> balances;
	
	public Double getTotal() {
		return this.total;
	}
	
	public void setTotal(Double total) {
		this.total = total;
	}
	
	public List<ClientBalanceDTO> getBalances() {
		return this.balances;
	}
	
	public void setBalances(List<ClientBalanceDTO> balances) {
		this.balances = balances;
	}
}
