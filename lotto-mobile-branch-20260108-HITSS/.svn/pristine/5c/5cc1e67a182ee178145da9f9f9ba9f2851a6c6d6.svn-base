    label[name=lblCodPromo] {
		top: 0px !important;
	}
	
	.ilot .form__input.focus label, .ilot .form__input.filled label {
		top: -6px !important;
	}
}

.lista-alpha {counter-reset: list;}
ul.lista-alpha > li{list-style:none;position:relative;margin:5px 0 5px 0;}
ul.lista-alpha > li:before{counter-increment:list;content:counter(list, lower-alpha) ") ";position:absolute;left:-1.4em;font:bold 13px Arial, Helvetica, sans-serif;color:#5e5e5e;line-height:16px;}

