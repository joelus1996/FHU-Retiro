.icono-download::before {
  font-family: 'ilot' !important;
  speak: none;
  font-style: normal;
  font-weight: normal;
  font-variant: normal;
  text-transform: none;
  line-height: 1;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  content: '\e906';
  display: block;
  position: absolute;
  font-size: 24px;
  left: -2px;
  top: -2px;
  -webkit-transition: all 0.3s;
  transition: all 0.3s;
  pointer-events: none;
  display: contents;
}
