package pe.com.intralot.loto.layer.dto.golden;

import java.util.List;

import com.google.gson.annotations.SerializedName;

public class DetailsDog {

	@SerializedName("events")
	private List<EventDog> events;

	public List<EventDog> getEvents() {
		return events;
	}

	public void setEvents(List<EventDog> events) {
		this.events = events;
	}
	
}
