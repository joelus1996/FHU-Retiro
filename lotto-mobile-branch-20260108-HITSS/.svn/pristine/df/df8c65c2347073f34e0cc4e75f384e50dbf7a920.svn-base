		public String toString(){
			return "eventpk:"+eventpk
					+" descripcion:"+descripcion+" score_1_0:"+score_1_0+" score_2_0:"+score_2_0+" score_2_1:"+score_2_1
					+" score_3_0:"+score_3_0+" score_3_1:"+score_3_1+" score_3_2:"+score_3_2+" score_4_0:"+score_4_0
					+" score_4_1:"+score_4_1+" score_4_2:"+score_4_2+" score_4_3:"+score_4_3+" score_5m_0:"+score_5m_0
					+" score_5m_1:"+score_5m_1+" score_5m_2:"+score_5m_2+" score_5m_3:"+score_5m_3+" score_5m_4:"+score_5m_4
					+" te_score:"+te_score_+" score_1_1:"+score_1_1+" score_2_2:"+score_2_2+" score_3_3"+score_3_3+" score_4_4:"+score_4_4
					+" score_5_5:"+score_5_5+" score_0_1:"+score_0_1+" score_0_2:"+score_0_2+" score_1_2:"+score_1_2+" score_0_3:"+score_0_3
					+" score_1_3:"+score_1_3+" score_2_3:"+score_2_3+" score_0_4:"+score_0_4+" score_1_4:"+score_1_4+" score_2_4:"+score_2_4
					+" score_3_4:"+score_3_4+" score_0_5m:"+score_0_5m+" score_1_5m:"+score_1_5m+" score_2_5m:"+score_2_5m+" score_3_5m:"+score_3_5m
					+" score_4_5m:"+score_4_5m+" teamLocal:"+teamLocal+" teamVisitor:"+teamVisitor+" ideLeague:"+ideLeague
					+" positionLocal:"+positionLocal+" positionVisitor:"+positionVisitor+" datePrincipal:"+datePrincipal
					+" closeDate:"+closeDate+" closeHour:"+closeHour+" closeMinute:"+closeMinute+" minimum:"+minimum+" unoLoad:"+unoLoad
