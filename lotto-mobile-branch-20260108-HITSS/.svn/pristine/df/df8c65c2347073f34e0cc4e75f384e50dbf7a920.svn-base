					+" lower2:"+lower2+" ower2:"+ower2+" mode:"+mode+" status:"+status+" result:"+result+" loResult:"+loResult
					+" teH1Load:"+teH1Load+" teH2Load:"+teH2Load+" teHXLoad:"+teHXLoad+" teHf11Load:"+teHf11Load+" teHfX1Load:"+teHfX1Load
					+" teHf21Load:"+teHf21Load+" teHf1xLoad:"+teHf1xLoad+" teHfXxLoad:"+teHfXxLoad+" teHf2xLoad:"+teHf2xLoad
					+" teHf12Load:"+teHf12Load+" teHfX2Load:"+teHfX2Load+" teHf22Load:"+teHf22Load+" teSum01Load:"+teSum01Load
					+" teSum23Load:"+teSum23Load+" teSum4mLoad:"+teSum4mLoad;
