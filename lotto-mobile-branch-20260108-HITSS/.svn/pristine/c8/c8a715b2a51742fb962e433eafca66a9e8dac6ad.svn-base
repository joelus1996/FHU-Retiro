	</div>	
	<div class="sub-header">
		<c:if test="${!empty clientId && agreement!=''}">
			<div class="cont-header user-data"  style="padding: .2em 1.0em;">
				<div class="text-header text-name"><b>${username}</b></div>
				<div class="text-header text-money">Saldo: <span id="clientSale-amount">${saldo}</span></div>
				<div class="text-header text-money">Bono Te Apuesto: <span id="billetera2-amount">${bonoTeApuesto}</span></div>
				<div class="text-header text-money">Jugadas gratis: <span>${bonoOtro}</span></div>
			</div>
		</c:if>
<!-- 		<div class="cont-header"> -->
<!-- 			<a href="#" onclick="window.location.href = 'home.html';"> -->
<!-- 				<img src="layer-view-image/v2/home.svg" alt="" /> -->
<!-- 			</a> -->
<!-- 		</div>	 -->
		<c:if test="${LottoCar > 0}" >	
				<span id="open-button-card" class="cart-count">${LottoCar}</span>
		 </c:if>
		<div class="cont-header">
			<a id="open-button" style="padding: 9px 0px;padding-right:1px;">
					<img src="layer-view-image/v2/menu.svg" alt="" style="height: 25px;" />	
			</a>
		</div>
		
	</div>
</header>

