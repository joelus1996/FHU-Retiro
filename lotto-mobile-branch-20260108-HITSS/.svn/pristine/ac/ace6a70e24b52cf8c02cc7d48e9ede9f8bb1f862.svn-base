/****/
/*style de combobox*/
div.selectBox {
    position: relative;
    width: 134px;
    height: 18px;
    border: 1px solid #949494;
    background: #e4e4e2 url(../../../layer-view-image/common/flecha-combo.png) no-repeat 120px 8px;
    border-radius: 5px;
    font-size: 10px;
    top: -2px;
    behavior: url(layer-view-script/common/PIE/PIE.htc)
}
div.selectBox div.box {
    position: absolute;
    left: 6px;
    top: 1px;
    width: 124px;
    height: 18px;
    line-height: 17px;
    font-size: 10px;
    color: #4e4e4d;
    overflow: hidden
}
div.selectBox select {
    background: #e4e4e2;
    width: 124px;
    height: 18px;
    font-size: 10px;
    border: 1px solid #949494;
    opacity: 0;
    filter: alpha(Opacity=0);
    cursor: pointer;
    font-size: 10px;
    z-index: 1
}
div.selectBox select option {
    font-size: 10px;
    color: #4e4e4d;
    border-bottom: 1px solid #e4e4e2;
    cursor: pointer
}
div.selectBox select option.ultimo {    border-bottom: 0 none}
#help {
    background: url(../../../layer-view-image/common/ayuda.png) no-repeat;
    background-position: 0 0;
    cursor: pointer;
    margin-top: -36px;
    width: 60px;
    margin-left: 550px;
    height: 30px;
    display: block;
}
#help:hover {
    background-position: 0 -36px;
}
.visible {
    position: absolute;
    visibility: hidden;
    width: 0;
    height: 0
}
