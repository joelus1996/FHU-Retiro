.transition-one-award {
    background: #ffffff url(../../../layer-view-image/game/tinka/transition-one-award.png) no-repeat 7px;
    width: 409px;
    height: 23px;
    border-radius: 5px 5px 0 0;
    padding: 5px 7px 4px 0;
    margin: 65px 0 0 0;
}
.transition-two-award {
    background: #ffffff url(../../../layer-view-image/game/tinka/transition-two-award.png) no-repeat 7px;
    width: 409px;/*308px;*/
    height: 23px;
    border-radius: 5px 5px 0 0;
    padding: 5px 7px 4px 0;
    margin: 65px 0 0 0;
}
/*******/

.midiv {
    height: 600px;
}
.Header{align-items:center;background:#4aaf6c;display:flex;justify-content:space-between;height:60px;padding:0 20px}
@media (max-width:93px){
	.Header{
	height:60px
	}
}
.Header .Logo{
	height:100%
}
.Header .Logo img{
	max-height:100%
}
.Header .UserActions{
	color:#000
}
@media (max-width:93px){
	.Header .UserActions{
	font-size:14px
	}
}
.Header .UserActions a{
	color:#fff
}
.Button{
	align-items:center;
	border:1;
	border-color: black;
	border-radius:2px;
	box-sizing:border-box;
	box-shadow:0 0 2px rgba(0,0,0,.12),0 2px 2px rgba(0,0,0,.2);
	color:#000!important;
	cursor:pointer;
	display:flex;
	font-size:16px;
	height:52px;
	justify-content:center;
	padding:7px;
	text-align:center;
	text-decoration:none!important;
	text-transform:uppercase;
	transition:box-shadow easi-in-out .2s,background .125s ease,color .125s ease;
	touch-action:none;
	-webkit-user-select:none;
	-moz-user-select:none;
	-ms-user-select:none;
	user-select:none;
	z-index:2;
	white-space:nowrap
}
.Button:active,.Button:focus{
	outline:none
}
.Button--primary{
	background-color:#ff8a23;
	color:#fff;
	color:#fff!important
}
.Button--primary:hover{
	background-color:#3b8b56
}
.Button--primary:focus{
	text-decoration:none;
	outline:none
}
.Button--primary:active{
	text-decoration:none;
	-webkit-transform:scale(.99);
	transform:scale(.99)
}
.Button--primary.Btn--inverted{
	background:#fff;
	color:#4aaf6c
}
.Button--primary.Btn--inverted:hover{
	background-color:#e6e6e6
}
.Button--primary.is-active{
	background-color:#3b8b56
}
.Button--primary+.Btn__extended-nav{
	background:#15321f
}
.Button--primary+.Btn__extended-nav ul li{
	color:#fff;
	border-color:#2c6740
}
.Button--primary+.Btn__extended-nav ul li:hover span{
	background:#2c6740
}
.Button--primary+.Btn__extended-nav ul li:active{
	text-decoration:none;
	-webkit-transform:scale(.99);
	transform:scale(.99)
}
.Button--secondary{
	background-color:#eceff1;
	color:#fff
}
.Button--secondary:hover{
	background-color:#cfd6db
}
.Button--secondary:focus{
	text-decoration:none;
	outline:none
}
.Button--secondary:active{
	text-decoration:none;
	-webkit-transform:scale(.99);
	transform:scale(.99)
}
.Button--secondary.Btn--inverted{
	background:#fff;color:#eceff1
}
.Button--secondary.Btn--inverted:hover{
	background-color:#e6e6e6
}
.Button--secondary.is-active{
	background-color:#cfd6db
}
.Button--secondary+.Btn__extended-nav{
	background:#8598a5
}
.Button--secondary+.Btn__extended-nav ul li{
	color:#fff;
	border-color:#b1bec6
}
.Button--secondary+.Btn__extended-nav ul li:hover span{
	background:#b1bec6
}
.Button--secondary+.Btn__extended-nav ul li:active{
	text-decoration:none;
	-webkit-transform:scale(.99);
	transform:scale(.99)
}
.GameSearch{
	display:flex;
	margin:20px auto;
	width:50%
}
@media (max-width:93px){
	.GameSearch{
	width:90%
	}
}
.GameSearch input.search{
	border:0;
	box-sizing:border-box;
	box-shadow:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.12);
	box-shadow:0 1px 8px 0 rgba(0,0,0,.14);
	padding:8px 20px;
	height:100%;
	outline:0;
	transition:box-shadow .3s cubic-bezier(.25,.8,.25,1);
	width:60%
}
.GameSearch input.search:focus{
	box-shadow:0 3px 12px -1px rgba(0,0,0,.3)
}
.GameSearch select{
	width:20%
}
@media (max-width:93px){
	.GameSearch select{
	width:40%
	}
}
.GameSearch .GridStyleToggle{
	align-items:center;
	display:flex;
	justify-content:center;
	width:20%
}
@media (max-width:93px){
	.GameSearch .GridStyleToggle{
	display:none
	}
}
.GameSearch .GridStyleToggle label{
	color:#fff;
	margin:0;
	margin-right:10px
}
.GameSearch .GridStyleToggle .StyleToggle{
	display:block;
	cursor:pointer;
	position:relative;
	width:70px;
	height:35px;
	-webkit-appearance:none;
	background:#4aaf6c;
	outline:none;
	border-radius:60px;
	transition:.5s
}
.GameSearch .GridStyleToggle .StyleToggle:checked{
	background:#2c6740
}
.GameSearch .GridStyleToggle .StyleToggle:before{
	content:"SS";
	position:absolute;
	width:35px;
	height:35px;
	border-radius:60px;
	line-height:35px;
	top:0;left:0;
	-webkit-transform:scale(1.1);
	transform:scale(1.1);
	background:#fff;
	text-align:center;
	transition:.5s
}
.GameSearch .GridStyleToggle .StyleToggle:checked:before{
	content:"T";
	left:50%
}
.GridWrapper h1{
	color:#fff;
	display:flex;
	margin:30px 15px auto;
	justify-content:center;
	width:100%
}
.GridList{
	display:flex;
	flex-flow:row wrap;
	list-style:none;
	padding:0;
	margin:0 auto;
	margin-right: -21px;
	max-width:1350px
}
.GridList .GridItem{
	/*background:#3b3b3b;*/
	border-radius:11px;
	box-shadow:0 1px 3px rgba(0,0,0,.12),0 1px 2px rgba(0,0,0,.24);
	cursor:pointer;
	margin:5px;
	margin-bottom: 13px;
	position:relative;
	width:calc(33% - 16px);
	transition:box-shadow .3s cubic-bezier(.25,.8,.25,1),-webkit-transform .3s cubic-bezier(.25,.8,.25,1);
	transition:box-shadow .3s cubic-bezier(.25,.8,.25,1),transform .3s cubic-bezier(.25,.8,.25,1);
	transition:box-shadow .3s cubic-bezier(.25,.8,.25,1),transform .3s cubic-bezier(.25,.8,.25,1),-webkit-transform .3s cubic-bezier(.25,.8,.25,1)
}
/*@media (max-width:1230px){
	.GridList .GridItem{
	width:calc(50% - 83px)
	}
}*/
@media (max-width:93px){
	.GridList .GridItem{
	margin:2% auto;
	width:46%}
}
.GridList .GridItem--thumbnail{
	background-size:cover;
	background-repeat:no-repeat;
	background-position:50%;
	color:#fff;
	height:152px;
	padding-top:20px;
	text-align:center
}
@media (max-width:93px){
	.GridList .GridItem--thumbnail{
	height:140px
	}
}
.GridList .GridItem--screenshot{
	background-size:contain;
	background-repeat:no-repeat;
	background-position:bottom;
	color:#fff;
	height:350px;
	padding-top:20px;
	text-align:center
}
@media (max-width:93px){
	.GridList .GridItem--screenshot{
	height:140px}
}
.GridList .GridItem--slots .GridItem--screenshot{
	height:214px
}
.GridList .GridItem .GridItemOverlay{
	background:rgba(0,0,0,.7);
	position:absolute;
	height:100%;
	width:100%;
	left:0;
	top:0;
	bottom:0;
	right:0;
	opacity:0;
	transition:opacity .3s ease-in-out
}
@media (max-width:93px){
	.GridList .GridItem .GridItemOverlay{
	display:none
	}
}
.GridList .GridItem .GridItemOverlayContent{
	position:absolute;
	text-align:center;
	padding-left:1em;
	padding-right:1em;
	width:100%;
	left:50%;
	opacity:0;
	top:80%;
	-webkit-transform:translate(-50%,-50%);
	transform:translate(-50%,-50%);
	transition:top .3s ease-in-out,left .3s ease-in-out,opacity .3s ease-in-out
}
@media (max-width:93px){
	.GridList .GridItem .GridItemOverlayContent{
	opacity:1;
	top:0;
	left:0;
	-webkit-transform:none;
	transform:none;
	padding:0;
	position:relative
	}
}
.GridList .GridItem .GridItemOverlayContent--info{
	color:#fff;
	font-size:18px;
	height:40px;
	line-height:40px;
	padding:0 10px;
	text-align:center
}
@media (max-width:93px){
	.GridList .GridItem .GridItemOverlayContent--info{
	display:none
	}
}
.GridList .GridItem .GridItemOverlayContent--actions{
	box-sizing:border-box;
	display:flex;
	flex-flow:row;
	justify-content:space-between;
	padding:10px;
	width:100%
}
.GridList .GridItem .GridItemOverlayContent--actions .Button{
	margin:auto;
	width:48%;
	font-size: 13px;
}/*
.GridList .GridItem:hover{
	box-shadow:0 14px 28px rgba(0,0,0,.25),0 10px 10px rgba(0,0,0,.22);
	-webkit-transform:scale(1.09);
	transform:scale(1.09)
}*/
.GridList .GridItem:hover .GridItem--thumbnail{
	color:#3b3b3b
}
.GridList .GridItem:hover .GridItemOverlay{
	opacity:1
}
.GridList .GridItem:hover .GridItemOverlayContent{
	top:50%;
	left:50%;
	opacity:1
}
@media (max-width:93px){
	.GridList .GridItem:hover .GridItemOverlayContent{
	opacity:1;
	top:0;
	left:0}
}
.GridList[data-liststyle=thumbnail] .GridItem--thumbnail{
	display:flex
}
.GridList[data-liststyle=thumbnail] .GridItem--screenshot{
	display:none
}
.GridList[data-liststyle=screenshot] .GridItem{
	background:transparent;
	box-shadow:none!important
}
@media (max-width:93px){
	.GridList[data-liststyle=screenshot] .GridItem{
	background:#3b3b3b
	}
}
.GridList[data-liststyle=screenshot] .GridItem--thumbnail{
	display:none
}
.GridList[data-liststyle=screenshot] .GridItem--screenshot{
	display:flex
}
@media (max-width:93px){
	.GridList[data-liststyle=screenshot] .GridItem--screenshot{
	height:210px
	}
}
.CasinoContainer{
	background:#263238;
	display:flex;
	flex-flow:row;
	justify-content:space-between;
	margin:auto;
	margin-top:20px;
	position:relative;
	width:90%
}
.CasinoContainer .MobileFrame{
	display:none;
	background-image:url("/img/iphone8.png");
	background-size:contain;
	background-repeat:no-repeat;
	height:100%;
	width:100%;
	position:absolute;
	pointer-events:none;
	z-index:2
}
.CasinoContainer[data-gamechannel=mobile]{
	background:transparent
}
.CasinoContainer[data-gamechannel=mobile] .MobileFrame{
	display:block
}
.GameContainer{
	box-sizing:border-box;
	box-shadow:0 14px 28px rgba(0,0,0,.25),0 5px 10px rgba(0,0,0,.5);
	width:100%
}
.GameContainer #game{
	border:none;
	z-index:1
}
.GameContainer[data-gamechannel=mobile]{
	box-shadow:none;
	padding:13% 4% 23% 3.5%
}
.Sidebar{
	background:#232d32;
	box-sizing:border-box;
	bottom:0;
	color:#fff;
	padding:20px;
	top:0;
	width:300px
}

.box-main-game-alert-iivv {
    background-color: #ff5232;
    color: white;
    font-size: 19px;
    text-align: center;
    border-radius: 0%;
    padding: 10px;
}

.popup .GridItemPrecio {
    color: #fff;
    font-size: 18px;
    font-weight: bold;
    padding-left: 27%;
    text-align: center;
    margin-top: 8px;
    position: absolute;
    transition: top .3s ease-in-out,left .3s ease-in-out,opacity .3s ease-in-out;
}


/*+++++++++++++*/
.raspaditaItem {
    height: 57%;
    width: 81%;
    position: fixed;
    display: flex;
    align-items: center;
    text-align: center;
    border-radius: 10px;
}

.raspaditaItem:before {
    content: '';
    background: linear-gradient(25deg, #ffffff, #ffe600, #f73d3d);
    background-size: 600% 600%;
    -webkit-animation: AnimationName 2s ease infinite;
    -moz-animation: AnimationName 2s ease infinite;
    animation: AnimationName 2s ease infinite;
    position: fixed;
    width: 84%;
    height: 68%;/*81%;*/
    top: 15%; /*10%;*/
    left: 8%;
    z-index: -1;
    border-radius: 18px;
}
.raspaditaItem h3 {
    width: 100%;
    text-align: center;
    color: white;
    padding: 20px 0px;
    margin-bottom: 0px;
    padding-bottom: 20px;
}
.raspaditaItem .imgcore {
    content: '';
    position: fixed;
    z-index: -1;
    border-radius: 16px;
    transition: 0.3s;
    transform: translateX(-50%)translateY(-50%);
    top: 52%;
    left: 50%;
    background-size: 99% 91%;
    background-repeat: no-repeat;
    width: 77%;
    height: 70%;
}
.front {
    position: fixed;
    width: 100%;
    bottom: 6%;
    color: white;
    font-size: 18px;
    transition: 0.3s;
    font-family: sans-serif;
    font-weight: bold;
    line-height: 5px;
}/*
.raspaditaItem:hover .imgcore {
    width: calc(100% - 20px);
    height: calc(100% - 20px);
}*/
.raspaditaItem:hover .front {
    transform: translateY(-10px);
    opacity: 0;
}
.raspaditaItem:hover .back {
    opacity: 1;
}
.raspaditaItem:hover:after {
    opacity: 0.7;
}
.raspaditaContent ul li {
    top: 14%;
    margin-bottom: -1px;
    cursor: pointer;
    margin: 0px;
    position: fixed;
    left: 22px;
    width: 88%;
    transition: box-shadow .3s cubic-bezier(.25,.8,.25,1),-webkit-transform .3s cubic-bezier(.25,.8,.25,1);
    transition: box-shadow .3s cubic-bezier(.25,.8,.25,1),transform .3s cubic-bezier(.25,.8,.25,1);
    transition: box-shadow .3s cubic-bezier(.25,.8,.25,1),transform .3s cubic-bezier(.25,.8,.25,1),-webkit-transform .3s cubic-bezier(.25,.8,.25,1);
}
.raspaditaContent ul li:hover:before {
    opacity: 0;
}
.raspaditaItem .buttons a.btn--secondary {
    background: #e4e4e4;
    color: #000000;
}
.raspaditaItem .buttons a.btn--primary {
	background: #fbe601;
    color: black;
}
.raspaditaItem .buttons a {
    display: block;
    max-width: 51%;
    line-height: 40px;
    margin: auto;
    margin-bottom: 10px;
    text-decoration: none;
    background: #eb8831;
    color: white;
    height: auto;
    font-size: 23px;
    padding: 0px 0px;
}

.back1 {
    width: 100%;
    position: fixed;
    height: 37%;
    z-index: 2;
    transition: 0.3s;
    bottom: 0px;
    left: 0px;
}

@-webkit-keyframes AnimationName {
    0%{background-position:11% 0%}
    50%{background-position:90% 100%}
    100%{background-position:11% 0%}
}
@-moz-keyframes AnimationName {
    0%{background-position:11% 0%}
    50%{background-position:90% 100%}
    100%{background-position:11% 0%}
}
@-ms-keyframes AnimationName {
    0%{background-position:11% 0%}
    50%{background-position:90% 100%}
    100%{background-position:11% 0%}
}
@keyframes AnimationName {
    0%{background-position:11% 0%}
    50%{background-position:90% 100%}
    100%{background-position:11% 0%}
}
