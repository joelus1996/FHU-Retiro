body {
	background: rgb(197, 204, 211);
	font-family: Helvetica;
	padding: 0;
	-webkit-user-select: none;
	-webkit-text-size-adjust: none;
}

/***** List (base) ******/
ul {
	list-style-type: none;
	color: black;
	font: bold 17px Helvetica;
	padding: 0;
	margin: 15px 10px 17px 0;
	border-radius: 8px;
	list-style-type: none;
}

ul.listContent{
	border: 1px solid #B4B4B4;
	border-top: 0px;
}

/* FONDO DEL CONTENEDOR GENERAL DE LA PAGINA */
ul.listContentCuadro{
	background: #ffffff;
    background-image: -webkit-gradient(linear, left top, left bottom, from(#ffffff), to(#d9d9d9) );
	background-image: -webkit-linear-gradient(#ffffff, #d9d9d9);
	background-image: -moz-linear-gradient(#ffffff, #d9d9d9);
	background-image: -ms-linear-gradient(#ffffff, #d9d9d9);
	background-image: -o-linear-gradient(#ffffff, #d9d9d9);
	background-image: linear-gradient(#ffffff, #d9d9d9);
}

/* FONDO DEL MENU INFERIOR */
ul.listContentMenu{
	font-size: 17px;
	background: #e1e2df;
    background-image: -webkit-gradient(linear, left top, left bottom, from(#e1e2df), to(#f1f1f0) );
	background-image: -webkit-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -moz-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -ms-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -o-linear-gradient(#e1e2df, #f1f1f0);
	background-image: linear-gradient(#e1e2df, #f1f1f0);
}

/* universal arrows */
ul li.arrow {
	color: #666;
	border-top: 1px solid #B4B4B4;
	list-style-type: none;
	padding: 10px 10px 10px 10px;
	background-position: right center;
	background-repeat: no-repeat;
}

/* universal links on list */
ul li a,li.img a+a {
	color: #000;
	text-decoration: none;
	text-overflow: ellipsis;
	white-space: nowrap;
	overflow: hidden;
	/*
	display: block;
	padding: 12px 10px 12px 10px;
	*/
	-webkit-tap-highlight-color: rgba(0, 0, 0, 0)
}


/* standard mini-label */
ul li small {
	color: #369;
	font: 17px Helvetica;
	text-align: right;
	text-overflow: ellipsis;
	white-space: nowrap;
	overflow: hidden;
	display: block;
	width: 23%;
	float: right;
	padding: 7px 0 0 0
}

/* BARRA SUPERIOR INTRALOT */
.ui-bar-c {
	border: 1px solid #FA8F07;
	background: #FA8F07;
	color: #fff;
	font-weight: bold;
	text-shadow: 0 1px 0 #eee;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#FA8F07), to(#FA8F07) );
	background-image: -webkit-linear-gradient(#FA8F07, #FA8F07);
	background-image: -moz-linear-gradient(#FA8F07, #FA8F07);
	background-image: -ms-linear-gradient(#FA8F07, #FA8F07);
	background-image: -o-linear-gradient(#FA8F07, #FA8F07);
	background-image: linear-gradient(#FA8F07, #FA8F07);
}

/* BARRA JUEGO */
.ui-bar-b {
	border: 1px solid #3ab3e8;
	color: #fff;
	font-weight: bold;
	text-shadow: 0 -1px 1px #254f7a;
	background: #3ab3e8;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#3ab3e8), to(#25AAE3) );
	background-image: -webkit-linear-gradient(#3ab3e8, #25AAE3);
	background-image: -moz-linear-gradient(#3ab3e8, #25AAE3);
	background-image: -ms-linear-gradient(#3ab3e8, #25AAE3);
	background-image: -o-linear-gradient(#3ab3e8, #25AAE3);
	background-image: linear-gradient(#3ab3e8, #25AAE3);
}

/* FONDO DE PAGINA */
.ui-body-c,.ui-dialog.ui-overlay-c {
	border: 1px solid #b3b3b3;
	color: #333;
	text-shadow: 0 1px 0 #fff;
	background: #B2E0DD;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#B2E0DD), to(#57B7DF) );
	background-image: -webkit-linear-gradient(#B2E0DD, #57B7DF);
	background-image: -moz-linear-gradient(#B2E0DD, #57B7DF);
	background-image: -ms-linear-gradient(#B2E0DD, #57B7DF);
	background-image: -o-linear-gradient(#B2E0DD, #57B7DF);
	background-image: linear-gradient(#B2E0DD, #57B7DF);
}