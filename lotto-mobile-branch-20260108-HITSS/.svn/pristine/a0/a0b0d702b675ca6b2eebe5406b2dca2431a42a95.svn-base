	<jsp:include page="../../include/footer.jsp" />

	<script type="text/javascript">
		var count=0;
		var sub_total = 0;
		function enabledAddon() {
		    // console.log(count);
		    if (count > 5) {
		        //$('#btn_mobile_chau_chamba_kabala').attr('checked', false);
		        $('#btn_mobile_chau_chamba_kabala').attr('disabled', false);
		    } else {
		        //$('#btn_mobile_chau_chamba_kabala').attr('checked', false);
		    	$('#btn_mobile_chau_chamba_kabala').attr('checked', false).attr('disabled', true);
		    }
		}
		$(document).ready(function () {	
			//3 $.mobile.defaultPageTransition = 'none';	
			$(document).delegate('#btn_mobile_chau_chamba_kabala', 'click', function() {
				datalayerTinkaJugada('Chau Chamba','Elige 6 n·meros o mßs','checkbox','Jugar');             
			});
			
			$(document).delegate('#btn_mobile_agregar_boleto_kabala', 'click', function() {
				// Se valida si el usuario tiene documentos pendientes de confirmaci¾n, el parßmetro que recibe
				// es una function que se realizarß en caso no tenga docs pendientes de confirmacion
				mainValidatePendingsDocsForAproval('interfaceBetClickwheelChchAgregarBoletoKabala');
			});

			function interfaceBetClickwheelChchAgregarBoletoKabala () {
				datalayerTinkaJugada(this,'Elige 6 n·meros o mßs','Button','Jugar');
				document.forms["game_kabala_add_bet"].submit();
			}
			
			window.addEventListener("message", function(event) {
			    if (event.data === "interfaceBetClickwheelChchAgregarBoletoKabala") {
			    	interfaceBetClickwheelChchAgregarBoletoKabala(); 
			    }
			});
			
			$(document).delegate('#clean', 'click', function() {   
				$("input[type=checkbox]:checked").each(function() {	
					$("#div_"+$(this).attr('id')).removeClass("button_select"); 		 			 
					//$(this).attr('checked', false);
					$(this).prop('checked', false);//.checkboxradio('refresh');
					$("#div_"+$(this).attr('id')).removeClass("button_select");
				});
				count=0;
				enabledAddon();
				datalayerTinkaJugada(this,'Elige 6 n·meros o mßs','Button','Jugar');
			});
			$(document).delegate('#azar', 'click', function() {				 
							 
				$("input[type=checkbox]:checked").each(function() {		
					$("#div_"+$(this).attr('id')).removeClass("button_select");	 
					$(this).attr('checked', false);
					//$(this).prop('checked', false);//.checkboxradio('refresh');
				});		     
				var count_random_kabala = 0;
				var array_random = [];
				while(count_random_kabala < 6){
					var number = Math.round(1 + (Math.random() * (40 - 1)));
					//if (jQuery.inArray(number,array_random) == -1) {
					if(array_random.indexOf(number) == -1) {
						array_random[count_random_kabala] = number;	         			         	 	 
						count_random_kabala++;
						$("#div_kb_chk_"+number).addClass("button_select");
						$("#kb_chk_" + number).attr('checked', true);
					}
				}
				/*mgRandon=Math.round(1+(Math.random()*(5-1)));
				$("#div_mg_chk_"+mgRandon).addClass("button_select"); 		 
				$("#mg_chk_"+mgRandon).attr('checked', true);//.checkboxradio('refresh');
				for (var i = 0; i < array_random.length; i++) {
					$("#kb_chk_" + array_random[i]).attr('checked', true);//.checkboxradio('refresh');
				}
				//$("#mg_chk_" + Math.round(1 + (Math.random() * (5 - 1)))).attr('checked', true).checkboxradio('refresh');*/
		        count = 6;
		        enabledAddon();
		        datalayerTinkaJugada(this,'Elige 6 n·meros o mßs','Button','Jugar');
			});
			$(document).undelegate('input[type=checkbox]', 'change');
			//$(document).delegate('[type=checkbox]', "change", function( e ) {
			$(document).delegate('input[name=kb]', 'change', function (event) {
				var countPlay = 0;
		    	var plusEnabled = "${plusBoolean}";
		    	var chauchambaEnabled = "${chauchambaBoolean}";
				if($(this).attr('id').substring(0,2)=='kb'){
					//if ( $(this).is(":checked") ){
					if ($(this).prop("checked")) {
						count ++;
						//if(count > 12){
						if(count > 15){
							//$(this).attr('checked',false);
							$(this).prop('checked', false);//.checkboxradio("refresh");
							$("#div_"+$(this).attr('id')).removeClass("button_select");
							count --;
						} else {
							$("#div_"+$(this).attr('id')).addClass("button_select");
							countPlay += (count==6)?(countPlay+=1):(count==7)?(countPlay+=7):(count==8)?(countPlay+=28):(count==9)?(countPlay+=84):(count==10)?(countPlay+=210):
		                    	(count==11)?(countPlay+=462):(count==12)?(countPlay+=924):(count==13)?(countPlay+=1716):(count==14)?(countPlay+=3003):(count==15)?(countPlay+=5005):(countPlay+=0);
		                    	if($('#btn_mobile_chau_chamba_kabala').prop('checked')) countPlay *= 2;
		                    	countPlay += parseFloat("${totalBet}");
		                    if(countPlay > 6006) {
		                    	$(this).prop('checked', false);//.checkboxradio("refresh");
		                    	$("#div_"+$(this).attr('id')).removeClass("button_select");
		                        count--;
		                    }
						}
					} else {
						$("#div_"+$(this).attr('id')).removeClass("button_select");
						count --;
					}
				}
				enabledAddon();
				if(plusEnabled.toLowerCase()=="false" && chauchambaEnabled.toLowerCase()=="true") {
		            if(countPlay >= 6006) {
		            	$('#btn_mobile_chau_chamba_kabala').attr('checked', false).attr("disabled", true);//.checkboxradio("refresh");
		            } else {
		            	$('#btn_mobile_chau_chamba_kabala').attr("disabled", false);//.checkboxradio("refresh");
		            }
		        }
			});
			$(document).delegate('#game_kabala_show_menu', 'click', function() {
				window.location.href ='game_kabala_show_menu.html';
			});
			/*$(document).delegate('#plus', 'change', function(e) {
				//$("#chau_chamba").prop("disabled", false).checkboxradio("refresh");
				//if(document.getElementById("plus").checked){
				//	$("#chau_chamba").prop("disabled", false).checkboxradio("refresh");
				//} else {
				//	$("#chau_chamba").prop("checked", false).checkboxradio("refresh");
				//	$("#chau_chamba").prop("disabled", true).checkboxradio("refresh");
				//}
				//console.log(e.target);
				var $chauChamba = $('#chau_chamba');
				$(this).prop('checked') ? $chauChamba.prop('disabled', false).checkboxradio("refresh") : $chauChamba.prop('disabled', true).prop('checked', false).checkboxradio("refresh");
			});*/
			taggingJuegaKabalaSlider();
		});
			
	</script>
	
</body>
</html>
