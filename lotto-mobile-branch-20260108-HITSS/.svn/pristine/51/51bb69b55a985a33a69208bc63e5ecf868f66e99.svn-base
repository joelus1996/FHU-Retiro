<a class="m-banner-lot m-banner-count-down open-count-down-popup" href="javascript:void(0)">
    <div class="m-banner-count-down__title m-title banner-title-count">El sorteo comienza en</div>
    <div class="m-count-down m-banner-count-down__counter">
        <div>
            <span id="hours">00</span>
            <p>Horas</p>
        </div>
        <span>:</span>
        <div>
            <span id="minutes">00</span>
            <p>Minutos</p>
        </div>
        <span>:</span>
        <div>
            <span id="seconds">00</span>
            <p>Segundos</p>
        </div>
    </div>
    <picture>
        <source srcset="./layer-view-image/game/kabala/live/bg-banner-start-lot.png 1x, ./layer-view-image/game/kabala/live/bg-banner-start-lot@2x.png 2x" />
        <img class="m-banner-count-down__bg" src=" ./layer-view-image/game/kabala/live/bg-banner-start-lot.png " alt="kabala" />
    </picture>
</a>
