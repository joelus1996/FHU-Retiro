package pe.com.intralot.loto.layer.model.bean;

import java.io.Serializable;
import java.util.List;

@SuppressWarnings("rawtypes")
public class DataGenericBet implements Serializable{
	
	private static final long serialVersionUID = 1L;
	

	private Integer consecutive;
	private List multiply;
	private List combination;
	private Integer clientId;
	private String remoteIp;
	private Double total;
	private String strTotal;
	private Long numberLotocard;
			


	public Integer getConsecutive() {
		return consecutive;
	}
	public void setConsecutive(Integer consecutive) {
		this.consecutive = consecutive;
	}
	public Integer getClientId() {
		return clientId;
	}
	public void setClientId(Integer clientId) {
		this.clientId = clientId;
	}
	public String getRemoteIp() {
		return remoteIp;
	}
	public void setRemoteIp(String remoteIp) {
		this.remoteIp = remoteIp;
	}
	public Double getTotal() {
		return total;
	}
	public void setTotal(Double total) {
		this.total = total;
	}
	public String getStrTotal() {
		return strTotal;
	}
	public void setStrTotal(String strTotal) {
		this.strTotal = strTotal;
	}
	public List getMultiply() {
		return multiply;
	}
	public void setMultiply(List multiply) {
		this.multiply = multiply;
	}
	public List getCombination() {
		return combination;
	}
	public void setCombination(List combination) {
		this.combination = combination;
	}
	public Long getNumberLotocard() {
		return numberLotocard;
	}
	public void setNumberLotocard(Long numberLotocard) {
		this.numberLotocard = numberLotocard;
	}	

}
