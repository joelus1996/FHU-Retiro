.contentpoupcrop {
  background: white;
  position: absolute;
  width: 96%;
  left: 2%;
  top: 50%;
  transform: translateY(-50%);
  padding: 50px 10px;
  padding-bottom: 20px;
}
.popupcrop {
  position: fixed;
  top: 0;
  z-index: 15000;
  background: #00000075;
  left: 0;
  width: 100%;
  height: 100%;
}
span.closepopupc:after {
  content: '';
  width: 20px;
  height: 3px;
  background: white;
  position: absolute;
  top: 17px;
  transform: rotate(-45deg);
  left: 10px;
}
span.closepopupc:before {
  content: '';
  width: 20px;
  height: 3px;
  background: white;
  position: absolute;
  top: 17px;
  transform: rotate(45deg);
  left: 10px;
}
span.close_pop {
  display: block;
  margin-top: 10px;
  border-radius: 20px;
  background: #07663a;
  padding: 10px;
  color: white;
  box-shadow: 0px 2px 3px #0000008c;
}
.contentpoupcrop h3 {
  font-size: 16px;
  color: #07663a;
  margin-bottom: 20px;
}
.popupcrop.open {
  transform: none;
}
.contentpoupcrop h4 {
  color: #07663a;
}
.contentpoupcrop h4,
.contentpoupcrop p {
  font-size: 14px;
}
.popupcrop {
  transition: 0.5s;
  transform: translateX(-100%);
}
