/*Visor te apuesto grecia retail*/
.overlay-grecia {
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.7);
  -webkit-transition: opacity 500ms;
  -moz-transition: opacity 500ms;
  -o-transition: opacity 500ms;
  transition: opacity 500ms;
  visibility: hidden;
  opacity: 0;
  z-index: 11;
}

.overlay-grecia:target,
.overlay-grecia.opened {
   visibility: visible;
  opacity: 1;
  z-index: 11;
  overflow: scroll;
}

.tableHead { background-color: black; color: white; }
.tableSubHead { background-color: #fddfc1; }
.table-gracia { width: 100%; margin-bottom: 1rem; background-color: transparent; border-collapse: collapse; }
.table-gracia tr:hover { background-color: #dee2e6;}
.table-grecia td { padding: 0.15rem; width:55%;}
.table-grecia th {padding: 0.15rem;width:45%;}
.table-bordered td, .table-bordered th {
    border: 1px solid #dee2e6;
}
.table-gracia  th {
    padding: 0.15rem;
    width: 45%;
}
.table-iflex {
	font-size: small !important;
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    color: #212529;
    text-align: left;
    background-color: #fff;}

.popup2.popup-sm2 {
    olor: #5A5A5A;
    font-size: 14px;
    line-height: 20px;
    background: #F2F2F2;
    width: 90%;
    max-width: 350px;
    position: absolute;
    z-index: 220;
    left: 50%;
    top: 50%;
    margin: 0px;
    height: auto;
    -webkit-transform: translate(-50%, -50%);
    transform: translate(-50%, -50%);
    text-align: center;
    padding-top: 30px;
    padding-bottom: 30px;
}

