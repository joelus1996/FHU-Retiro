.info{
	text-align: center;
	margin-left: 60px;
}
.info div{
	text-align: right;
	width:50%;
	float:left;
}
.info div + div{
	text-align: left;
	width:48%;
	padding-left: 2%;
}

@media (max-width: 370px) {
	.info{
		text-align: center;
		margin-left: 15px;
	}
	.info-promotion{
		text-align: left;
		margin-left: 30px;
	}
}

@media (max-width: 325px) {
	.info-promotion{
		text-align: left;
		margin-left: 10px;
	}
}
.iivv-game {
    background-size: 101%;
    padding-top: 114%;
    background-repeat: no-repeat;
    background-clip: border-box;
    background-position: center;
    transition: background-size 0.2s;
    transition-timing-function: cubic-bezier(.07,1.41,.82,1.41);
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    text-indent: 100%;
    white-space: nowrap;
}

.casino-game {
    background-size: 100% 74%;
    padding-top: 76%;
    padding-bottom: 26px;
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    background-repeat: no-repeat;
    background-clip: border-box;
    transition: background-size 0.2s;
    transition-timing-function: cubic-bezier(.07,1.41,.82,1.41);
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    text-indent: 100%;
    white-space: nowrap;
}

