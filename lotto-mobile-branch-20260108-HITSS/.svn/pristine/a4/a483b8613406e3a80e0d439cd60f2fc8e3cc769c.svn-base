body.main-ganagol {
  position: relative;
  background: transparent;
  z-index: 1;
}
.main-ganagol:before {
  background: #52c134;
  background: -moz-linear-gradient(top, #52c134 0%, #071a01 100%);
  background: -webkit-gradient(
    linear,
    left top,
    left bottom,
    color-stop(0%, #52c134),
    color-stop(100%, #071a01)
  );
  background: -webkit-linear-gradient(top, #52c134 0%, #071a01 100%);
  background: -o-linear-gradient(top, #52c134 0%, #071a01 100%);
  background: -ms-linear-gradient(top, #52c134 0%, #071a01 100%);
  background: linear-gradient(to bottom, #52c134 0%, #071a01 100%);
  filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#ffffff', endColorstr='#000000',GradientType=0 );
  position: fixed;
  top: 0;
  left: 0;
  content: '';
  height: 100%;
  z-index: -1;
  width: 100%;
}
.f_linea {
  width: 100%;
  height: 1px;
  background: white;
  margin: 15px 0px;
  margin-bottom: 20px;
}
.main-ganagol .game-desc {
  margin-top: 0;
}
.main-ganagol .game-desc h2 {
  color: #fff;
}
.main-ganagol .game-desc h4 {
  color: #fff;
}
.main-ganagol .game-price .current-price {
  color: #fff;
  text-shadow: 0 2px 2px rgba(0, 0, 0, 0.3);
}
.main-ganagol .game-price .current-date {
  color: #fff;
}
.main-ganagol .results-games .result-title h3 {
  color: #fff;
}
.main-ganagol .results-games .result-title h5 {
  color: #fff;
}
.main-ganagol .my-games .my-game .number-game h3 {
  color: #fff;
}
.main-ganagol .my-games .my-game .game-alert p {
  color: #000;
}
.main-ganagol .boxes-game-ticket .box-game-ticket .title-game-ticket h3 {
  color: #fff;
}
.main-ganagol .footer-game-tikect .content-game-ticket .field-ticket {
  color: #fff;
}
.main-ganagol .results-balls .result-ball {
  border-color: #ffd400;
  border-radius: 0.5em;
  border-width: 1px;
  margin-right: 0.2em;
  margin-left: 0.2em;
  /*background-color: #ed2915;*/
  box-shadow: none;
}
.main-ganagol .results-balls .result-ball .ball {
  height: 2em;
  width: auto;
  line-height: 2em;
  min-width: 2em;
  padding: 0 0.5em;
}
.main-ganagol .results-balls .result-ball .ball span {
  color: #fff;
}
.main-ganagol .link-block {
  color: #fff;
}
.main-ganagol .last-result {
  border-color: transparent;
  margin-bottom: 15px;
}
.main-ganagol .last-result .last-text {
  color: #fff;
}
.main-ganagol .last-result .last-date {
  color: #fff;
}
.main-ganagol .program-list {
  padding: 0.5em 0 1em;
}
.main-ganagol .program-list .program {
  display: block;
  color: #fff;
  line-height: 1.875em;
  border: 1px solid #fff;
  border-radius: 0.9375em;
  margin: 0.9em 0;
  height: auto;
}
.main-ganagol .program-list .program:hover {
  background-color: rgba(0, 0, 0, 0.2);
}
.main-ganagol .program-list .program .program-match {
  position: relative;
}
.main-ganagol .program-list .program .program-match:after {
  content: 'vs';
  position: absolute;
  left: 50%;
  width: 1em;
  margin-left: -0.5em;
  margin-top: -1.25em;
  top: 50%;
  font-size: 0.75em;
}
.main-ganagol .program-list .program .program-bet {
  font-size: 0.75em;
  line-height: 2em;
  margin-top: -0.75em;
  min-height: 0.75em;
}
.main-ganagol .program-list .program .program-team {
  vertical-align: middle;
  padding: 0 1.5em;
  line-height: 2.5em;
}
.main-ganagol .program-list .program .program-team .team-name {
  font-size: 0.75em;
}
@media (min-width: 360px) {
  .main-ganagol .program-list .program .program-team {
    display: table-cell;
    vertical-align: middle;
    padding: 0 1.5em;
    width: 50%;
    line-height: 2em;
  }
  .main-ganagol .program-list .program .program-team.team-right {
    text-align: left;
  }
  .main-ganagol .program-list .program .program-team.team-left {
    text-align: right;
  }
}
/* .main-ganagol .teams-match { */
/*   position: relative; */
/*   background-image: url('../../layer-view-image/v2/ball.png'); */
/*   background-size: 40px 40px; */
/*   background-repeat: no-repeat; */
/*   background-position: center center; */
/* } */
.main-ganagol .teams-match .team-match {
  font-size: 20px;
  color: #fff;
  line-height: 25px;
  padding: 1em 0;
  overflow: hidden;
  text-overflow: ellipsis;
}
@media (min-width: 260px) {
  .main-ganagol .teams-match .left-match,
  .main-ganagol .teams-match .right-match {
    display: table-cell;
    vertical-align: middle;
    width: 50%;
    max-width: 1em;
  }
  .main-ganagol .teams-match .left-match.right-match,
  .main-ganagol .teams-match .right-match.right-match {
    text-align: left;
    padding-left: 2.5em;
  }
  .main-ganagol .teams-match .left-match.left-match,
  .main-ganagol .teams-match .right-match.left-match {
    text-align: right;
    padding-right: 2.5em;
  }
  .main-ganagol .teams-match .team-match {
    padding: 0;
  }
}
