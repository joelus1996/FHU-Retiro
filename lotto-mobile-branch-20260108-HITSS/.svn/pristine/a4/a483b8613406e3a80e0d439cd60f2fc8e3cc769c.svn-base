  -moz-osx-font-smoothing: grayscale;
  content: '\e902';
  display: block;
  position: absolute;
  font-size: 18px;
  /*right: 300px;
  top: 364px;*/
  right: 40px;
  top: 0px;
  -webkit-transition: all 0.3s;
  transition: all 0.3s;
  pointer-events: none;
}

.modalpp .mod__text4.is-charge.opened::before {
  -webkit-transform: rotateX(180deg);
          transform: rotateX(180deg);
}

.modalpp .icon-regresar:before {
    content: "\e902";
}

