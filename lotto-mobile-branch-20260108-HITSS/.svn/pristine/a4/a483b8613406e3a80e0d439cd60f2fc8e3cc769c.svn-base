/*Estilos para el autocontrol*/
.frm-desactivar-limites{
	display: none;
}

.response.received-msg-autocontrol{display:block !important}
 

 
/*Estilos para el filtro de jugadas*/
.form_filter-j {
    -webkit-box-sizing: border-box;
    box-sizing: border-box;
    border: solid 1px #A5A5A5;
    border-radius: 5px;
    margin-bottom: 13px;
    position: relative;
    -webkit-transition: border-color .25s linear;
    transition: border-color .25s linear;
    background: white;
}

.form__input-jugadas button {
    position: absolute;
    background-image: url(../../layer-view-image/client/icon-calendar.svg);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 15px 15px;
    width: 19px;
    height: 19px;
    top: 9px;
    right: 16px;
    border: none;
    outline: none;
    cursor: pointer;
}

.form_filter-j input {
    background-color: transparent;
    border: none;
    outline: none;
    color: #000000;
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    letter-spacing: 0.25px;
    margin: 6px 0 0 16px;
    width: calc(100% - 12px);
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    height: 27px;
    cursor:pointer;
}

.filter_jugadas {
    width: 100%;
    margin: 20px 0;
    border: medium none;
    /*border-radius: 5px;*/
    padding: 10px;
}

.button_jugadas{
	border: #e30613;
    background: #e30613;
    color: #fff;
    font-size: 13px;
    border-radius: 25px;
    box-shadow: none;
    width: 100%;
    margin: 0px;
    height: 33px;
}

.button_jugadas[disabled] {
    background-color: #ced4da;
    border-color: #ced4da;
    cursor: default;
}
.sms_jugadas{
	text-align: justify;
	font-size: 13px; 
	margin: 0px 0px 11px; 
    font-family: "Roboto", sans-serif;
}

.form_filter-j label {
    color: #5A5A5A;
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    background-color: #ffffff;
    line-height: 12px;
    top: -6px;
    position: absolute;
    display: block;
    left: 16px;
}

.form__input-jugadas::before {
    font-family: 'ilot' !important;
    speak: none;
    font-style: normal;
    font-weight: normal;
    font-variant: normal;
    text-transform: none;
    line-height: 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    content: '\e90e';
    display: block;
    position: absolute;
    font-size: 17px;
    color: #7F7F7F;
    right: 8px;
    top: .48em;
    pointer-events: none;
}

/*ESTILOS PARA MOVIMIENTO DE CUENTA*/
.form_filter {
    -webkit-box-sizing: border-box;
    box-sizing: border-box;
    border: solid 1px #A5A5A5;
    border-radius: 5px;
    margin-bottom: 13px;
    position: relative;
    -webkit-transition: border-color .25s linear;
    transition: border-color .25s linear;
    background: white;
}

.form__input-filtro button {
    position: absolute;
    background-image: url(../../layer-view-image/client/icon-calendar.svg);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 15px 15px;
    width: 19px;
    height: 19px;
    top: 9px;
    right: 16px;
    border: none;
    outline: none;
    cursor: pointer;
}

.form_filter input {
    background-color: transparent;
    border: none;
    outline: none;
    color: #000000;
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    letter-spacing: 0.25px;
    margin: 6px 0 0 16px;
    width: calc(100% - 12px);
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    height: 27px;
    cursor:pointer;
}

.filter_movimientos {
    width: 100%;
    margin: 20px 0;
    border: medium none;
    padding: 10px;
}

.button_filter{
	border: #e30613;
    background: #e30613;
