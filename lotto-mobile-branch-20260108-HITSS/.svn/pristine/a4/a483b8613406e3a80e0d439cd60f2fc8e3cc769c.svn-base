.box-play.f_inline.golazo200_seccion {
    margin: 0;
}

.f_inline .box-checkbox.golazo200 [type='checkbox']:not(:checked) + label, 
.f_inline .box-checkbox.golazo200 [type='checkbox']:checked + label{
	display: inline-block;    
    width: 4.5em;
    height: 2.5em;
    line-height: 2.5em;
    text-align: center;
    transition: 0.5s;
}


.f_inline .box-checkbox.golazo200 [type='checkbox']:checked + label:before{
	border: 2px solid #ffed00;
	width: 4.5em;
}

.f_inline .box-checkbox.golazo200 [type='checkbox']:not(:checked) + label:before{
	background: transparent;
    width: 4.5em;
    height: 3.5em;
    left: 0;
    right: auto;
    border: 2px solid #fff;   
}

.f_inline .box-checkbox.golazo200 [type='checkbox']:checked + label:after{
    top: 0.45em;
    left: 1.2em;
    right: auto !important;
    font-size: 1.5em;
    color: #ffed00;
}

.f_inline .box-checkbox.golazo200 [type='checkbox']:not(:checked) + label:after{
    top: 0.45em;
    left: 0.5em;
    right: auto !important;
    font-size: 1.5em;
    color: #ffed00;
}

