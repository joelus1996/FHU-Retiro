	background-image: url("../../layer-view-image/client/icon-password-hide.svg");
    background-size: 16px 15px;
}

 .form-cambiar-password .help-block,
 .form-cambiar-password .strength-meter {
 /* position: absolute;*/
  width: 100%;
  top: 54px;
  left: 0;
  text-transform: uppercase;
  font-size: 10px;
  font-weight: 700;
  color: #5A5A5A;
  text-align: left;
  margin-bottom: 10px;
  margin-top: 5px; }
   .form-cambiar-password .help-block span,
   .form-cambiar-password .strength-meter span {
    padding-left: 15px;
    text-transform: uppercase;
    font-size: 10px;
    font-weight: 700;
    color: #5A5A5A;
    background-image: url("../../layer-view-image/client/icon-info.svg");
    background-repeat: no-repeat;
    background-position: left;
    background-size: 8px; }
   .form-cambiar-password .help-block .status-level,
   .form-cambiar-password .strength-meter .status-level {
    height: 4px;
    padding: 0;
    margin: 0 0 6px;
    list-style: none; }
     .form-cambiar-password .help-block .status-level li,
     .form-cambiar-password .strength-meter .status-level li {
      float: left;
      background: #f2f2f2;
      width: calc(33.33333% - 4px);
      height: 4px; }
       .form-cambiar-password .help-block .status-level li:nth-child(1),
       .form-cambiar-password .strength-meter .status-level li:nth-child(1) {
        border-top-left-radius: 2px;
        border-bottom-left-radius: 2px; }
       .form-cambiar-password .help-block .status-level li:nth-child(2),
       .form-cambiar-password .strength-meter .status-level li:nth-child(2) {
        margin: 0 6px; }
       .form-cambiar-password .help-block .status-level li:nth-child(3),
       .form-cambiar-password .strength-meter .status-level li:nth-child(3) {
        border-top-right-radius: 2px;
        border-bottom-right-radius: 2px; }
     .form-cambiar-password .help-block .status-level.bad li:nth-child(1),
     .form-cambiar-password .strength-meter .status-level.bad li:nth-child(1) {
      background-color: #F04040; }
     .form-cambiar-password .help-block .status-level.weak li:nth-child(1),
     .form-cambiar-password .help-block .status-level.weak li:nth-child(2),
     .form-cambiar-password .strength-meter .status-level.weak li:nth-child(1),
     .form-cambiar-password .strength-meter .status-level.weak li:nth-child(2) {
      background-color: #FFE600; }
     .form-cambiar-password .help-block .status-level.good li,
     .form-cambiar-password .strength-meter .status-level.good li {
      background-color: #00952E; }
      
  .control-form.filled.has-error .error{
  	text-align:left;
  	font-size: unset;
  }
  
  .control-form.focus.filled .strength-meter, .control-form.focus.filled.has-success.focus .strength-meter,
  .control-form.focus.filled.has-success .strength-meter,
  .control-form.filled.viewing.has-error .strength-meter{
  	margin-bottom: 10px;
    margin-top: 5px;
  }
      
  #form-new-password .error{
