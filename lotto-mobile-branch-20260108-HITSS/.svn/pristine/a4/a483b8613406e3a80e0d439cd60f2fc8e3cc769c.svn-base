#banner .swiper-container,
#bannerp .swiper-container {
  width: 100%;
}
#banner article,
#bannerp article {
  position: relative;
  max-width: 750px;
  margin: 0 auto;
}
#banner article img,
#bannerp article img {
  max-width: 100%;
  display: block;
}
#banner .info,
#bannerp .info {
  position: absolute;
  width: 100%;
  text-align: left;
}
#banner .info h3,
#bannerp .info h3 {
  color: #fff;
  font-family: AllerBold, Arial, sans-serif;
  font-size: 0.875em;
  margin: 0.5em 0.75em;
}
#banner .swiper-pagination-bullet,
#bannerp .swiper-pagination-bullet {
  background-color: transparent;
  border: 1px solid #fff;
  opacity: 1;
}
#banner .swiper-pagination-bullet-active,
#bannerp .swiper-pagination-bullet-active {
  background-color: #fff;
}
#banner .swiper-container-horizontal > .swiper-pagination-bullets,
#banner .swiper-pagination-custom,
#banner .swiper-pagination-fraction,
#bannerp .swiper-container-horizontal > .swiper-pagination-bullets,
#bannerp .swiper-pagination-custom,
#bannerp .swiper-pagination-fraction {
  bottom: 1px;
}

.styled-checkbox {
  position: absolute;
  opacity: 0;
}
.styled-checkbox + label {
  position: relative;
  cursor: pointer;
  padding: 0;
}
.styled-checkbox + label:before {
  content: '';
  margin-right: 10px;
  display: inline-block;
  vertical-align: text-top;
  width: 12px;
  height: 12px;
  background: transparent;
  border: 1px solid #fff;
  border-radius: 6px;
  box-sizing: border-box;
  margin-top: 2px;
}
.styled-checkbox:focus + label:before {
  box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.12);
}
.styled-checkbox:disabled + label {
  color: #b8b8b8;
  cursor: auto;
}
.styled-checkbox:disabled + label:before {
  box-shadow: none;
  background: #ddd;
}
.styled-checkbox:checked + label:after {
  content: '';
  position: absolute;
  left: 2px;
  top: 7px;
  background: #fff;
  width: 2px;
  height: 2px;
  border-radius: 3.5px;
  box-shadow: 2px 0 0 white, 4px 0 0 white, 4px -2px 0 white, 4px -4px 0 white,
    4px -6px 0 white, 4px -8px 0 white;
  -webkit-transform: rotate(45deg);
  -moz-transform: rotate(45deg);
  -ms-transform: rotate(45deg);
  -o-transform: rotate(45deg);
  transform: rotate(45deg);
}

.box-checkbox {
  /* Base for label styling */
  /* checkbox aspect */
  /* checked mark aspect */
  /* checked mark aspect changes */
  /* disabled checkbox */
  /* accessibility */
  /* hover style just for information */
}
.box-checkbox [type='checkbox']:not(:checked),
.box-checkbox [type='checkbox']:checked {
  position: absolute;
  left: -9999px;
}
.box-checkbox [type='checkbox']:not(:checked) + label,
.box-checkbox [type='checkbox']:checked + label {
  position: relative;
  padding-right: 2em;
  cursor: pointer;
}
.box-checkbox [type='checkbox']:not(:checked) + label:before,
.box-checkbox [type='checkbox']:checked + label:before {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  width: 1.25em;
  height: 1.25em;
  border: 2px solid #000;
  background: #fff;
}
.box-checkbox [type='checkbox']:not(:checked) + label:after,
.box-checkbox [type='checkbox']:checked + label:after {
  content: '\2714';
  position: absolute;
  top: 0.35em;
  right: 0.25em;
  font-size: 0.9em;
  line-height: 0.8;
  color: #000;
  -webkit-transition: all 0.2s;
  -moz-transition: all 0.2s;
  -o-transition: all 0.2s;
  transition: all 0.2s;
}
.box-checkbox [type='checkbox']:not(:checked) + label:after {
  opacity: 0;
  -webkit-transform: scale(0);
  -moz-transform: scale(0);
  -ms-transform: scale(0);
  -o-transform: scale(0);
  transform: scale(0);
}
.box-checkbox [type='checkbox']:checked + label:after {
  opacity: 1;
  -webkit-transform: scale(1);
  -moz-transform: scale(1);
  -ms-transform: scale(1);
  -o-transform: scale(1);
  transform: scale(1);
}
.box-checkbox [type='checkbox']:disabled:not(:checked) + label:before,
.box-checkbox [type='checkbox']:disabled:checked + label:before {
  box-shadow: none;
  border-color: #bbb;
  background-color: #ddd;
}
.box-checkbox [type='checkbox']:disabled:checked + label:after {
  color: #999;
}
.box-checkbox [type='checkbox']:disabled + label {
  color: #aaa;
}
.box-checkbox.checkbox-white [type='checkbox']:not(:checked) + label:before,
.box-checkbox.checkbox-white [type='checkbox']:checked + label:before {
  border-color: #fff;
  background-color: transparent;
}
.box-checkbox.checkbox-white [type='checkbox']:not(:checked) + label:after,
.box-checkbox.checkbox-white [type='checkbox']:checked + label:after {
  color: #fff;
}
.box-checkbox.checkbox-left [type='checkbox']:not(:checked) + label,
.box-checkbox.checkbox-left [type='checkbox']:checked + label {
  margin: 0;
  padding: 0.2em 0 0 2em;
  text-align: left;
}
.box-checkbox.checkbox-left [type='checkbox']:not(:checked) + label:before,
.box-checkbox.checkbox-left [type='checkbox']:checked + label:before {
  left: 0;
  right: auto;
}
.box-checkbox.checkbox-left [type='checkbox']:not(:checked) + label:after,
.box-checkbox.checkbox-left [type='checkbox']:checked + label:after {
  left: 0.3em;
  right: auto;
}

.custom-accordion .transition,
.custom-accordion .body-accordion,
.custom-accordion ul li i:before,
.custom-accordion ul li i:after {
  -webkit-transition: all 0.5s ease-in-out;
  -moz-transition: all 0.5s ease-in-out;
  -o-transition: all 0.5s ease-in-out;
  transition: all 0.5s ease-in-out;
}
.custom-accordion .flipIn,
.custom-accordion ul li {
  -o-animation: flipdown 0.5s ease both;
  -webkit-animation: flipdown 0.5s ease both;
  -moz-animation: flipdown 0.5s ease both;
  animation: flipdown 0.5s ease both;
}
.custom-accordion h2 {
  font-size: 1em;
}
.custom-accordion .body-accordion {
  position: relative;
  overflow: hidden;
  /*max-height: 800px;*/
  opacity: 1;
  -webkit-transform: translate(0, 0);
  -moz-transform: translate(0, 0);
  -ms-transform: translate(0, 0);
  -o-transform: translate(0, 0);
  transform: translate(0, 0);
  z-index: 2;
  padding: 0.5em 0 0; /*1.75em 0 .75em;*/
}
.custom-accordion ul {
  list-style: none;
  -ms-perspective: 900px;
  -webkit-perspective: 900px;
  -moz-perspective: 900px;
  -o-perspective: 900px;
  perspective: 900px;
  padding: 0;
  margin: 0;
}
.custom-accordion ul li {
  position: relative;
  padding: 0;
  margin: 1em 0;
}
.custom-accordion ul li:nth-of-type(1) {
  -webkit-animation-delay: 0.25s;
  animation-delay: 0.25s;
}
.custom-accordion ul li:nth-of-type(2) {
  -webkit-animation-delay: 0.5s;
  animation-delay: 0.5s;
}
.custom-accordion ul li:nth-of-type(3) {
  -webkit-animation-delay: 0.75s;
  animation-delay: 0.75s;
}
.custom-accordion ul li:nth-of-type(4) {
  -webkit-animation-delay: 1s;
  animation-delay: 1s;
}
.custom-accordion ul li:nth-of-type(5) {
  -webkit-animation-delay: 1.25s;
  animation-delay: 1.25s;
}
.custom-accordion ul li:nth-of-type(6) {
  -webkit-animation-delay: 1.5s;
  animation-delay: 1.5s;
}
.custom-accordion ul li:nth-of-type(7) {
  -webkit-animation-delay: 1.75s;
  animation-delay: 1.75s;
}
.custom-accordion ul li:nth-of-type(8) {
  -webkit-animation-delay: 2s;
  animation-delay: 2s;
}
.custom-accordion ul li:nth-of-type(9) {
  -webkit-animation-delay: 2.25s;
  animation-delay: 2.25s;
}
.custom-accordion ul li:nth-of-type(10) {
  -webkit-animation-delay: 2.5s;
  animation-delay: 2.5s;
}
.custom-accordion ul li:nth-of-type(11) {
  -webkit-animation-delay: 2.75s;
  animation-delay: 2.75s;
}
.custom-accordion ul li:nth-of-type(12) {
  -webkit-animation-delay: 3s;
  animation-delay: 3s;
}
.custom-accordion ul li:nth-of-type(13) {
  -webkit-animation-delay: 3.25s;
  animation-delay: 3.25s;
}
.custom-accordion ul li:nth-of-type(14) {
  -webkit-animation-delay: 3.5s;
  animation-delay: 3.5s;
}
.custom-accordion ul li:nth-of-type(15) {
  -webkit-animation-delay: 3.75s;
  animation-delay: 3.75s;
}
.custom-accordion ul li:nth-of-type(16) {
  -webkit-animation-delay: 4s;
  animation-delay: 4s;
}
.custom-accordion ul li:nth-of-type(17) {
  -webkit-animation-delay: 4.25s;
  animation-delay: 4.25s;
}
.custom-accordion ul li:nth-of-type(18) {
  -webkit-animation-delay: 4.5s;
  animation-delay: 4.5s;
}
.custom-accordion ul li:nth-of-type(19) {
  -webkit-animation-delay: 4.75s;
  animation-delay: 4.75s;
}
.custom-accordion ul li:nth-of-type(20) {
  -webkit-animation-delay: 5s;
  animation-delay: 5s;
}
.custom-accordion ul li:last-of-type {
  padding-bottom: 0;
}
.custom-accordion ul li:hover .btn-white {
  background-color: rgba(255, 255, 255, 0.8);
}
.custom-accordion ul li:hover .btn-trans {
  background-color: rgba(255, 255, 255, 0.3);
}
.custom-accordion ul li i {
  position: absolute;
  margin-top: 1em;
  left: 1.25em;
  width: 0.625em;
  height: 0.625em;
  z-index: 1;
}
.custom-accordion ul li i.loading {
  animation-name: spin;
  animation-duration: 2000ms;
  animation-iteration-count: infinite;
  animation-timing-function: linear;
}
.custom-accordion ul li i:before,
.custom-accordion ul li i:after {
  content: '';
  position: absolute;
  background-color: #07663a;
  width: 2px;
  height: 0.625em;
}
.custom-accordion ul li i:before {
  -ms-transform: rotate(90deg);
  -webkit-transform: rotate(90deg);
  -moz-transform: rotate(90deg);
  -o-transform: rotate(90deg);
  transform: rotate(90deg);
}
.custom-accordion ul li i:after {
  opacity: 0;
}
.custom-accordion ul li input[type='checkbox'],
.custom-accordion ul li input[type='radio'] {
  position: absolute;
  cursor: pointer;
  width: 100%;
  height: 100%;
  z-index: 1;
  opacity: 0;
  left: 0;
}
.custom-accordion ul li input[type='checkbox']:checked ~ .body-accordion,
.custom-accordion ul li input[type='radio']:not(:checked) ~ .body-accordion {
  margin-top: 0;
  max-height: 0;
  opacity: 0;
  -webkit-transform: translate(0, 50%);
  -moz-transform: translate(0, 50%);
  -ms-transform: translate(0, 50%);
  -o-transform: translate(0, 50%);
  transform: translate(0, 50%);
  padding: 0;
  margin: 0;
}
.custom-accordion ul li input[type='checkbox']:checked ~ i:after,
.custom-accordion ul li input[type='radio']:not(:checked) ~ i:after {
  opacity: 1;
}
.custom-accordion ul li h2 {
  position: relative;
}
.custom-accordion ul li h2 span {
  display: inline-block;
  background-color: #de111d;
  color: #fff;
  margin: 0 0 0 5px;
  padding: 1px 4px 0 4px;
  line-height: 16px;
  font-size: 12px;
  position: absolute;
  top: 1.2em;
  left: 11em;
}
.custom-accordion ul li img {
  position: absolute;
  top: 0.2em;
  right: 1.5em;
  /*display: none;*/
}
.custom-accordion ul li .body-accordion img {
  display: inline-block;
  position: relative;
  right: 0;
}
@keyframes flipdown {
  0% {
    opacity: 0;
    transform-origin: top center;
    transform: rotateX(-90deg);
  }
  5% {
    opacity: 1;
  }
  80% {
    transform: rotateX(8deg);
  }
  83% {
    transform: rotateX(6deg);
  }
  92% {
    transform: rotateX(-3deg);
  }
  100% {
    transform-origin: top center;
    transform: rotateX(0deg);
  }
}
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
.overlay {
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.7);
  -webkit-transition: opacity 500ms;
  -moz-transition: opacity 500ms;
  -o-transition: opacity 500ms;
  transition: opacity 500ms;
  visibility: hidden;
  opacity: 0;
  z-index: 11;
}

.overlayData {
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.7);
  visibility: hidden;
  opacity: 0;
  z-index: -1;
}

.overlayData:target,
.overlayData.opened {
   visibility: visible;
  opacity: 1;
  z-index: 11;
  overflow: scroll;
  transition: opacity 500ms;
}

