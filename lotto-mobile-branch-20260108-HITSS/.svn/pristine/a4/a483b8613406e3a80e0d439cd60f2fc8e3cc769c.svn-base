.popup.popup-sm.login-error {
    color: #5A5A5A;
    font-size: 14px;
    line-height: 20px;
    padding: 25px 25px;
    background: #F2F2F2;
    width: 90%;
    max-width: 590px;
    position: absolute;
    z-index: 220;
    left: 50%;
    top: 50%;
    margin: 0px;
    height: auto;
    -webkit-transform: translate(-50%, -50%);
    transform: translate(-50%, -50%);
}
.mensaje-login-error {
    font-size: 15px;
    font-weight: 300;
    line-height: 19px;
    font-family: "Roboto", sans-serif;
}
.titulo-login-error {
    font-size: 17.5px;
    font-weight: 900;
    font-family: "Roboto", sans-serif;
}
.popup .close-login-error {
    position: absolute;
    top: 0.1em;
    left: 88%;
    transition: all 200ms;
    font-size: 3.25em;
    text-decoration: none;
    color: #07663a;
    font-family: AllerLight, Arial, sans-serif;
}

.btn.btn-login-error {
    background-color: #07663a;
    color: #fafafa;
    box-shadow: none;
}

/* tipo documento login */
.form__select.selected {
    border-color: #5A5A5A;
}

.form__select {
    -webkit-box-sizing: border-box;
    box-sizing: border-box;
    border: solid 1px #A5A5A5;
    border-radius: 5px;
    height: 47px;
    margin-bottom: 15px;
    position: relative;
}

.form__select div {
    position: absolute;
    left: 15px;
    top: 14px;
    font-weight: 400;
    font-size: 16px;
    color: #000000;
}

.form__select.selected label {
    color: #5A5A5A;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    background-color: #ffffff;
    top: -6px;
    position: absolute;
    display: block;
    left: 15px;
}

.form__select select {
    width: 100%;
    position: absolute;
    top: 12px;
    left: 0;
    opacity: 0;
    cursor: pointer;
}

.form__select::after {
    content: '';
    position: absolute;
    background-image: url(../../layer-view-image/client/icon-arrow-green.svg);
    background-position: center;
    background-repeat: no-repeat;
    width: 12px;
    height: 6px;
    top: 20px;
    right: 16px;
}

.ilot .disabledInput2 input {
    pointer-events: none;
}

.ilot .disabledInput2 label {
    pointer-events: none;
}

.ilot .form__check.disabledInput2 input:checked + label::before {
    background-color: #e2e2e2;
    border-color: #e2e2e2;
}


