	color: #fff;
	font-size: 2.375em;
    font-family: Cocogoose, Arial, sans-serif; 
    
}

.golazo200-cierre{
	background-color: #004d16; 	
	border-radius: 7px;
	color: #fff;
	padding: 15px;
	opacity: 0.5;
}

