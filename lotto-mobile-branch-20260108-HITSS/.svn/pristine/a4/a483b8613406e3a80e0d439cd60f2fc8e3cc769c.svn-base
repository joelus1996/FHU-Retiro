    width: 280px;
}
.my-input-item label {
    display: block;
    font-size: 12px;
}
.my-input-item input {
    width: 100%;
    padding: 12px 10px;
    padding-bottom: 13px;
    border-radius: 5px;
    border: solid 1px #C7C7C7;
    outline: none;
    margin: 5px 0px;
}
.my-button-item button {
    width: 100%;
    border: none;
    background: #07663a;
    border-radius: 5px;
    color: white;
    padding: 14px 10px;
    display: block;
    width: 100%;
    font-size: 14px;
}
.item-my_form__icon img {
    display: block;
}
.my-input-item select {
    -webkit-appearance: button;
    margin-bottom: 5px;
    margin-top: 5px;
    width: 100%;
    padding: 12px 10px;
    padding-bottom: 13px;
    border-radius: 5px;
    border: solid 1px #C7C7C7;
    outline: none;
    margin: 5px 0px;
}
.terms .no-upper {
    font-size: 12px;
    margin-bottom: 25px;
    margin-top: 25px;
    color: #717171;
}
.sub-head-form p {
    color: #717171;
    font-size: 14px;
}
.option-list {
    margin: 0px;
}
.condition-list {
    list-style: none;
    padding: 0px;
    text-align: justify;
}
body.iframe-content-wordpress {
    height: 100vh;
    overflow-y: hidden;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
}
body.iframe-content-wordpress iframe {
    width: 100%;
    height: calc(100vh - 64px);
    margin-top: 64px;
    border: none;
}
.close-menu-not-wrap.active {
    display: block;
    background: rgba(0, 0, 0, 0.75);
}
.tutorial_hands {
    position: absolute;
    z-index: 15;
    color: white;
    top: 72px;
    right: 82px;
    display: none;
}
.tutorialS:nth-child(2) {
    left: -12px;
    position: relative;
}
.tutorial_hands.active {
	display:flex;
}
.tutorialS {
    white-space: nowrap;
    width: 50px;
    opacity: 0;
    transition: 0.3s;
    position: relative;
}
.tutorialS span {
    font-size: 14px;
    position: absolute;
    display: block;
    margin-top: 5px;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
}
.tutorialS.active{
	opacity: 1;
}
.tutorialS svg {
    display: block;
    margin: auto;
}
#form-book .content .right form .form-group .form-control {
    padding: 10px !important;
    height: 50px;
    margin-bottom: 5px;
}
#form-book .content .right form .form-group label.error {
    display: block !important;
    position: relative;
    left: 0px !important;
    top: 0px !important;
    text-align: left;
    padding: 0px !important;
    font-weight: 700;
}
#form-book .content .right form .form-group .form-control.error {
    border-color: #E9041B;
    text-align: left;
    border-radius: 5px;
}
.my-input-item input.error {
    border: solid 1px #d71b22;
}
label#soles-error {
    margin-top: 0px;
    margin-bottom: 10px;
    font-weight: 700;
    font-size: 9px;
}
p.error-p {
    display: block;
    font-weight: 700;
    color: #d71b22;
    font-size: 9px;
}
select.errorf {
    border: solid 1px #d71b22;
}
@media (max-width: 815px) {
	#form-book .content .left .block {
	    margin-left: 0px;
	    margin-right: 0px;
	}
}
@media (max-width: 341px){
	#header .logo a svg {
	    position: relative;
	    left: -10px;
	    height: 30px;
	}
	#header .logo a {
	    overflow: hidden;
	}
	#header .sub-header .btn-balance {
		margin-right: 10px;
	}
	#header .logo {
		width: 35%;
	}
}

@media (min-width: 700px) {
	#header .logo {
		width: 20%;
	}
}

@media (min-width: 500px) and  (max-width: 700px) {
	#header .logo {
		width: 30%;
	}
}

