#form-book .content {
    padding-top: 64px;
}
#form-book {
    max-width: 100%;
    margin: auto;
}

.right {
    float: none;
}
.title-form {
    padding: 0px;
}
.block p {
    font-size: 13px !important;
    color: #464646;
    line-height: 20px;
}
.block h1 {
    color: #464646;
    font-size: 25px;
}
.form-group input {
    display: block;
    width: 100%;
    height: calc(1.5em + .75rem + 2px);
    padding: .375rem .75rem;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    color: #495057;
    background-color: #fff;
    background-clip: padding-box;
    border: 1px solid #ced4da;
    border-radius: .25rem;
    transition: border-color 0.15s ease-in-out,box-shadow 0.15s ease-in-out;
    margin-bottom: 20px;
}
.form-group label {
    position: absolute;
    z-index: 2;
    pointer-events: none;
    font-size: 14px;
    left: 5px;
    top: 10px;
}
.title-form {
    margin-bottom: 15px;
}
.form-group {
    position: relative;
}
#form-book .content .right form .form-group .form-control.valid ~ label, .form-group .form-control:focus + label {
    text-transform: uppercase;
    transform: translateY(-3px) !important;
    font-size: 12px;
    color: #9a9a9a;
    left: 13px;
}
p.radio-button {
    margin-left: 16px;
    margin-top: 0px;
}
#form-book .content .right form .form-group .radio-button label:before {
    top: 1px !important;
}
#form-book .content .right form .form-group .radio-button input {
    position: absolute;
}
textarea {
    box-sizing: border-box;
    width: 100%;
    margin-bottom: 10px;
    border: none;
}
#form-book button {
    width: 100%;
    border: none;
    color: white;
    background: #07663a;
    padding: 15px 0px;
    margin-bottom: 20px;
    border-radius: 5px;
    font-size: 18px;
}
#form-book {
    overflow: hidden;
}
.autocontrol-ss .container {
    max-width: calc(100% - 40px);
    margin: auto;
    padding-top: 80px;
}
.autocontrol-ss .container h2 {
    font-family: AllerRegular, Arial, sans-serif;
    margin-bottom: 10px;
}
.autocontrol-ss form {
    margin-bottom: 20px;
}
.autocontrol-ss form  fieldset {
    border-radius: 5px;
    padding-bottom: 20px;
    padding-left: 15px;
    padding-right: 15px;
    border: solid 1px #bababa;
    background: rgba(228,228,228,0.3);
}
.autocontrol-ss form  fieldset legend {
    font-weight: 700;
    text-transform: uppercase;
}
.autocontrol-ss form fieldset input {
    width: 100%;
    border: none;
    border-bottom: solid 1px #7b7b7b99;
}
.autocontrol-ss form  fieldset button {
    margin-top: 10px;
    height: auto;
    color: white !important;
    text-transform: uppercase;
}
.autocontrol-ss form  fieldset input {
    width: 100%;
    border: none;
    border-bottom: solid 1px rgba(123, 123, 123, 0.56);
    background: transparent;
    padding: 10px 0px;
}
.autocontrol-ss form fieldset select {
    -webkit-appearance: button;
    width: 100%;
    padding: 10px 0px;
    border: none;
    border-bottom: solid 1px rgba(110, 110, 110, 0.51);
    background: transparent;
}
.autocontrol-ss .container h2 {
    color: #07663a;
    padding-bottom: 5px;
    margin-bottom: 15px;
    border-bottom: solid 1px rgba(150,150,150,0.2);
}
.item-my_form__icon svg {
