@font-face {
  font-family: 'ilot';
  src: url("../common/fonts/ilot.eot?dy7ume");
  src: url("../common/fonts/ilot.eot?dy7ume#iefix") format("embedded-opentype"), url("../common/fonts/ilot.ttf?dy7ume") format("truetype"), url("../common/fonts/ilot.woff?dy7ume") format("woff"), url("../common/fonts/ilot.svg?dy7ume#ilot") format("svg");
  font-weight: normal;
  font-style: normal;
  font-display: block;
}

.content_liquidacion{
	text-align: center !important;
	height: 98px !important;
	padding: 0.7em 1em 0.7em 1em !important;
}

.linkbox {
    width: 200px;
    height: 36px !important;
    background-color: white;
    display: block;
    border: 1px solid #E2E2E2;
    -webkit-box-sizing: border-box;
    box-sizing: border-box;
    border-radius: 5px;
    color: #464646;
    font-weight: 700;
    font-size: 14px !important;
    text-decoration: none;
    position: relative;
    margin-top: 12px;
    font-family: AllerBold, Arial, sans-serif !important;
    text-align: center !important;
    padding: 0.7em 1em 0.7em 1.5em !important;
    line-height: 1em !important;
}

.btn_red_new{
	border: solid 1px #e30613;
    background-color: #e30613;
    color: white;
}
.linkbox::before {
    font-family: 'ilot' !important;
    speak: none;
    font-style: normal;
    font-weight: normal;
    font-variant: normal;
    text-transform: none;
    line-height: 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    content: '\e901';
    display: block;
    position: absolute;
    font-size: 24px;
    right: 48px;
    top: 50%;
    color: #07663a;
    margin-top: -11px;
    margin-right: -8px;
}

.btn_red_new::before{
    color: white;
}

