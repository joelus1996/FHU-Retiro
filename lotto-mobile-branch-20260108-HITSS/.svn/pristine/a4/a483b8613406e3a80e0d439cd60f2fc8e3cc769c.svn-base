    line-height: 1.2em;
    font-size: 1.8em;
    margin-bottom: 30px;
}

.box-content-img {
	display: block;
	padding:0px;
	margin: 0 0 20px 0;
	text-align:center;
}

.box-content-img img {
	border-radius: 0px;
	width: 100%;
	height: auto;
}
    
