html,
body {
  width: 100%;
  min-height: 100%;
}

body {
  background-color: #f6f6f6;
  font-family: AllerRegular, Arial, sans-serif;
}
body.orange {
  background-color: #fbe601;
  
}
body.modal {
  overflow: hidden;
}

body.body-perfil{
	background-color:#FFFFFF;
}

*,
*:after,
*:before {
  -moz-box-sizing: border-box;
  -webkit-box-sizing: border-box;
  box-sizing: border-box;
}

* {
  outline: 0;
}

a,
a:hover,
a:active {
  text-decoration: none;
}

b {
  font-family: AllerBold, Arial, sans-serif;
  font-weight: bold;
}

.no-select,
.custom-accordion h2 {
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  -webkit-user-select: none;
  -khtml-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  user-select: none;
}

h1,
h2,
h3,
h4,
h5 {
  margin: 0;
  padding: 0;
}

.container {
  overflow-x: hidden;
}

.clearfix:after {
  display: block;
  content: '';
  clear: both;
}

.show {
  display: block;
}

.hide {
  display: none;
}

table {
  border-collapse: collapse;
  background-color: transparent;
}
table th {
  text-align: left;
}

figure {
  margin: 0;
  padding: 0;
}

.right {
  float: right;
}

.left {
  float: left;
}

.pr-1 {
  padding-right: 0.3125em;
}

.pl-1 {
  padding-left: 0.3125em;
}

.pr-2 {
  padding-right: 0.625em;
}

.row:after {
  display: block;
  content: '';
  clear: both;
}

.w-100 {
  width: 100%;
  float: left;
}

.w-50 {
  width: 50%;
  float: left;
}

.w-33 {
  width: 33.3%;
  float: left;
}

.w-66 {
  width: 66.7%;
  float: left;
}

.br-white {
  border-right: 3px solid #07663a;
}

.br-gray {
  border-right: 2px solid #c2c4c2;
}

.bb-gray {
  border-bottom: 2px solid #c2c4c2;
}

.bt-gray {
  border-top: 2px solid #c2c4c2;
}

.link-block {
  color: #fff;
  display: block;
  line-height: 2em;
  height: 2em;
  text-align: center;
  font-family: AllerBold, Arial, sans-serif;
  font-size: 1em;
}
.link-block:hover {
  text-decoration: underline;
}

.m-0 {
  margin: 0 !important;
}

.p-0 {
  padding: 0 !important;
}

.error {
  font-size: 0.8em; /*.65em;*/
  color: #d71b22;
  margin: 5px 0;
  text-align: center;
}

.ok {
  font-size: 0.8em;
  margin: 5px 0;
  text-align: center;
}

.success {
  font-size: 0.65em;
  color: #383a35;
}

.menu-wrap a {
  color: #fff !important;
  text-decoration: none !important;
  letter-spacing: 0 px;
}

.menu-wrap a:hover,
.menu-wrap a:focus {
  color: rgba(255, 255, 255, 0.8) !important;
}

.content-wrap {
  overflow: hidden;
  -webkit-overflow-scrolling: touch;
  padding-top: 64px;
}

.content {
  position: relative;
}

.content::before {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 10;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  content: '';
  opacity: 0;
  -webkit-transform: translate3d(100%, 0, 0);
  transform: translate3d(100%, 0, 0);
  -webkit-transition: opacity 0.4s, -webkit-transform 0s 0.4s;
  transition: opacity 0.4s, transform 0s 0.4s;
  -webkit-transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
  transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
}
.content::before {
	z-index: 12
}
/* Menu Button */
.menu-button {
  cursor: pointer;
  position: relative;
  z-index: 1000;
  padding: 0;
  width: 2.5em;
  height: 2em;
  border: none;
  text-indent: 2.5em;
  font-size: 1.5em;
  color: transparent;
  background: transparent;
  margin: 0.3em 0.5em 0.3em 1em;
}

.menu-button::before {
  position: absolute;
  top: 0.5em;
  right: 0.5em;
  bottom: 0.5em;
  left: 0.5em;
  background: linear-gradient(
    #fff 20%,
    transparent 20%,
    transparent 40%,
    #fff 40%,
    #fff 60%,
    transparent 60%,
    transparent 80%,
    #fff 80%
  );
  content: '';
}

.menu-button:hover {
  opacity: 0.6;
}

/* Close Button */
.close-button {
  width: 1.5em;
  height: 1.5em;
  position: absolute;
  right: 0.5em;
  top: 0.5em;
  overflow: hidden;
  text-indent: 1em;
  font-size: 0.75em;
  border: none;
  background: transparent;
  color: transparent;
  cursor: pointer;
}
.close-button:hover {
  opacity: 0.8;
}

.close-button::before,
.close-button::after {
  content: '';
  position: absolute;
  width: 1px;
  height: 100%;
  top: 0;
  left: 50%;
  background: #fff;
}

.close-button::before {
  -ms-transform: rotate(45deg);
  -webkit-transform: rotate(45deg);
  -moz-transform: rotate(45deg);
  -o-transform: rotate(45deg);
  transform: rotate(45deg);
}

.close-button::after {
  -ms-transform: rotate(-45deg);
  -webkit-transform: rotate(-45deg);
  -moz-transform: rotate(-45deg);
  -o-transform: rotate(-45deg);
  transform: rotate(-45deg);
}

/* Menu */
.menu-wrap {
  position: fixed;
  right: 0;
  top: 0;
  z-index: 1001;
  width: 80%;
  height: 100%;
  background: #484848;
  font-size: 1.15em;
  -webkit-transform: translate3d(100%, 0, 0);
  transform: translate3d(100%, 0, 0);
  -webkit-transition: -webkit-transform 0.4s;
  transition: transform 0.4s;
  -webkit-transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
  transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
}
@media (min-width: 360px) {
  .menu-wrap {
    width: 80%;
  }
}

.menu,
.icon-list {
  height: 100%;
}

.icon-list {
  position: relative;
  padding-top: 20px;
  text-align: right;
}

.box-account__header .username span {
    max-width: 100px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    font-family: AllerRegular, Arial, sans-serif;
}
.box-account__header .balance .amount span {
    max-width: 110px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
    white-space: nowrap;
    font-family: AllerRegular, Arial, sans-serif;
}


.icon-list a {
  display: block;
  position: relative;
  cursor: pointer;
  font-size: 14px;
}

.icon-list form a.pending span {
  color: #fbe601;
}
.icon-list form a.pending:after {
  background-color: #07663a;
  border-color: #07663a;
}
.icon-list form a.pending:hover:after {
  background-color: #07663a;
}
.icon-list a.pending span {
  color: #ffed00;
}
.icon-list a.pending:after {
  background-color: #07663a;
  border-color: #07663a;
}
.icon-list a.pending:hover:after {
  background-color: #07663a;
}

.icon-list a.active:after,
.icon-list a:hover:after {
  background-color: #fff;
}

.icon-list,
.icon-list a {
  -webkit-transition: -webkit-transform 0s 0.4s;
  transition: transform 0s 0.4s;
  -webkit-transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
  transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
}

.icon-list a:nth-child(2) {
  -webkit-transform: translate3d(0, 1000px, 0);
  transform: translate3d(0, 1000px, 0);
}

.icon-list a:nth-child(3) {
  -webkit-transform: translate3d(0, 1500px, 0);
  transform: translate3d(0, 1500px, 0);
}

.icon-list a:nth-child(4) {
  -webkit-transform: translate3d(0, 2000px, 0);
  transform: translate3d(0, 2000px, 0);
}

.icon-list a:nth-child(5) {
  -webkit-transform: translate3d(0, 2500px, 0);
  transform: translate3d(0, 2500px, 0);
}

.icon-list a:nth-child(6) {
  -webkit-transform: translate3d(0, 3000px, 0);
  transform: translate3d(0, 3000px, 0);
}

.icon-list a:nth-child(7) {
  -webkit-transform: translate3d(0, 3500px, 0);
  transform: translate3d(0, 3000px, 0);
}

.icon-list a:nth-child(8) {
  -webkit-transform: translate3d(0, 4000px, 0);
  transform: translate3d(0, 3000px, 0);
}

.icon-list a:nth-child(9) {
  -webkit-transform: translate3d(0, 4500px, 0);
  transform: translate3d(0, 3000px, 0);
}

.icon-list a:nth-child(10) {
  -webkit-transform: translate3d(0, 5000px, 0);
  transform: translate3d(0, 3000px, 0);
}

.icon-list a:nth-child(11) {
  -webkit-transform: translate3d(0, 5500px, 0);
  transform: translate3d(0, 3000px, 0);
}

.icon-list a span {
    font-family: AllerRegular;
    font-size: 12px;
    margin-right: 20px;
    display: block;
    position: relative;
    top: -5px;
}

/* Opening menu */
.opened-menu .menu-wrap {
  overflow-y: auto;
}

/* Shown menu */
.show-menu .menu-wrap {
  -webkit-transform: translate3d(0, 0, 0);
  transform: translate3d(0, 0, 0);
  -webkit-transition: -webkit-transform 0.8s;
  transition: transform 0.8s;
  -webkit-transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
  transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
}

.show-menu .icon-list,
.show-menu .icon-list a {
  -webkit-transform: translate3d(0, 0, 0);
  transform: translate3d(0, 0, 0);
  -webkit-transition: -webkit-transform 0.8s;
  transition: transform 0.8s;
  -webkit-transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
  transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
}

.show-menu .icon-list a {
  -webkit-transition-duration: 0.9s;
  transition-duration: 0.9s;
}

.icon-list a img {
    max-width: 15px;
    display: inline-block;
    vertical-align: middle;
    position: relative;
    top: -2px;
    margin-right: 5px;
    filter: invert(1);
}

.icon-list-item {
  margin-right: 1.2em;
  display: block;
}

.show-menu .content::before {
  opacity: 1;
  -webkit-transition: opacity 0.8s;
  transition: opacity 0.8s;
  -webkit-transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
  transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
  -webkit-transform: translate3d(0, 0, 0);
  transform: translate3d(0, 0, 0);
}

#header {
