body {
	background: rgb(197, 204, 211);
	font-family: Arial;
	padding: 0;
	-webkit-user-select: none;
	-webkit-text-size-adjust: none;
}

/***** List (base) ******/
ul {
	color: black;
	background: #fff;
	font: 12px Arial;
	padding: 0;
	margin: 15px 10px 17px 0;
	border-radius: 8px;
	list-style-type: none;
}

ul.listContent{
	border: 1px solid #B4B4B4;
	border-top: 0px;
}

/* FONDO DEL CONTENEDOR GENERAL DE LA PAGINA */
ul.listContentCuadro{
	background: #ffffff;
    background-image: -webkit-gradient(linear, left top, left bottom, from(#ffffff), to(#d9d9d9) );
	background-image: -webkit-linear-gradient(#ffffff, #d9d9d9);
	background-image: -moz-linear-gradient(#ffffff, #d9d9d9);
	background-image: -ms-linear-gradient(#ffffff, #d9d9d9);
	background-image: -o-linear-gradient(#ffffff, #d9d9d9);
	background-image: linear-gradient(#ffffff, #d9d9d9);
}

/* FONDO DEL MENU INFERIOR */
ul.listContentMenu{
	font-size: 17px;
	background: #e1e2df;
    background-image: -webkit-gradient(linear, left top, left bottom, from(#e1e2df), to(#f1f1f0) );
	background-image: -webkit-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -moz-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -ms-linear-gradient(#e1e2df, #f1f1f0);
	background-image: -o-linear-gradient(#e1e2df, #f1f1f0);
	background-image: linear-gradient(#e1e2df, #f1f1f0);
}

/* universal arrows */
ul li.arrow {
	color: #666;
	border-top: 1px solid #B4B4B4;
	list-style-type: none;
	padding: 10px 10px 10px 10px;
	background-position: right center;
	background-repeat: no-repeat;
}

/* universal links on list */
ul li a,li.img a+a {
	color: #000;
	text-decoration: none;
	text-overflow: ellipsis;
	white-space: nowrap;
	overflow: hidden;
	/*
	display: block;
	padding: 12px 10px 12px 10px;
	*/
	-webkit-tap-highlight-color: rgba(0, 0, 0, 0)
}


/* standard mini-label */
ul li small {
	color: #369;
	font: 17px Helvetica;
	text-align: right;
	text-overflow: ellipsis;
	white-space: nowrap;
	overflow: hidden;
	display: block;
	width: 23%;
	float: right;
	padding: 7px 0 0 0
}

/* BARRA SUPERIOR INTRALOT */
.ui-bar-c {
	border: 1px solid #FA8F07;
	color: #fff;
	font-weight: bold;
	text-shadow: 0 1px 0 #eee;
	background: #FA8F07;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#FA8F07), to(#f28704) );
	background-image: -webkit-linear-gradient(#FA8F07, #f28704);
	background-image: -moz-linear-gradient(#FA8F07, #f28704);
	background-image: -ms-linear-gradient(#FA8F07, #f28704);
	background-image: -o-linear-gradient(#FA8F07, #f28704);
	background-image: linear-gradient(#FA8F07, #f28704);
}

/* BARRA JUEGO */
.ui-bar-b {
	border: 1px solid #131010;
	color: #fff;
	font-weight: bold;
	text-shadow: 0 -1px 1px #333333;
	background: #272820;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#272820), to(#050504) );
	background-image: -webkit-linear-gradient(#272820, #050504);
	background-image: -moz-linear-gradient(#272820, #050504);
	background-image: -ms-linear-gradient(#272820, #050504);
	background-image: -o-linear-gradient(#272820, #050504);
	background-image: linear-gradient(#272820, #050504);
}

/* FONDO DE PAGINA */
.ui-body-c,.ui-dialog.ui-overlay-c {
	border: 1px solid #a7d617;
	color: #333;
	text-shadow: 0 1px 0 #fff;
	background: #a7d617;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#a7d617), to(#1a6502) );
	background-image: -webkit-linear-gradient(#a7d617, #1a6502);
	background-image: -moz-linear-gradient(#a7d617, #1a6502);
	background-image: -ms-linear-gradient(#a7d617, #1a6502);
	background-image: -o-linear-gradient(#a7d617, #1a6502);
	background-image: linear-gradient(#a7d617, #1a6502);
}

/* BOTON 1 */
.ui-btn-up-d {
	background: #E54537;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#f8f001), to(#8B1A12) );
	background-image: -webkit-linear-gradient(#E54537, #8B1A12);
	background-image: -moz-linear-gradient(#E54537, #8B1A12);
	background-image: -ms-linear-gradient(#E54537, #8B1A12);
	background-image: -o-linear-gradient(#E54537, #8B1A12);
	background-image: linear-gradient(#E54537, #8B1A12);
    background: linear-gradient(#E54537, #8B1A12) repeat scroll 0 0 #2567AB;
    border: 0px solid #E54537;
    color: #FFFFFF;
    font-weight: bold;
    text-shadow: 0 -1px 1px #E54537;
}

/* BOTON 1 */
.ui-btn-hover-d {
	background: #E54537;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#f8f001), to(#8B1A12) );
	background-image: -webkit-linear-gradient(#E54537, #8B1A12);
	background-image: -moz-linear-gradient(#E54537, #8B1A12);
	background-image: -ms-linear-gradient(#E54537, #8B1A12);
	background-image: -o-linear-gradient(#E54537, #8B1A12);
	background-image: linear-gradient(#E54537, #8B1A12);
    background: linear-gradient(#E54537, #8B1A12) repeat scroll 0 0 #2567AB;
    border: 0px solid #E54537;
    color: #FFFFFF;
    font-weight: bold;
    text-shadow: 0 -1px 1px #E54537;
}

/* BOTON 2 */
.ui-btn-up-e {
	background: #FFEE00;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#FFEE00), to(#FFBA00) );
	background-image: -webkit-linear-gradient(#FFEE00, #FFBA00);
	background-image: -moz-linear-gradient(#FFEE00, #FFBA00);
	background-image: -ms-linear-gradient(#FFEE00, #FFBA00);
	background-image: -o-linear-gradient(#FFEE00, #FFBA00);
	background-image: linear-gradient(#FFEE00, #FFBA00);
    background: linear-gradient(#FFEE00, #FFBA00) repeat scroll 0 0 #2567AB;
    border: 0px solid #FFEE00;
    color: #066d36;
    font-weight: bold;
    text-shadow: 0 -1px 1px #FFEE00;
}

/* BOTON 2 */
.ui-btn-hover-e {
	background: #FFEE00;
	background-image: -webkit-gradient(linear, left top, left bottom, from(#FFEE00), to(#FFBA00) );
	background-image: -webkit-linear-gradient(#FFEE00, #FFBA00);
	background-image: -moz-linear-gradient(#FFEE00, #FFBA00);
	background-image: -ms-linear-gradient(#FFEE00, #FFBA00);
	background-image: -o-linear-gradient(#FFEE00, #FFBA00);
	background-image: linear-gradient(#FFEE00, #FFBA00);
    background: linear-gradient(#FFEE00, #FFBA00) repeat scroll 0 0 #2567AB;
    border: 0px solid #FFEE00;
    color: #066d36;
    font-weight: bold;
    text-shadow: 0 -1px 1px #FFEE00;
}