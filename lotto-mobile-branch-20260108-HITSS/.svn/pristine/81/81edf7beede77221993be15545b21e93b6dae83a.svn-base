@font-face {
	font-family: 'Aller-Bold';
    src: url('fonts/original_Aller.eot?#iefix') format('embedded-opentype'),
         url('fonts/original_Aller.woff') format('woff'),
         url('fonts/original_Aller.ttf') format('truetype'),
         url('fonts/original_Aller.svg') format('svg');
	font-weight: normal;
	font-style: normal;
}
@font-face {
	font-family: 'AllerDisplay';
    src: url('fonts/original_AllerDisplay.eot?#iefix') format('embedded-opentype'),
         url('fonts/original_AllerDisplay.woff') format('woff'),
         url('fonts/original_AllerDisplay.ttf') format('truetype'),
         url('fonts/original_AllerDisplay.svg') format('svg');
	font-weight: normal;
	font-style: normal;
}
@font-face {
	font-family: 'Aller';
    src: url('fonts/original_Aller_Rg.eot?#iefix') format('embedded-opentype'),
         url('fonts/original_Aller_Rg.woff') format('woff'),
         url('fonts/original_Aller_Rg.ttf') format('truetype'),
         url('fonts/original_Aller_Rg.svg') format('svg');
	font-weight: normal;
	font-style: normal;
}


body{
	font-family: 'AllerDisplay', Arial, sans-serif !important;
	padding: 0;
	margin: 0;
}

header *{
	font-family: 'AllerRegular', Arial, sans-serif !important;
	font-weight: 400 !important;
}
