.titular{
	text-align: center;
	font-size: 22px;
	text-transform: uppercase;
	margin-top:30px;
	margin-bottom:15px;
}
.info_res{
	text-align: center;
	font-size: 18px;
	font-weight: 300;
	text-transform: uppercase;
	margin-bottom:15px;
}
.fix{
	clear: both;
}
.container{
	padding-top: 35px;
	width: 100%;
	background: #02BAE2;
}
.container .logo-brand{
	background-color: #02BAE2;
	text-align: center;
	padding: 20px 0;
}
.container .logo-brand img{
	width: 250px;
	height: auto;
	margin: 0 auto;
}
.text_stl{
	color: #fff;
	font-size: 14px;
	text-align: center;
	margin: 10px 0 0 0;
	font-family: 'AllerDisplay';
	letter-spacing: 1.5px;
	text-transform: uppercase;
}
.titulo_pr{
	background-color: #90368A;
	text-transform: uppercase;
	color: #fff;
	text-align: center;
	display: block;
	padding: 20px 0;
	margin: 0;
	font-size: 22px;
	letter-spacing: 1.5px;
	font-family: 'AllerDisplay';
	position: relative;
}
.triangle-down {
	width: 0;
	height: 0;
	border-left: 16px solid transparent;
	border-right: 16px solid transparent;
	border-top: 12px solid #90368A;
    position: absolute;
    bottom: -12px;
    margin-left: -16px;
    left: 50%;
    z-index: 9;
}
.box_five{
	padding-top: 15px;
	padding-bottom: 10px;
	position: relative;
}
.boxtitle{
	color: #333333;
    font-size: 19px;
    margin: 0;
    text-align: center;
    font-family: 'AllerDisplay';
    text-transform: uppercase;
    margin-bottom: 20px;
}
.bg-blue{
	background-color: #1FD3FD !important;
}


.ball_small{
	width: 38px;
	height: 38px;
	line-height: 38px;
	margin-left: 10px;
}

.ball_large{
	width: 42px;
	height: 42px;
	line-height: 42px;
}
.list-ball-large{
	list-style: none;
	padding: 0;
	text-align: left;
    width: 230px;
    margin: 0 auto;
}
.list-ball-large.big{
    width: 300px;
}
.list-ball-large li{
	display: inline-block;
	margin-bottom: 10px;

}
.list-ball-large li:first-child .ball_small,
.list-ball-large li:nth-child(7) .ball_small{
	margin-left: 0;
}
.mg-lf{
	margin-left: 0 !important;
}
.numbers{
	position: relative;
}
.box_five .triangle-down{
	border-top: 12px solid #fff !important;
}
.st-bottom{
	color: #fff;
	text-transform: uppercase;
	background-color: #D71B22;
	font-family: 'Aller-Bold';
	font-size: 16px;
	text-align: center;
	line-height: 46px;
	margin-top: 40px;
}
.botones div{
	width: 48%;
	float: left;
	text-align: right;
	padding-right: 2%;
	margin: 30px 0;
	-webkit-box-sizing: initial;
    box-sizing: initial;
}
.botones div+div{
	padding-left: 2%;
	text-align: left;
	padding-right: 0;
}
.botones div a{
	background-color: #90368A;
	padding: 15px 40px 13px 40px;
	color: #fff;
	font-family: 'Aller-Bold';
	font-size: 16px;
	text-decoration: none;
	border-radius: 50px;
	text-transform: uppercase;
	box-shadow: 0px 4px 8px 3px rgba(0, 0, 0, 0.3);
}
.delete{
	text-align: center;
}
.delete a{
	text-decoration: none;
	color: #000;
}
.delete span +  span{
	position: relative;
	top: -5px;
	font-family: 'Aller';
    font-size: 12px;
}
hr{
    border: 1px solid #fff;
    border-top: 0;
    width: 90%;
    margin-top: 10px;
    margin-bottom: 30px;
}
hr.blue{
    border: 1px solid #008EC3;
}
.btns{
	width: 85%;
	margin: 0 auto;
	font-family: 'Aller-Bold';
	font-size: 16px;
	color: #fff;
	text-align: center;
	background: #90368A;
	line-height: 45px;
	display: block;
	border-radius: 30px;
	text-transform: uppercase;
	text-decoration:none;
	border: 1px solid #90368A;
	margin-bottom: 35px;
	box-shadow: 0px 4px 8px 3px rgba(0, 0, 0, 0.3);
}
.btns.trans{
	background: rgba(0,0,0,0.2) !important;
	border: 1px solid #fff !important;
}
.info{
	text-align: center;
}
.info div{
	text-align: right;
	width:50%;
	float:left;
	font-family: 'Aller';
}
.info div + div{
	text-align: left;
	width:48%;
	padding-left: 2%;
	font-family: 'Aller-Bold';
}
.chk-area{
	position: relative;
	width: 75%;
	line-height: 42px;
	padding: 0 15px;
	background-color: rgba(0,0,0,0.1);
	border: 1px solid #fff;
	border-radius: 30px;
	margin: 0 auto;
	margin-bottom: 10px;

}
.chk-area span{
	font-family: 'Aller-Bold';
	color: #fff;
	font-size: 18px;

}
.in-ck {
	float: right;
    position: relative;
    top: 6px;
}
.ckbx {
	display:none;
}

.ckbx + label
{
	background: url('../../../layer-view-image/game/kinelo/check1.png') no-repeat center center;
	background-size: contain;
	height: 20px;
	width: 20px;
	display:inline-block !important;
	padding: 0 0 0 0px !important;
	 
}
.ckbx:checked + label
{
	background: url('../../../layer-view-image/game/kinelo/check2.png') no-repeat center center;
	background-size: contain;
	height: 20px;
	width: 20px;
	display:inline-block !important;
	padding: 0 0 0 0px !important;
}
.select-bx {
    padding: 30px 10px;
}
select.select-itm {
	font-family: 'Aller';
    width: 48%;
    margin-right: 2%;
		float: left;
		height: 30px;
		border: 0;
		border-radius: 5px;
		padding-left: 35px;
		font-size: 0.9em;
		padding-top: 2px;

}

.select-itm {
	font-family: 'Aller';
    width: 48%;
    margin-right: 2%;
		float: left;
		height: 30px;
		border: 0;
		border-radius: 5px;
		padding-left: 30px;
		font-size: 0.9em;
		padding-top: 2px;

}

.fecha{
	background: #fff url('../../../layer-view-image/game/kinelo/calendario.png') no-repeat 10px center;
	background-size: 13%;
}

select.select-itm.fecha {
	background: #fff url('../../../layer-view-image/game/kinelo/calendario.png') no-repeat 10px center;
	background-size: 13%;
}
select.select-itm.hora {
	background: #fff url('../../../layer-view-image/game/kinelo/hora.png') no-repeat 10px center;
	background-size: 13%;
}
select.select-itm + select {
    width: 48%;
    margin-left: 2%;
    margin-right: 0;
		float: right;
}
.label-resultado {
    text-align: center;
    font-size: 18px;
    /*font-weight: 600;*/
    color: #333333;
		margin-bottom: 30px;
}
.info-resultado {
    width: 90%;
    margin: 0 auto;
    background-color: #1FD3FD;
    padding: 5%;
		margin-bottom: 10px;
}
.info-resultado h1 {
    font-size: 14px;
    margin-top: 0;
    text-align: center;
    color: #90368A;
	margin-bottom: 5px;
}

.info-resultado-sorteo {
    color: #90368A !important;
}

.info-resultado p {
    font-size: 14px;
    text-align: center;
		margin-top: 0;
		margin-bottom: 5px;
		color: #333333
}
.info-resultado span {
    font-size: 14px;
		color: #333333
}
.numbers ul li input {
    display: none;
}
.numbers ul li input:checked+.ball_st {
	background: url('../../../layer-view-image/game/kinelo/bola2.png') center center no-repeat;
	background-size: contain;
	font-size: 18px;
	font-family: 'Aller';
	color: #fff;
	text-align: center;
	display: block;
	text-decoration: none;
}
.ball_st{
	background: url('../../../layer-view-image/game/kinelo/bola.png') center center no-repeat;
	background-size: contain;
	font-size: 18px;
	font-family: 'Aller';
	color: #000;
	text-align: center;
	display: block;
	text-decoration: none;
}

.ball_st_home{
	background: url('../../../layer-view-image/game/kinelo/bola.png') center center no-repeat;
	background-size: contain;
	font-size: 18px;
	font-family: 'Aller';
	color: #000;
	text-align: center;
	display: block;
	text-decoration: none;
	margin-right: 4px;
}

.hide{
	display: none;
}
.results-balls{
	width: 75%;
	margin: 0 auto;
	text-align: center;
}
.results-balls .result-ball {
    display: inline-block;
    text-align: center;
    overflow: hidden;
}
#container-animation{padding-top: 66px; height: 600px;}

.espacio{
	margin-top: 75px;
}

.close-button{
	z-index: 100000;
}

.menu-wrap{
	z-index: 100000 !important;
}

.main-kinelo {
  background-color: #02BAE2 !important; 
}

.main-kinelo .my-games .game-options a.ico {
    color: #000;
}

.main-kinelo .my-games .game-options a.ico:before {
    border-color: #000;
}

.main-kinelo .my-games .game-options a svg {
    fill: #000;
}

.boxes-game-ticket .box-game-ticket {
    padding:  0 !important;
    border-bottom: 0 !important;
}

.box-checkbox [type="checkbox"]:not(:checked) + label:before, .box-checkbox [type="checkbox"]:checked + label:before{
	content: none;
    border-color: transparent !important;
}

.box-checkbox [type="checkbox"]:not(:checked) + label:after, .box-checkbox [type="checkbox"]:checked + label:after{
	display: none !important;
}

.boxes-lots .box-checkbox{
	line-height: 42px !important;
}
/*
input[type="date"]::before{
   color: black;
   content: "FECHA " !important;
   padding-left:25px;
}
input[type="date"]:focus::before {
   color: black;
   content: "FECHA " !important;
   padding-left:25px;
}
*/

.select-fecha{
	padding-left:45px;
}

.select-itm-fecha::before{
   color: black;
   content: "FECHA " !important;
   padding-left:17px;
}

.select-itm-fecha:focus::before{
   color: black;
   content: "FECHA " !important;
   padding-left:17px;
}

.f_textoInterno{
	padding-right: 30px;
    padding-left: 30px;
    font-family: AllerRegular, Arial, sans-serif !important;
}

.btn.btn-red:hover{
	background-color: #d71b22 !important;
}

.title-game-ticket{
	font-size: 1.1em;
    font-family: AllerDisplay, Arial, sans-serif;
    text-transform: uppercase;
    text-align: center;
	margin-top:30px;
	margin-bottom:15px;
}

.title-game-ticket{
	font-size: 1.1em;
    font-family: AllerDisplay, Arial, sans-serif;
    text-transform: uppercase;
    text-align: center;
	margin-top:30px;
	margin-bottom:15px;
}

.game-desc{
	font-size: 1.5em;
    font-family: AllerDisplay, Arial, sans-serif;
    text-transform: uppercase;
    text-align: center;
}

.consecutive-seleccionado{
	background-color: #33d1f3 !important;
}

.add-size {
    font-size: 17.6px !important;
    font-family: 'AllerDisplay' !important;
}

.cart-count{
	font-family: AllerRegular, Arial, sans-serif !important;
}
