package pe.com.intralot.loto.layer.model.pojo;

import javax.persistence.Column;
import javax.persistence.Entity;
import javax.persistence.Id;
import javax.persistence.Table;

@Entity
@Table(name = "LOTOCARD.pin_printed")
public class PinPrinted {
	
	@Id
	@Column(name = "PIN_NUMBER_ID")
	private String pinNumberId;
	
	@Column(name = "PIN_AMOUNT")
	private Double pinAmount;

	public String getPinNumberId() {
		return pinNumberId;
	}

	public void setPinNumberId(String pinNumberId) {
		this.pinNumberId = pinNumberId;
	}

	public Double getPinAmount() {
		return pinAmount;
	}

	public void setPinAmount(Double pinAmount) {
		this.pinAmount = pinAmount;
	}
}
