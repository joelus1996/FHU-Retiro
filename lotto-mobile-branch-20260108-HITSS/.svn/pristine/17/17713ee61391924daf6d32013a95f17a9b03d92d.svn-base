:root {
  --color-white: #ffffff;
  --color-black: #000000;
  --color-primary: #07663a;
  --color-secondary: #fbe601;
  --color-accent: #3c6b34;
  --color-warning: #e30613;
  --color-success: #06c270;
  --color-error: #e9041b;
  --color-info: #1bbff2;
  --color-text-primary: #000000;
  --color-text-secondary: #5a5a5a;
  --color-opacity-50: rgba(0, 0, 0, 0.5);
  --color-disabled: #e2e2e2;
  --color-gray-100: #f2f2f2;
  --color-gray-200: #e2e2e2;
  --color-gray-300: #c2c4c2;
  --color-gray-400: #a5a5a5;
  --color-gray-450: #808080;
  --color-gray-600: #5a5a5a;
  --color-gray: #383a35;
  --color-scrollbar: #f2f2f2;
}

.Dialog-root {
  position: fixed;
  z-index: 999;
  right: 0;
  bottom: 0;
  top: 0;
  left: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.Dialog-root.is-open {
  z-index: 1300;
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.Dialog-backdrop {
  position: fixed;
  display: flex;
  align-items: center;
  justify-content: center;
  right: 0;
  bottom: 0;
  top: 0;
  left: 0;
  background-color: var(--color-opacity-50);
  -webkit-tap-highlight-color: transparent;
  z-index: -1;
}
.Dialog-container {
  height: 100%;
  outline: 0;
  display: flex;
  justify-content: center;
  align-items: center;
}
.Dialog-paper {
  background-color: var(--color-gray-100);
  color: var(--color-black);
  -webkit-transition: box-shadow 300ms cubic-bezier(0.4, 0, 0.2, 1) 0ms;
  transition: box-shadow 300ms cubic-bezier(0.4, 0, 0.2, 1) 0ms;
  margin: 32px;
  position: relative;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  max-height: calc(100% - 64px);
  max-width: 600px;
}
@media screen and (max-width: 360px) {
  .Dialog-paper:not(.Dialog-paperFullScreen) {
    margin: 24px;
  }
}
@media screen and (max-width: 648px) {
  .Dialog-paper.Dialog-paperFullScreen {
    margin: 0;
    display: flex;
    flex-direction: column;
    max-height: none;
    max-width: 100%;
    width: 100%;
    height: 100%;
  }
}
.Dialog-content {
  flex: 1 1 auto;
  -webkit-overflow-scrolling: touch;
  overflow-y: auto;
  padding: 20px 21px;
}
.Dialog-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 0 0 auto;
  /* padding: 8px; */
  padding-top: 0px;
  padding-left: 16px;
  padding-right: 16px;
  padding-bottom: 24px;
}
.Dialog-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
  background-color: transparent;
  outline: 0;
  border: 0;
  margin: 0;
  border-radius: 50%;
  padding: 8px;
  cursor: pointer;
  user-select: none;
  vertical-align: middle;
  text-decoration: none;
  color: var(--color-black);
  text-align: center;
  flex: 0 0 auto;
  overflow: visible;
  margin-top: -8px;
  margin-right: -8px;
  margin-bottom: -8px;
}

.Dialog-paper .icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.AlertDialog-paper,
.HelpDialog-paper {
  min-width: 296px;
  max-width: 360px;
  overflow: inherit;
}

/* Alert Dialog Styles */
.AlertDialog-content {
  font-family: 'Roboto', -apple-system, system-ui, sans-serif;
  color: var(--color-text-secondary);
  text-align: center;
  position: relative;
  overflow: inherit;
}
.AlertDialog-content .is-hidden {
  display: none !important;
}
.AlertDialog-header {
  display: flex;
  justify-content: flex-end;
  position: absolute;
  top: -30px;
  right: 0;
  left: 0;
}
.AlertDialog-header .Dialog-close {
  color: var(--color-white);
  margin-right: -12px;
}
.AlertDialog-image {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  width: 100%;
}
.AlertDialog-title {
  margin-top: 16px;
}
.AlertDialog-title h2 {
  font-size: 15px;
  font-weight: 700;
  line-height: 20px;
}
@media screen and (min-width: 768px) {
  .AlertDialog-title h2 {
      font-size: 16px;
  }
}
.AlertDialog-paragraph {
  margin-top: 16px;
}
.AlertDialog-paragraph p {
  font-size: 14px;
  font-weight: 400;
  line-height: 20px;
  margin: 0;
}
.AlertDialog-actions {
  flex-direction: column;
}
.AlertDialog-actions .btn-alert:not(:first-of-type) {
  margin-top: 16px;
}
.AlertDialog-actions .btn-alert {
  width: 100%;
  font-size: 18px;
  align-items: center;
  appearance: none;
  border-radius: 999px;
  border: 1px solid transparent;
  cursor: pointer;
  display: inline-flex;
  font-family: var(--font-base);
  font-weight: var(--medium);
  justify-content: center;
  line-height: 24px;
  outline: none;
  padding: 11px 24px;
  text-decoration: none;
  text-transform: capitalize;
}
.AlertDialog-actions .btn-alert.is-hidden {
  display: none;
}
.AlertDialog-actions .btn-alert-dialog-primary {
  background-color: var(--color-primary);
  color: var(--color-white);
  border: 1px solid var(--color-primary);
}
.AlertDialog-actions .btn-alert-dialog-outline-primary {
  background-color: var(--color-white);
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

/* Guide Dialog Styles */
.HelpDialog-content {
  font-family: 'Roboto', -apple-system, system-ui, sans-serif;
  color: var(--color-text-secondary);
  text-align: center;
  padding-top: 24px;
  padding-bottom: 24px;
  position: relative;
  overflow: inherit;
}
.HelpDialog-content p {
  font-size: 14px;
  font-weight: 400;
  line-height: 20px;
  text-align: justify;
  margin: 0;
}
.HelpDialog-content p > a {
  color: var(--color-primary);
  text-decoration: underline;
  font-weight: 600;
}
.HelpDialog-content > p:not(:last-child) {
  margin-bottom: 20px;
}
.HelpDialog-header {
  display: flex;
  justify-content: flex-end;
  position: absolute;
  top: -30px;
  right: 0;
  left: 0;
}
.HelpDialog-header .Dialog-close {
  color: var(--color-white);
  margin-right: -12px;
}

/* Ticket Dialog styles */
.TicketDialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 16px;
  min-height: 60px;
  background: var(--color-white);
  box-shadow: 0px 6px 14px rgba(0, 0, 0, 0.15);
  z-index: 2;
}
.TicketDialog-header .btn-icon {
  appearance: none;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  outline: none;
  cursor: pointer;
  padding: 0;
  border: none;
  background: transparent;
}
.TicketDialog-image {
  flex: 1 1;
  width: 100%;
  background: var(--color-white);
  box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.25);
}
.TicketDialog-image img {
  width: 100%;
  height: auto;
  min-height: 346px;
  max-width: 360px;
}
@media screen and (min-width: 648px) {
  .TicketDialog-paper {
      min-width: 392px;
  }
}

@media only screen and (min-width: 600px) {
  .Dialog-container ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
    background-color: rgba(0, 0, 0, 0);
  }

  .Dialog-container ::-webkit-scrollbar:hover {
    width: 6px;
    height: 6px;
    background-color: rgba(0, 0, 0, 0.06);
  }

  .Dialog-container ::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: var(--color-gray-300);
    transition: background-color 0.2s linear, width 0.2s;
    cursor: pointer;
  }

  .Dialog-container ::-webkit-scrollbar-thumb:active {
    border-radius: 999px;
  }

  .Dialog-container ::-webkit-scrollbar-track {
    background: var(--white-color);
  }
}