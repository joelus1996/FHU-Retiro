package pe.com.intralot.loto.layer.dto.client;

public class ClientBalanceInformationResponseDTO {
	private String status;
	private String message;
	private String token;
	private ClientBalanceDataDTO data;
	
	
	public String getStatus() {
		return this.status;
	}
	
	public void setStatus(String status) {
		this.status = status;
	}
	
	public String getMessage() {
		return this.message;
	}
	
	public void setMessage(String message) {
		this.message = message;
	}
	
	public String getToken() {
		return this.token;
	}
	
	public void setToken(String token) {
		this.token = token;
	}
	
	public ClientBalanceDataDTO getData() {
		return this.data;
	}
	
	public void setData(ClientBalanceDataDTO data) {
		this.data = data;
	}
}
