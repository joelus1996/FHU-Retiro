    border-radius: 5px;
    color: #fffff;
    font-weight: 700;
    font-size: 14px !important;
    text-decoration: none;
    position: relative;
    margin-top: 12px;
    font-family: AllerBold, Arial, sans-serif !important;
    text-align: center !important;
    padding: 0.7em 1em 0.7em 1.5em !important;
    line-height: 1em !important;
}

.main-wallet .top-wallet-jg .jg-tt-wallet {
    padding-bottom: 10px;
}

/* ====================
   Mejoras de Tinka Express 3.0
   ==================== */
.switch {
  position: relative;
  display: inline-block;
  width: 50px;
  height: 28px;
}

.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ccc;
  transition: 0.4s;
  border-radius: 34px;
}

.slider:before {
  position: absolute;
  content: "";
  height: 20px;
  width: 20px;
  left: 4px;
  bottom: 4px;
  background-color: white;
  transition: 0.4s;
  border-radius: 50%;
}

input:checked + .slider {
  background-color: #00cc88;
}

input:checked + .slider:before {
  transform: translateX(22px);
}

.auto-payment-table {
    width: 100%;
}

.auto-payment-table .title {
    font-size: 18px;
    color: #000000;
    font-weight: 700;
}

.auto-payment-table .right {
