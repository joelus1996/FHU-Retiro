}

.auto-payment-table .subtitle {
    font-size: 14px;
    color: #7f7d77;
    font-weight: 700;
}

.auto-payment-table .description {
    font-size: 14px;
    color: #7f7d77;
}

.justify-text {
    text-align: justify;
}

.button.button-orange-reverse.no-margin.green {
    background-color: #f2f2f2;
    color: #000000;
    box-shadow: none;
    border-radius: 30px;
    text-transform: none;
    height: 2.9em;
    line-height: 1em;
    text-align: center;
    display: block;
    border: 2px solid #07663a;
    font-family: AllerBold, Arial, sans-serif;
    cursor: pointer;
    padding: 0;
}