.title-form {
    font-size: 16px;
    font-family: AllerRegular, Arial, sans-serif;
    font-weight: 700;
    padding: 15px !important;
    color: #464646;
}
#form-book .content .right form .form-group .radio-button input:checked + label:before {
    background: white;
    border: solid 4px #07663a;
}
#form-book .content .right form .form-group .radio-button input {
    opacity: 0;
}
#form-book .content .left .block p {
    font-weight: 600;
    font-size: 16px;
}
#form-book .content .right form .form-group .radio-button label:before {
    content: '';
    position: absolute;
    width: 15px;
    height: 15px;
    background: white;
    border-radius: 50%;
    left: -18px;
    top: 5px;
    border: solid 1px #959595;
}

#form-book .content .right form .form-group .radio-button label {
    position: relative;
    top: 0px;
    left: 0px;
    cursor: pointer;
}
#form-book .content .right form .form-group .radio-button {
    display: inline-block;
    margin-right: 10px;
}
.title-form i {
    font-style: normal !important;
    position: absolute !important;
    left: 15px !important;
}
.title-form {
    position: relative !important;
    padding-left: 35px !important;
}
.text-ident p {
    text-align: justify !important;
}

.text-ident p {
    font-size: 12px !important;
    margin-bottom: 0px !important;
    color: #636363 !important;
}
.text-ident li:before {
    content: '*';
    position: absolute;
    left: 0px;
}
.text-ident li {
    position: relative;
    padding-left: 8px;
}
.text-ident ul {
    font-size: 12px;
    margin-bottom: 0px;
    color: #636363;
    margin: 0px;
    padding: 0px;
}
.text-ident {
    padding: 0px 15px;
    margin-bottom: 20px;
}
.text-ident-s a {
    display: inline-block;
    background: ##07663a;
    color: white;
    text-decoration: none;
    padding: 10px 20px;
    border-radius: 5px;
    line-height: 16px;
    font-size: 16px;
    padding-bottom: 12px;
}
.content-t p {
    font-size: 14px;
    color: #5A5A5A;
    margin-bottom: 10px;   
        font-family: 'roboto'; 
}
#form-book .content .right form .form-group .form-control:focus ~ label {
    text-transform: uppercase;
}
.dropdown-menu {
    left: 0px !important;
    border: none;
    padding-top: 0px;
    top: 47px;
}
.dropdown-menu.show {
    display: none;
}
#form-book .content .right form .form-group .form-control.valid ~ label {
    text-transform: uppercase;
}
#form-book .content .right form .form-group .form-control {
    border-color: #A5A5A5;
}
#form-book .content .right form .form-group label:not(.error) {
    color: #A5A5A5;
}
#form-book .content .left .block p {
    color: #5A5A5A;
}
.dropdown-toggle::after {
    display: inline-block;
    margin-left: 5px;
    vertical-align: .255em;
    content: "";
    border-top: 0.5em solid white;
    border-right: .5em solid transparent;
    border-bottom: 0;
    border-left: 0.5em solid transparent;
}
@font-face {
  font-family: 'Avenir';
  src: url("../../../v2/fonts/avenir-lt-black.eot");
  src: url("../../../v2/fonts/avenir-lt-black.eot?#iefix") format("embedded-opentype"), url("../../../layer-view-style/v2/fonts/avenir-lt-black.woff2") format("woff2"), url("../../../layer-view-style/v2/fonts/avenir-lt-black.woff") format("woff"), url("../../../layer-view-style/v2/fonts/avenir-lt-black.ttf") format("truetype");
  font-weight: 900;
  font-style: normal; }
  
  .title-form {
    font-family: 'Avenir';
  }
    @font-face {
  font-family: 'Roboto';
  font-style: normal;
  font-weight: 400;
  src: url('../../common/fonts/roboto.eot'); /* IE9 Compat Modes */
  src: local('Roboto'), local('Roboto-Regular'),
       url('../../common/fonts/roboto.eot?#iefix') format('embedded-opentype'), /* IE6-IE8 */
       url('../../common/fonts/roboto.woff') format('woff'), /* Modern Browsers */
       url('../../common/fonts/roboto.ttf') format('truetype'), /* Safari, Android, iOS */
       url('../../common/fonts/roboto.svg#Roboto') format('svg'); /* Legacy iOS */
}

#form-book .content .right form .form-group label:not(.error) {
    font-family: 'Roboto';
    top: 14px;
}
#form-book .content .right form .form-group .form-control.error ~ label {
    text-transform: uppercase;
}
#form-book .content .right .btn-submit {
font-family: 'Roboto';
}


#form-book .content .right form .form-group .form-control.valid ~ label {
    /*color: #f78f1e !important;*/
    left: 2.5em !important;
    font-size: 10px !important;
    color: #5A5A5A !important;
}

#form-book .content .left .block p {
    color: #5A5A5A;
    font-family: 'Roboto';
}
#form-book .content .right .btn-submit {
    padding: 12px 0px;
}
#form-book .content .left .block p {
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #5A5A5A;
}
#form-book .content .left .block {
    max-width: 400px;
    margin-left: auto;
    margin-right: 50px;
}
.form-contact-button-limpiar {
    display: block;
    text-align: center;
    font-family: roboto;
    text-transform: uppercase;
    font-size: 16px;
    padding: 14px 0px;
    margin-bottom: 20px;
}
.title-form.mobile-form-title i {
    left: 0px;
}
.title-form.mobile-form-title {
    padding-left: 20px;
}
#header .logo {
    top: 15px;
}
.text-ident ul {
    list-style: none;
}
.icon-list a span {
    top: 0px !important;
}
.icon-list a span i svg {
    top: -2px !important;
}
#form-book .content .right form .form-group .form-control.valid + label {
    color: #f78f1e;
}
#form-book .content .right form .form-group .form-control.valid {
    border-color: #5A5A5A;
}
.form-contact-button-limpiar {
    display: block !important;
    font-family: 'Roboto';
    font-size: 14px !important;
    padding: 14px 0px !important;
    padding-top: 15px !important;
}

.mobile-form-title i{
	left: 0px !important;
}

.title-form.mobile-form-title {
    padding-left: 20px !important;
}

.button{
	width: 100% !important;
    border: none !important;
    /*background: none !important;*/
    text-decoration: none !important;
    outline: none !important;
    -webkit-appearance: none !important;
    -moz-appearance: none !important;
    appearance: none !important;
    cursor: pointer !important;
    padding: 0 60px !important;
    display: inline-block !important;
    position: relative !important;
    font-family: "Roboto", sans-serif !important;
    font-weight: 700 !important;
    font-size: 16px !important;
    text-align: center !important;
    height: 48px !important;
    line-height: 44px !important;
    border-radius: 24px !important;
    -webkit-box-sizing: border-box !important;
    box-sizing: border-box !important;
}
	
.button__base{
	/*
	text-transform: uppercase !important;
    color: #ffffff !important;
    border: solid 2px #eb8830 !important;
    background-color: #eb8830 !important;
    */
}
.align-g-recaptcha{
	padding: 0px 15px;
    margin-bottom: 20px;
}

#form-book .btn-submit.button.button__base.color_green[disabled='disabled'] {
    background-color: #e2e2e2;
    border-color: #e2e2e2;
    cursor: default;
    color: #ffffff;
    box-shadow: none;
    pointer-events: none;
    
}  

span.help-block.form-error {
    font-family: AllerRegular, Arial, sans-serif;
    font-size: 10px;
    color: #CF161B;
    text-transform: uppercase;
    display: block !important;
    position: relative;
    left: 0px !important;
    top: 0px !important;
    text-align: left;
    padding: 0px !important;
    font-weight: 700;
    margin: 5px 0px;
}

.form__check input {
    position: absolute;
    opacity: 0;
}

.form__check input + label::before {
    content: '';
    margin-right: 5px;
    display: inline-block;
    vertical-align: text-top;
    width: 14px;
    height: 14px;
    border: solid 1px #1a6d30;
    border-radius: 2px;
    background-color: #ffffff;
    background-image: url(../../../layer-view-image/client/icon-check.svg);
    background-size: 10px;
    background-position: center;
    background-repeat: no-repeat;
}

.form__check input:checked + label::before {
    background-color: #1a6d30;
}

.form__check.has-error .help-block.form-error{
	font-family: AllerRegular, Arial, sans-serif;
    font-size: 10px;
    color: #CF161B;
    text-transform: uppercase;
    display: block !important;
    position: relative;
    left: 0px !important;
    top: 0px !important;
    text-align: left;
    padding: 0px !important;
    font-weight: 700;
    margin-top:0px;
    margin-left: 20px;
}

.form__check .link__base {
    color: #1a6d30;
    border-bottom: solid 1px #1a6d30;
    font-weight: 700;
}

/* styles imagenes de evidencia*/

.step {
  margin-left: 1rem;
  position: relative;
  font-weight: 400;
  font-size: 16px;
  line-height: 1.3rem;
  color: #5A5A5A;
  margin-bottom: 24px;
  text-align:justify;
  word-break: break-word;
}

.step:last-child {
  margin-bottom: 0;
}

.fileup-image {
  position: relative;
  margin-right: 1rem;
}

.fileup-image input[type="file"] {
  display: none;
}

.fileup-image .btn {
  width: 70%;
}

.fileup-image .hide {
  display: none;
}

.fileup-image .filename,
.fileup-image .filename-empty {
  font-weight: 400;
  font-size: 15px;
  line-height: 16px;
  color: #5A5A5A;
  padding-top: 0.7rem;
  margin-left: 4.5rem;
  display: block;
  word-break: break-word;
}

.fileup-image .filename-empty {
  display: none;
}

.fileup-image .empty .filename-empty {
  display: block;
}

.fileup-image .empty .filename-other,
.fileup-image .empty .filename-multiple {
  display: none;
}

.fileup-image .delimg {
  width: 24px;
  height: 24px;
  display: inline-block;
  color: #07663a;
  margin-left: 8px;
  font-size: 24px;
  vertical-align: middle;
  cursor: pointer;
}

[class^="icon-"], [class*=" icon-"] {
  font-family: 'ilot' !important;
  speak: none;
  font-style: normal;
  font-weight: normal;
  font-variant: normal;
  text-transform: none;
  line-height: 1;
  /* Better Font Rendering =========== */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}


.icon-error-min:before {
  content: "\e90b";
}

.fileup-image.is-error .btn {
  color: #FF0000;
  border-color: #FF0000;
}

.btn.is-secondary {
  border: 2px solid #07663a;
  background: #fff;
  color: #07663a;
}

.btn.is-secondary:hover {
  color: #07663a;
  border-color: #07663a;
  color: #fff;
  background: #07663a;
}

.btn {
  height: 36px;
  color: #fff;
  font-family: "Roboto", sans-serif;
  font-weight: bold;
  font-size: 12px;
  line-height: 16px;
  letter-spacing: 0;
  text-transform: uppercase;
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-align: center;
      -ms-flex-align: center;
          align-items: center;
  -webkit-box-pack: center;
      -ms-flex-pack: center;
          justify-content: center;
  background:  #e30613; 
  -webkit-box-sizing: border-box;
          box-sizing: border-box;
  border-radius: 30px;
  -webkit-transition: background 0.3s;
  transition: background 0.3s;
  border: 0;
  outline: none;
  margin: auto;
  min-width: 156px;
  cursor: pointer;
}



