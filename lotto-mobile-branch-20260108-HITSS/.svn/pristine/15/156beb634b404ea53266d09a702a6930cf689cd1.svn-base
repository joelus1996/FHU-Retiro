		<div align="center" >
			<form class="form-active-account" action="security_active_account.html" method="post" id="security_active_account_authentication">
							<div id="active_account_message" class="active_account_message">
							</div>
							<div class="control-form">
								<input class="control-custom" type="text" name="email" id="email" placeholder="E-mail:">
							</div>
							<span class="error" id="alertActiveAccount">${alertActiveAccount}</span>
							<BR>
							<div class="control-form">
								<button class="btn btn-orange" type="submit" id="activeAccount">ENVIAR</button>
							</div>	
						</form>	
			<BR>
 </div>
