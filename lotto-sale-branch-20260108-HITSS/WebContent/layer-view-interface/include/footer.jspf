<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/iframe-resizer/3.5.15/iframeResizer.js"></script>
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/iframe-resizer/3.5.15/iframeResizer.contentWindow.min.js"></script>
    <script type="text/javascript">

    	$(document).ready(function(){    	
    		iFrameResize({log:false}, '#myIframe');   
    		
    		if ( window.addEventListener ) {
    		    window.addEventListener('message', handleMessage, false);
    		} else if ( window.attachEvent ) { // ie8
    		    window.attachEvent('onmessage', handleMessage);
    		}
    		
    		var ban = localStorage.getItem("ban");
			if(ban=="OK"){
				window.location.href = 'inicio.html';
			}
    		
    	});

    	function handleMessage(e) {
    		if(e.data=='closeLogin'){
    			$('#loginBox').hide();
    		}else if(e.data==='closeLightboxCollectPrize'){
    			$('body').css('overflow-y', 'scroll');
    			$('body').find('#loading-ilot').remove();
    			$('body').find('#div-lightbox-collect-prize-ilot').remove();
    			//location.reload();
    			location.href="mi-cuenta.html#premios";
    		}else if(e.data==='closeLightboxRecharge'){
    			$('body').find('#loading-ilot').remove();
    			$('body').css('overflow-y', 'scroll');
    			$('body').find('#div-lightbox-recharge-ilot').remove();
    			
    			var ban = localStorage.getItem("ban");
    			if(ban=="OK"){
    				location.reload();
    			}
    		}else if(e.data==='closeLightboxAutocontrol'){
    			$('body').find('#loading-ilot').remove();
    			$('body').css('overflow-y', 'scroll');
    			$('body').find('#div-lightbox-recharge-ilot').remove();
    			window.location.href = 'autocontrol.html';
    		} else if (e.data==='closeLightboxTYCPDP') {
    			$('body').css('overflow-y', 'scroll');
    			$('body').find('#loading-ilot').remove();
    			$('body').find('#div-lightbox-tyc-pdp').remove();
    		}
    	}
    	
    </script>
<script type="text/javascript" src="layer-view-script/client/book/validate.js"></script>
