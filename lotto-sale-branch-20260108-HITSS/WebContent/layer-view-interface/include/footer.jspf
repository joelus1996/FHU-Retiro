<script>
var thisBtnAddSaldo = null;
$(window).on('load',function(){

	$.ajax({
        type: "POST",
        url: "load_recharge.html",
        dataType: "json",
        async: false,
        success: function (data) {
        	$("#clientSale-amount").text(floatFormat(data.billetera1));
        	$("#billetera2-amount").text(data.billetera2);
        	$("#billetera3-amount").text(data.billetera3);
        	$("#clientSale-amount-2").text(floatFormat(data.billetera1));
        }
	});

	$('#addSaldo').on('click', function () {
		thisBtnAddSaldo = this;
		// Se valida si el usuario tiene documentos pendientes de confirmación, el parámetro que recibe
		// es una function que se realizará en caso no tenga docs pendientes de confirmacion
		mainValidatePendingsDocsForAproval('footerAddSaldo');
	});

	$('#addSaldoW').on('click', function() {
		datalayerCargarSaldoW();
	    $('#addSaldo').trigger('click');
	});
	
	$('#lnkInicio').on('click', function() {
		$(parent.location).attr('href', 'mi-cuenta.html');
		
	});

	var cargarSaldo = getUrlParameter('cargarSaldo');
	if(cargarSaldo!=undefined && cargarSaldo!=null && cargarSaldo=="1"){
		$( "#addSaldo" ).trigger( "click" );	
	}
	/*
	
	$('#clientSale-amount-2').text(floatFormat($('#saldoUser').val()));
	$('#billetera3-amount').text(floatFormat($('#billetera3Cant').val()));*/
});


$('#openModal').on('click',function(e) {
	e.preventDefault();
	datalayerLogin(this);  
	//$('#loginBox').toggle();
	getFastTokenAndRedirect();
});
$('#buttonRegistrar').on('click',function(e) {
	datalayerRegistro(this);
});
$('.dropdown-toggle').on('click',function(e){
	e.stopPropagation();
	let $this = $(this);
	if ($this.hasClass('opacity')) {
		$this.removeClass('opacity');
		$this.closest('li').find('.dropdown-menu').hide();
	} else {
		$('.dropdown-menu').hide();
		$this.closest('li').find('.dropdown-menu').show();
		$('.dropdown-toggle').removeClass('opacity');
		$this.addClass('opacity');
	}
});
$('body').on('click',function(){
	$('.dropdown-toggle').removeClass('opacity');
	$('.dropdown-menu').hide();
});

function closeLightboxRechargeIlotF(){
	$('body').css('overflow-y', 'scroll');
	$('body').find('#loading-ilot').remove();
	$('body').find('#div-lightbox-recharge-ilot').remove();
	
	$.ajax({
        type: "POST",
        url: "load_recharge.html",
        dataType: "json",
        async: false,
        success: function (data) {
        	$("#clientSale-amount").text(floatFormat(data.billetera1));
        	$("#billetera2-amount").text(data.billetera2);
        	$("#billetera3-amount").text(data.billetera3);
        	$("#clientSale-amount-2").text(floatFormat(data.billetera1));
        }
	});
	
	if (typeof refreshBalance == 'function'){//valida que exista la funcion, es para raspaYa
		refreshBalance();	
	}

	if (typeof activaTimer == 'function'){//valida que exista la funcion, es para Casino
		activaTimer();	
	}
	
}
function retirar_loading(){
	setTimeout(function(){
		$('body').find('#loading-ilot').remove();
		$('#content-tab-item_4').find('#loading-ilot').remove();
	},500);
}

function getFastTokenAndRedirect() {
	var display = window.location.pathname;
	$.ajax({
        type: 'post',
        url: 'get-fast-token.html',
        dataType: 'json',
        data: 'display='+display
	}).done((res) => {
		if(res.message=="OK") {
			console.log(res);
			window.location.assign(res.redirect+"&token="+res.token);
			return res;
		}
    });
}

var $input = $('.fixeds-input input');
$input.on('blur',function(){
	let $ths = $(this);
	if (!$ths.val()){
		$ths.removeClass('active');
	} else {
		$ths.addClass('active');
	}
});
for (let a=0;a<$input.length;a++){
	if (!$input.eq(a).val()){
		$input.eq(a).removeClass('valid');
	} else {
		$input.eq(a).addClass('valid');
	}
}

$('#plays-1').on('mouseenter', function(){
	$('#loginBox').hide();
});
$('#plays-2').on('mouseenter', function(){
	$('#loginBox').hide();
});
$('body').on('click',function (e) {
    if ($(e.target).is('#openModal')) {
        // $('#loginBox').show();
    } else {
    	// $('#loginBox').hide();
    }
});
$('#loginBox').on('click',function (e) {
    e.stopPropagation();
});


$("#frmLoginClientIndex").validate({
	rules: {
		"user-client": "required",
		"password-client": "required"
	},
	messages: {
		"user-client": "DEBES INGRESAR TU USUARIO",
		"password-client": "DEBES INGRESAR TU CONTRASEŃA"
	},
	onfocusout: function(element) {
        this.element(element);  
    },
	errorElement : 'p',
    errorLabelContainer: '.errorTxt'
});

$('.drop--u .dropdown-header').on('click',function(event){
	  event.stopPropagation();
	  event.preventDefault();
	  var jQueryThis = $(this);
	  var dropaa = jQueryThis.closest('.drop--u');
	  if (dropaa.hasClass('active')){
		  dropaa.removeClass('active');
	  } else {
		  $('.drop--u').removeClass('active');
		  dropaa.addClass('active');
		  jQueryThis.closest('.dropdown-menu').show();
	  }
	});
$('aside .boxes-banner .box-banner a').on('click',function(){
	   $('#loginBox').hide();
	});
	
$("#password-client-header").bind("change keyup",function(){
	if( $("#password-client-header").val().length==0 ){
		$("#password-client-header-label").removeClass("fixeds-input-manual");
	}else if( $("#password-client-header").val().length>0 ){
		$("#password-client-header-label").addClass("fixeds-input-manual");
		$("#password-client-header").removeClass("error");
		$("#password-client-header").addClass("valid");
		$("#password-client-header").addClass("active");
		$("#errorTxt-onlypass").css("display","none");
	}
});

function footerAddSaldo() {
	validatePerfil("#"+$(thisBtnAddSaldo).prop('id'));
}

window.addEventListener("message", function(event) {
    if (event.data === "footerAddSaldo") {
    	footerAddSaldo(); 
    } else if (event.data === "footerRetirarLoading") {
    	retirar_loading();
	}
});

</script>
