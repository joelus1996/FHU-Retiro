<script type="text/javascript">

		function closeMensajeNotificacion(){
			try {
				cerrarMensajeNotificacion();
			} catch (e) {
				
			}
		}
		
		$(document).ready(function(){			
			$.ajax({
		        type: "POST",
		        url: "hasPendingNotificationsRead.html",
		        dataType: "json",
		        async: false
			})
