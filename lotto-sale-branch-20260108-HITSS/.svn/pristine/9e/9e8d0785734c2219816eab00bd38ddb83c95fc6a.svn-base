package pe.com.intralot.loto.layer.model.bean;

import java.io.Serializable;

public class GameBean implements Serializable {

    private static final long serialVersionUID = -7777384536315213083L;
    private String date;
    private String balance;
    private String bet_free;
    private String bet_middle_price;
    private String number_ticket;
    private String gameFaceTicket;
    private String gameFaceScratch;
    private String stateportal;
    private Double amount;

    public String getGameFaceScratch() {
        return gameFaceScratch;
    }

    public void setGameFaceScratch(String gameFaceScratch) {
        this.gameFaceScratch = gameFaceScratch;
    }

    public String getStateportal() {
        return stateportal;
    }

    public void setStateportal(String stateportal) {
        this.stateportal = stateportal;
    }

    public Double getAmount() {
        return amount;
    }

    public void setAmount(Double amount) {
        this.amount = amount;
    }

    public String getName() {
        return name;
    }

    public void setName(String name) {
        this.name = name;
    }

    public String getGameStateImageFlash() {
        return gameStateImageFlash;
    }

    public void setGameStateImageFlash(String gameStateImageFlash) {
        this.gameStateImageFlash = gameStateImageFlash;
    }

    private String name;
    private String gameStateImageFlash;

    public String getGameFaceTicket() {
        return gameFaceTicket;
    }

    public void setGameFaceTicket(String gameFaceTicket) {
        this.gameFaceTicket = gameFaceTicket;
    }

    public String getDate() {
        return date;
    }

    public void setDate(String date) {
        this.date = date;
    }

    public String getBalance() {
        return balance;
    }

    public void setBalance(String balance) {
        this.balance = balance;
    }

    public String getBet_free() {
        return bet_free;
    }

    public void setBet_free(String bet_free) {
        this.bet_free = bet_free;
    }

    public String getBet_middle_price() {
        return bet_middle_price;
    }

    public void setBet_middle_price(String bet_middle_price) {
        this.bet_middle_price = bet_middle_price;
    }

    public String getNumber_ticket() {
        return number_ticket;
    }

    public void setNumber_ticket(String number_ticket) {
        this.number_ticket = number_ticket;
    }
}
