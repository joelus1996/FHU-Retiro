    <meta charset="UTF-8">
    <meta name="viewport" content="width=1024">
    <link  rel="stylesheet" type="text/css" href="layer-view-style/common/normalize.css">
    <link  rel="stylesheet" type="text/css" href="layer-view-style/client/themeUser.css?v=5">
    <link  rel="stylesheet" type="text/css" href="layer-view-style/common/style.css?v=<%=Constants.common_style_css%>">
    <title>Collect Prize</title>
</head>
<body id="body-collect-prize">
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PWF5XVX"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<div id="content-collect-prize">
    <span id="options-title">Te damos 3 opciones:</span>
    <div>
        <span class="instructions">Haz clic en el icono de la lupa</span>
        <span id="lens"></span>
        <span class="instructions">  y escoge la opción que más te convenga</span>
    </div>
    <div id="options" class="group">
        <div id="option1">
            <div id="option1-title"><span id="image-number1"></span><span class="option-title">Cargar a saldo</span>
            </div>
            <div id="option1-description">Podrás cargar automáticamente a tu saldo sólo premios en efectivo igual o
                menor a S/.3,200
            </div>
            <div id="option1-image"></div>
        </div>
        <div id="option2">
            <div id="option2-title"><span id="image-number2"></span><span class="option-title">Cobrar en línea</span>
            </div>
            <div id="option2-description">Podrás cargar tus premios en efectivo a tu saldo y además jugar en línea tus
                premios de jugadas gratis y/o a mitad de precio.
            </div>
            <div id="option2-image"></div>
            <p id="option2-message">*Los premios jugada gratis y/o mitad de precio caducan a los 7 días de obtenidos</p>
        </div>
        <div id="option3">
            <div id="option3-title"><span id="image-number3"></span><span class="option-title">Cobrar en el Punto de Venta</span>
            </div>
            <!-- div id="option3-description">
                Presenta tu boleto impreso en los Puntos de Venta.
                Para ello ingresa tu número telefónico de contacto,
                activa el código de barras e imprime tu boleto.
                Para premios de hasta S/. 150 acércate al Punto de
                Venta más cercano. Para premios mayores a S/.150
                acércate a las oficinas de La Tinka.
            </div -->
            <div id="option3-description">
                Activa el c&oacute;digo de barras de tu boleto premiado e impr&iacute;melo para presentarlo en el punto de venta.
                Para premios de hasta S/. 150 ac&eacute;rcate al Punto de
                Venta m&aacute;s cercano. Para premios mayores a S/.150
                ac&eacute;rcate a las oficinas de La Tinka.
            </div>
            <div id="option3-image" class="group"></div>
        </div>
    </div>
    <div id="message-final">
        <p><span id="message-final-color1">Para retirar premios acumulados de Te Apuesto</span>
            antes debes generar tu boleto con el monto que deseas cobrar haciendo clic en <span id="message-final-color2">Liquidar</span>
        </p>
    </div>
</div>

</body>
</html>
