package pe.com.intralot.loto.layer.dto.visa;

import java.io.Serializable;

public class DataMap implements Serializable{

	private static final long serialVersionUID = 5097047109676796614L;
	private String userToken;
    private Double comisionVisanet;
    private Double balance;
    private Double igv;
    private Double totalVisanet;
    private Double debit;
	
	public String getUserToken() {
		return userToken;
	}
	public void setUserToken(String userToken) {
		this.userToken = userToken;
	}
	public Double getComisionVisanet() {
		return comisionVisanet;
	}
	public void setComisionVisanet(Double comisionVisanet) {
		this.comisionVisanet = comisionVisanet;
	}
	public Double getBalance() {
		return balance;
	}
	public void setBalance(Double balance) {
		this.balance = balance;
	}
	public Double getIgv() {
		return igv;
	}
	public void setIgv(Double igv) {
		this.igv = igv;
	}
	public Double getTotalVisanet() {
		return totalVisanet;
	}
	public void setTotalVisanet(Double totalVisanet) {
		this.totalVisanet = totalVisanet;
	}
	public Double getDebit() {
		return debit;
	}
	public void setDebit(Double debit) {
		this.debit = debit;
	}	
}
