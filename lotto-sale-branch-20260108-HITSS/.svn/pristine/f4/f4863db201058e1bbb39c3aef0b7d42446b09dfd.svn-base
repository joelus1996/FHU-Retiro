<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://java.sun.com/xml/ns/javaee" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd" id="WebApp_ID" version="2.5">
  <description>eCommerce sale</description>
  <distributable/>
  <servlet>
    <servlet-name>createDisposition</servlet-name>
    <servlet-class>pe.com.intralot.loto.layer.controller.payment.paysafecard.createDisposition</servlet-class>
    <load-on-startup>0</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>createDisposition</servlet-name>
    <url-pattern>/createDisposition</url-pattern>
  </servlet-mapping>
  <servlet>
    <servlet-name>showErrorAndDebug</servlet-name>
    <servlet-class>pe.com.intralot.loto.layer.controller.payment.paysafecard.showErrorAndDebug</servlet-class>
    <load-on-startup>0</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>showErrorAndDebug</servlet-name>
    <url-pattern>/showErrorAndDebug</url-pattern>
  </servlet-mapping>
  <servlet>
    <servlet-name>transError</servlet-name>
    <servlet-class>pe.com.intralot.loto.layer.controller.payment.paysafecard.transError</servlet-class>
    <load-on-startup>0</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>transError</servlet-name>
    <url-pattern>/transError</url-pattern>
  </servlet-mapping>
  <servlet>
    <servlet-name>transPN</servlet-name>
    <servlet-class>pe.com.intralot.loto.layer.controller.payment.paysafecard.transPN</servlet-class>
    <load-on-startup>0</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>transPN</servlet-name>
    <url-pattern>/transPN</url-pattern>
  </servlet-mapping>
  <servlet>
    <servlet-name>transSuccess</servlet-name>
    <servlet-class>pe.com.intralot.loto.layer.controller.payment.paysafecard.transSuccess</servlet-class>
    <load-on-startup>0</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>transSuccess</servlet-name>
    <url-pattern>/transSuccess</url-pattern>
  </servlet-mapping>
  <servlet>
    <servlet-name>teapuesto-site</servlet-name>
    <jsp-file>/layer-view-interface/game/teapuesto/teapuesto_site.jsp</jsp-file>
  </servlet>
  <servlet-mapping>
    <servlet-name>teapuesto-site</servlet-name>
    <url-pattern>/teapuesto-site/*</url-pattern>
  </servlet-mapping>
  <filter>
    <filter-name>characterEncodingFilter</filter-name>
    <filter-class>org.springframework.web.filter.CharacterEncodingFilter</filter-class>
    <init-param>
      <param-name>encoding</param-name>
      <param-value>UTF-8</param-value>
    </init-param>
    <init-param>
      <param-name>forceEncoding</param-name>
      <param-value>true</param-value>
    </init-param>
  </filter>
  <filter-mapping>
    <filter-name>characterEncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>
  <display-name>lotto-sale</display-name>
  <context-param>
    <param-name>contextConfigLocation</param-name>
    <param-value>classpath:resource/applicationContext.xml</param-value>
  </context-param>
  <listener>
    <listener-class>pe.com.intralot.loto.util.ContextListener</listener-class>
  </listener>
  <listener>
    <description>Spring Context Listener</description>
    <display-name>SpringContextListener</display-name>
    <listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
  </listener>
  <filter>
    <filter-name>hibernateFilter</filter-name>
    <filter-class>org.springframework.orm.hibernate3.support.OpenSessionInViewFilter</filter-class>
    <init-param>
      <param-name>singleSession</param-name>
      <param-value>true</param-value>
    </init-param>
  </filter>
  <filter-mapping>
    <filter-name>hibernateFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>
  <filter>
    <filter-name>springSecurityFilterChain</filter-name>
    <filter-class>org.springframework.web.filter.DelegatingFilterProxy</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>springSecurityFilterChain</filter-name>
    <url-pattern>*.html</url-pattern>
  </filter-mapping>
  <filter>
    <filter-name>TokenSessionFilter</filter-name>
    <filter-class>pe.com.intralot.loto.layer.filter.TokenSessionFilter</filter-class>
  </filter>
  <servlet>
    <servlet-name>dispatcher-servlet</servlet-name>
    <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
    <init-param>
      <param-name>contextConfigLocation</param-name>
      <param-value>classpath:resource/applicationContext-controller.xml</param-value>
    </init-param>
    <load-on-startup>1</load-on-startup>
  </servlet>
  <servlet>
    <servlet-name>Kaptcha</servlet-name>
    <servlet-class>com.google.code.kaptcha.servlet.KaptchaServlet</servlet-class>
    <init-param>
      <param-name>kaptcha.border</param-name>
      <param-value>no</param-value>
    </init-param>
    <init-param>
      <param-name>kaptcha.textproducer.font.color</param-name>
      <param-value>black</param-value>
    </init-param>
    <init-param>
      <param-name>kaptcha.textproducer.char.length</param-name>
      <param-value>6</param-value>
    </init-param>
    <init-param>
      <param-name>kaptcha.image.width</param-name>
      <param-value>170</param-value>
    </init-param>
    <init-param>
      <param-name>kaptcha.image.height</param-name>
      <param-value>50</param-value>
    </init-param>
  </servlet>
  <servlet-mapping>
    <servlet-name>dispatcher-servlet</servlet-name>
    <url-pattern>*.html</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>Kaptcha</servlet-name>
    <url-pattern>/Kaptcha.jpg</url-pattern>
  </servlet-mapping>
  <filter>
    <filter-name>InternavegacionFilter</filter-name>
    <filter-class>pe.com.intralot.loto.layer.filter.InternavegacionFilter</filter-class>
  </filter>
  <filter-mapping>
	 <filter-name>InternavegacionFilter</filter-name>
	 <url-pattern>/internavegacion/*</url-pattern>
	 <url-pattern>/*</url-pattern> 
  </filter-mapping>
  <session-config>
    <session-timeout>120</session-timeout>
  </session-config>
  <welcome-file-list>
    <welcome-file>/layer-view-interface/index.jsp</welcome-file>
  </welcome-file-list>
</web-app>