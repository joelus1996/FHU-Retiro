input[type=checkbox] {
    left: 8px;
    position: absolute;
    top: 5px;
    z-index: 1;      
    /*display: none;*/
}

#content label {
    /*-pie-background: linear-gradient(top, #f9f9f9 0%, #c7c6c2 100%);*/
    background: -moz-linear-gradient(top, #f9f9f9 0%, #c7c6c2 100%);
    background: -webkit-gradient(linear, 0% 0%, 0% 100%, from(#f9f9f9),     to(#c7c6c2) );
    background: -webkit-linear-gradient(top, #f9f9f9 0%, #c7c6c2 100%);
    background: -o-linear-gradient(top, #f9f9f9 0%, #c7c6c2 100%);
    background: -ms-linear-gradient(top, #f9f9f9 0%, #c7c6c2 100%);
    filter: progid:DXImageTransform.Microsoft.gradient(startColorstr=#f9f9f9, endColorstr=#c7c6c2, gradientType=0);
    display: inline-block;
    width: 20px;
    height: 20px;
    color: #646462;
    cursor: pointer;
    font-family: Arial;
    font-size: 10px;
    border-color: #c0bcb9;
    border-radius: 5px;
    text-align: center;
    line-height: 20px;
    font-weight: bold;
    border: 1px solid #c0bcb9;  
    user-select:none;
    -webkit-user-select:none;
    -moz-user-select:none;
    -o-user-select:none;
    -ms-user-select:none;
    /*behavior: url(layer-view-script/common/PIE/PIE.htc);*/}

#content .colorChecked {
    background: #a7097a;
    filter: progid:DXImageTransform.Microsoft.gradient(startColorstr=#a7097a, endColorstr=#a7097a, gradientType=0);
    /*-pie-background: #000000;*/
    color: #FFFFFF;
    border: 1px solid #a7097a;
    /*behavior: url(layer-view-script/common/PIE/PIE.htc);*/
}