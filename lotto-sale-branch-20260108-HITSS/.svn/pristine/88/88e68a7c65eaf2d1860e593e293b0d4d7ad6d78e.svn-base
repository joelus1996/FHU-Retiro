.datos_enunciado_cotejo_right { margin-left: 26px; margin-top: 70px; font-family: Arial; font-size: 11px; color: #52256a; font-weight: bold }
.datos_enunciado_contenido_cotejo_right { font-family: Arial; font-size: 11px; color: #454545 }
.datos_enunciado_cotejo_left { margin-left: 250px; margin-top: 70px; font-family: Arial; font-size: 11px; color: #52256a; font-weight: bold }
.cotejadores { font-family: Arial; margin-left: 26px; font-size: 11px; color: #454545 }
.datos_enunciado_contenido_cotejo_left { font-family: Arial; font-size: 11px; color: #454545 }
.datos_separador { margin-left: 26px; color: #f22b26; font-family: Arial; font-size: 15px; font-weight: bold; margin-left: 26px; margin-bottom: 5px }
.logo_teapuesto { margin-left: 26px; color: #306d20; font-family: Arial }
.calculo_premio { margin-left: 26px; margin-top: 10px; margin-bottom: 10px; color: #0681bb; font-family: Arial; font-size: 11px }
.table_teapuesto { font-family: Arial; font-size: 11px; width: 650px; margin-left: 26px; border-color: #a8a8a9 }
.th_teapuesto { background-color: #e00d0d; color: white; height: 11px; border-color: #a8a8a9 }
.td_teapuesto { color: #454545; height: 11px; text-align: center; border-color: #a8a8a9 }
.table_result_teapuesto { color: #52256a; background-color: #c7b5d2; height: 15px; border-bottom-color: #a8a8a9; border-color: #a8a8a9 }
.mensaje_teapuesto { font-family: Arial; font-size: 11px; color: #454545; margin-left: 26px }
.indicador_cotejo { margin-left: 26px; margin-top: 20px; font-family: Arial; font-size: 11px; color: #454545 }
.cotejador { font-family: Arial; font-size: 11px; color: #454545; margin-left: 26px; position: absolute; margin-top: -6px }
.cont_calculo { font-family: Arial; font-size: 11px; color: #454545; font-weight: normal }
#content-purchase { padding: 0 0 0 12px }