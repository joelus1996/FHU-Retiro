import java.io.Serializable;

import javax.persistence.Column;
import javax.persistence.Entity;
import javax.persistence.Id;
import javax.persistence.Table;

@Entity 
@Table(name = "LOTOCARD.VW_FLAG_POPUP_SIOSI")
public class ViewFlagPopupSiosi implements Serializable {

	private static final long serialVersionUID = 1L;

	@Id
	@Column(name = "FLAG_POPUP")
	private int flagPopup;

	public int getFlagPopup() {
		return flagPopup;
	}

	public void setFlagPopup(int flagPopup) {
		this.flagPopup = flagPopup;
	}
	
}
