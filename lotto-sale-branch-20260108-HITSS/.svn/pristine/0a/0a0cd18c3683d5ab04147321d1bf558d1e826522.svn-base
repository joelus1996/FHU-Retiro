package pe.com.intralot.loto.layer.dto.golden;

import com.google.gson.annotations.SerializedName;

public class BetKinelo {

	
	@SerializedName("lineId")
	private int lineId;
	
	 @SerializedName("marketId")
    private String marketId;
	 
	@SerializedName("marketName")
    private String marketName;
	
	@SerializedName("betParam")
    private String betParam;
	 
	@SerializedName("oddId")
    private String oddId;
	
	@SerializedName("oddName")
    private String oddName;
	
	@SerializedName("oddValue")
    private String oddValue;
	
	@SerializedName("minOdd")
    private double minOdd;
    
	@SerializedName("maxOdd")
    private double maxOdd;
    
	@SerializedName("solvedOdd")
    private double solvedOdd;
    
	@SerializedName("stake")
    private double stake;

	
	@SerializedName("wonAmount")
    private double wonAmount;
    
	@SerializedName("status")
    private String status;

	public int getLineId() {
		return lineId;
	}

	public void setLineId(int lineId) {
		this.lineId = lineId;
	}

	public String getMarketId() {
		return marketId;
	}

	public void setMarketId(String marketId) {
		this.marketId = marketId;
	}

	public String getMarketName() {
		return marketName;
	}

	public void setMarketName(String marketName) {
		this.marketName = marketName;
	}

	public String getBetParam() {
		return betParam;
	}

	public void setBetParam(String betParam) {
		this.betParam = betParam;
	}

	public String getOddId() {
		return oddId;
	}

	public void setOddId(String oddId) {
		this.oddId = oddId;
	}

	public String getOddName() {
		return oddName;
	}

	public void setOddName(String oddName) {
		this.oddName = oddName;
	}

	public String getOddValue() {
		return oddValue;
	}

	public void setOddValue(String oddValue) {
		this.oddValue = oddValue;
	}

	public double getMinOdd() {
		return minOdd;
	}

	public void setMinOdd(double minOdd) {
		this.minOdd = minOdd;
	}

	public double getMaxOdd() {
		return maxOdd;
	}

	public void setMaxOdd(double maxOdd) {
		this.maxOdd = maxOdd;
	}

	public double getSolvedOdd() {
		return solvedOdd;
	}

	public void setSolvedOdd(double solvedOdd) {
		this.solvedOdd = solvedOdd;
	}

	public double getStake() {
		return stake;
	}

	public void setStake(double stake) {
		this.stake = stake;
	}

	public double getWonAmount() {
		return wonAmount;
	}

	public void setWonAmount(double wonAmount) {
		this.wonAmount = wonAmount;
	}

	public String getStatus() {
		return status;
	}

	public void setStatus(String status) {
		this.status = status;
	}
	
	



}
