    <%@ include file="../../../include/header.jspf" %> 
    
    <div class="main-content" style="top: 0px;padding-top: 0px;">													
					<div class="main-game copa-casa" style="background-color: #d7e2e4;">
						<img src="layer-view-image/game/teapuesto/avionEstambul/home-desktop-estambul.png" alt="Te Apuesto te lleva a la Final de la Champions 2023" style="width: 100%;">
						<h2 style="color: #f75b1e;">Participa con tus tickets desde S/ 10</h2>
						<h3 style="color: #000000;">¿Quieres participar en la promoción?</h3>				
						<div class="copa-opciones2">
							<button style="width: 179px;" type="button" id="btnAvionEstambulRegistrar" onclick="return false;"class="button-avion-qatar-naranja" >Si quiero</button>
						</div>			
						<div class="f_linea-copabicolor2"></div>
						<div class="copa-opciones2">
							<button style="width: 179px;" type="button" id="btnAvionEstambulComoParticipar" onclick="return false;"class="button-avion-qatar-blanco">¿Cómo participar?</button>																																	
						</div>																																	
						<div class="copa-descripcion">
							<h3 style="color: #000000;">Del lunes 17 de abril al domingo 21 de mayo del 2023</h3>
						</div>
					</div>														
    </div>
    
    <script type="text/javascript" src="layer-view-script/common/jquery-3.6.3.min.js"></script>
