.holder {
	margin: 10px 0 0 4px;/*15px 0;*/
}

.holder a {
	/*font-size: 11px;*/
	cursor: pointer;
	margin: 0 3px;/*0 5px;*/
	color: #818181;/*#333;*/
	/*text-decoration: none;*/
	/*font-weight: bold;*/
}

.holder a:hover {
	/*background-color: #222;*/
	color: #000000;/*#fff;*/
	font-weight: bold;
}

.holder a.jp-previous { margin-right:5px;/*15px;*/text-decoration: none; }
.holder a.jp-next { margin-left:5px;/*15px;*/text-decoration: none; }

.holder a.jp-current, a.jp-current:hover { 
	color: #FF6600;/*#FF4242;*/
	font-weight: bold;
	text-decoration: none;
}

.holder a.jp-disabled, a.jp-disabled:hover {
	color: #bbb;
}

.holder a.jp-current, a.jp-current:hover,
.holder a.jp-disabled, a.jp-disabled:hover {
	cursor: default; 
	background: none;
}

.holder span { margin: 0 5px; }

.holder .indice_page { display:inline-block;margin-right:5px;color:#818181; }


