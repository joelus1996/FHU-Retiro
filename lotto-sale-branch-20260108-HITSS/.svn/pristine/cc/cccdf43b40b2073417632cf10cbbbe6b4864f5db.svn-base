/**Kabala Add On**/
.increases-your-prize-chch {
    background-color: #f2f2f2;
    /*margin: 12px 0 0 0;*/
    padding: 4px 4px 0;
    height:57px;
}
.increases-your-prize {
    background-color: #f2f2f2;
    /*margin: 12px 0 0 0;*/
    padding: 4px 4px 0;
    height:82px;
}
.chau-chamba-chch {
    float: left;
    padding: 4px 1% 0 1%;
    width: 98%
}
.plus, .chau-chamba {
    float: left;
    padding: 6px 1%;
    width: 48%
}
.plus label, .chau-chamba label, .chau-chamba-chch label {
    background-image: url(../../../layer-view-image/game/kabala/logo-addon.png);
    background-repeat: no-repeat;
    display: inline-block;
    font-size: 0;
    height: 28px;
    width: 58px
}
.plus label {
    background-position: 50% 0%
}
.chau-chamba label, .chau-chamba-chch label {
    background-position: 50% 93%
}
.text-increment {
    color: #818181;
    font-size: 10px;
    margin: 0 0 0 7px;
    position:relative;
    top:5px;
    display:inline-block;
}
.text-increment-1 ,
.text-increment-2 {
    color: #818181;
    font-size: 10px;
    margin: 0;
    padding: 2px 0 0 0;
    line-height: 10px;
}
.plus input, .plus label, .plus span,
.chau-chamba input, .chau-chamba label, .chau-chamba span,
.chau-chamba-chch input, .chau-chamba-chch label, .chau-chamba-chch span {
    display: inline-block;
    vertical-align: middle
}
.plus span, .chau-chamba span, .chau-chamba-chch span {
    color: #F78225;
    font-size: 12px;
    font-weight: bold;
    margin: 0 0 0 5px;
    line-height:10px;
}
.chau-chamba-chch span span {
    font-size:10px;
    margin:0;
    font-weight:normal;
}
.plus p, .chau-chamba p, .chau-chamba-chch p {
    text-align: justify
}
.plus p {}
.chau-chamba p {}
