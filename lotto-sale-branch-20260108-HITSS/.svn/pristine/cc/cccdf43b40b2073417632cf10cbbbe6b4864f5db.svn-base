.separate-bottun {
    padding: 1px;
}

.attribute-texarea {
    background: #FFF;
    border: 1px solid #e1e1e1;
    border-radius: 10px;
    resize: none;
    overflow: hidden;
    height: 38px;
    padding: 7px;
    width: 87px;
    font-size: 10px;
    font-family: Arial;
    color: #818181;
    behavior: url(layer-view-script/common/PIE/PIE.htc)
}

.attribute-button {
    background: #EEF4C6;
    border: 1px solid #EEF4C6;
    height: 14.5px;
    width: 100px;
    cursor: pointer
}

.attribute-button:hover {
    background: #E6EFA9;
    border: 1px solid #E6EFA9;
    height: 14.5px;
    width: 100px;
    cursor: pointer
}

.linear {
    float: left
}

.separate-textarea-bottuns {
    padding: 60px 0px 0px 0px
}

.separate-textarea-number {
    /*padding-left: 165px*/
    padding: 0 0 10px 165px;
}

.icon {
    padding: 4px 6px 10px 5px
}

.height-div {
    height: 59px
}

.text-play {
    -pie-background: linear-gradient(bottom, #ef710d 9%, #f9903c 69%);
    background-image: -o-linear-gradient(bottom, #ef710d 9%, #f9903c 69%);
    background-image: -moz-linear-gradient(bottom, #ef710d 9%, #f9903c 69%);
    background-image: -webkit-gradient(linear, 100% 100%, 100% 0%, color-stop(0.09, #ef710d), color-stop(0.69, #f9903c));
    background-image: -webkit-linear-gradient(bottom, #ef710d 9%, #f9903c 69%);
    background: -ms-linear-gradient(bottom, #ef710d 9%, #f9903c 69%);
    border-radius: 5px 5px 0px 0px;
    border-color: #f9903c;
    height: 18px;
    width: 279px;
    text-align: center;
    font-family: Arial;
    font-size: 11px;
    font-weight: bold;
    color: #ffffff;
    padding: 4px 0px 0px 0px;
    margin-bottom: 5px;
    behavior: url(layer-view-script/common/PIE/PIE.htc)
}

.number-textarea-button {
    /*padding: 5px 0px 0px 0px;*/
    /*padding: 0 0 8px 0;*/
    /*margin: 0 0 8px 0;*/
