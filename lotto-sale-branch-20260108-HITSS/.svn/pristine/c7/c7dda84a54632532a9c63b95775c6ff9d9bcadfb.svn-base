.label_1{display:block;color:#0681bc;padding:15px 0 15px 0;position:relative;top:0;}
.left-panel{width:304px;height:95px;padding-top:0;margin-right:22px;}
.right-panel{width:266px;padding-top:24px;}
#sub_purchase{padding-top:20px;}
.img_zona_segura{float:none;position:absolute;bottom:7px;}
#panel_finaliza_compra{margin:10px 37px 15px 0;}
.result_purchase .label_resu1_subscribe{top:10px;font-size:12px;font-weight:bold;}
.result_purchase .label_resu2_subscribe{top:31px;font-size:10px;}
.result_purchase .label_resu3_subscribe{top:50px;font-size:10px;font-weight:bold}
.result_purchase .label_resu4_subscribe{top:69px;font-size:10px;}
.result_purchase .label_resu1_subscribe, 
.result_purchase .label_resu2_subscribe, 
.result_purchase .label_resu3_subscribe, 
.result_purchase .label_resu4_subscribe{left:10px;position:absolute;width:220px;}
.result_purchase .result1_subscribe{position:absolute;font-weight:bold;font-size:12px;top:10px;right:10px;text-align:right;}
.result_purchase .result2_subscribe{position:absolute;font-size:10px;top:31px;right:10px;text-align:right;}
.result_purchase .result3_subscribe{position:absolute;font-size:10px;font-weight:bold;top:50px;right:10px;text-align:right;}
.result_purchase .result4_subscribe{position:absolute;font-size:10px;top:69px;right:10px;text-align:right;}
.right-panel .result_purchase{height:54px;}
.label-top{color:#FF6A24;font-size:13px;font-weight:bold;font-family:Arial;}
.label_info{color:#666666;font-family:Arial, sans-serif; font-weight:bold;line-height:22px;}
#panel_keep-playing{float:left;margin:8px 0 0 109px;padding:0;border:0;/*margin:8px 0 0 37px;*/}
#panel_game-history{float:right;margin:8px 0 0 7px;padding:0;border:0;width:138px;/*margin:8px 0 0 37px;*/}
#panel_keep-playing a.class-keep-playing{background:url(../../../layer-view-image/client/btn-seguir-jugando.png) no-repeat top left;/*game/tinka/subscription/btn_seguirjugando_off.png) no-repeat top left;*/width:135px;/*207px;*/height:30px;}
#panel_keep-playing a.class-keep-playing:hover{background-position:bottom left;}/*background:url(../../../layer-view-image/game/tinka/subscription/btn_seguirjugando_on.png) no-repeat top left;}*/
#panel_game-history a.class-game-history{background:url(../../../layer-view-image/client/btn-ir-a-mis-jugadas.png) no-repeat top left;/*game/tinka/subscription/btn_historial-off.png) no-repeat top left;*/width:112px;/*207px;*/height:30px;}
#panel_game-history a.class-game-history:hover{background-position:bottom left;}/*background:url(../../../layer-view-image/game/tinka/subscription/btn_historial-on.png) no-repeat top left;}*/
#panel_game-award{float:left;display:none;margin:8px 0 0 7px;/*140px;*/padding:0;border:0;width:118px;}
#panel_game-award a.class-game-award{background-image:url(../../layer-view-image/client/btn-ir-a-mis-premios.png);/*common/btn-ir-premios.png);*/background-position:top left;background-repeat:no-repeat;float:left;width:112px;/*102px;*/height:30px;/*26px;*/text-decoration:none;margin:0;padding:0;border:0}
#panel_game-award a.class-game-award:hover{background-position:bottom left}