.panel-subscription{position:relative;top:-19px;display:inline-block;}
.panel-subscription span{position:absolute;top:62px;font-size:12px;text-align:justify;margin:0 18px;line-height:16px;color:#337e18;}
.panel-subscription span a, .panel-subscription span a:active{font-size:11px;color:#337e18;}
.panel-subscription span a:hover{text-decoration:none;}
.panel-book{position:relative;top:0;}
.disabled{display:none;}
.section-central{float:left;width:614px;height:311px;background: url("../../../layer-view-image/game/tinka/subscription/tk-suscripcion.jpg")no-repeat top left;border-radius:8px 8px 0 0;}
.section-left{position:relative;top:0;left:0;width:304px;height:128px;float:left;margin:0;padding:0;background: url("../../../layer-view-image/game/tinka/subscription/tk-base-btn.jpg") no-repeat top left;border-radius:0 0 0 8px;}
.section-center{position:relative;top:0;left:0;width:6px;height:128px;float:left;margin:0;padding:0;background-color:#f8c617;}
.section-right{position:relative;top:0;right:0;width:304px;height:128px;float:left;margin:0;padding:0;background: url("../../../layer-view-image/game/tinka/subscription/tk-base-btn.jpg") no-repeat top left;border-radius:0 0 8px 0;}
.link-left, .link-left:active{position:absolute;top:0;right:0;width:170px;height:56px;background: url("../../../layer-view-image/game/tinka/subscription/btn-regular-off.png") no-repeat top left;}
.link-left:hover{background-image:url("../../../layer-view-image/game/tinka/subscription/btn-regular-on.png");}
.link-right, .link-right:active{position:absolute;top:0;right:0;width:170px;height:56px;background: url("../../../layer-view-image/game/tinka/subscription/btn-suscripcion-off.png") no-repeat top left;}
.link-right:hover{background-image: url("../../../layer-view-image/game/tinka/subscription/btn-suscripcion-on.png");}
.transition-subscription-one {
    background: #ffffff url("../../../layer-view-image/game/tinka/subscription/transition-one-suscripcion.gif") no-repeat 7px;
    width: 459px;
    height: 23px;
    border-radius: 5px 5px 0 0;
    padding-right: 7px;
    padding-top: 5px;
    margin-top: 65px;
    padding-bottom: 4px;
}
.transition-subscription-two {
    background: #ffffff url("../../../layer-view-image/game/tinka/subscription/transition-two-suscripcion.gif") no-repeat 7px;
    width: 459px;
    height: 23px;
    border-radius: 5px 5px 0 0;
    padding-right: 7px;
    padding-top: 5px;
    margin-top: 65px;
    padding-bottom: 4px;
}
.text-subscription-play1 {
    /*background-image: -o-linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);
    background-image: -moz-linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);
    background-image: -webkit-gradient(linear, 100% 100%, 100% 0, color-stop(0.09, #80ad25), color-stop(0.69, #a0cd47));
    background-image: -webkit-linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);
    background: -ms-linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);*/
    position:relative;
    background-color:#b6d971;
    /*border-radius: 5px 5px 0 0;*/
    /*border-color: #007bb6;*/
    height: 29px;
    width: 279px;
    /*text-align: center;*/
    font-size: 11px;
    font-weight: bold;
    color: #446625;
    padding: 0;
    margin: 0;
}
.text-subscription-play2 {
	position:relative;
    background-color:#d3e8aa;
    /*border-radius: 5px 5px 0 0;*/
    /*border-color: #007bb6;*/
    height: 29px;
    width: 303px;
    /*text-align: center;*/
    font-size: 11px;
    font-weight: bold;
    color: #446625;
    padding: 0;
    margin: 0;
}
.text-subscription-play1 span {margin:0;padding:8px 0 0 13px;position:absolute;vertical-align:top;line-height:12px;}
.text-subscription-play2 span {margin:0;padding:8px 0 0 13px;position:absolute;vertical-align:top;line-height:12px;}
.number-textarea-button1 {
    padding: 8px 0 0 0;
    background: url("../../../layer-view-image/game/tinka/subscription/background-paso01.gif") no-repeat top left;
    border-top: 0;
    border-left: 2px dotted #e0e0e0;
    border-right: 0;/*2px dotted #e0e0e0;*/
    border-bottom: 2px dotted #e0e0e0;
    width: 277px;
    height: 306px;
}
.number-textarea-button2 {
    padding: 8px 0 0 0;
    border-top: 0;
    border-left: 0;/*2px dotted #e0e0e0;*/
    border-right: 2px dotted #e0e0e0;
    border-bottom: 2px dotted #e0e0e0;
    width: 301px;
    height: 306px;
}
.panel-play{float:left;padding:0 0 0 7px;}
.panel-section{float:left;}
.panel-linear{float:left;padding:5px 0 0 0;width:147px;}
.panel-numbers{padding:5px 0 0 18px;float:left;width:110px;}
.panel-buttons{padding:102px 0 0 0;}
.panel-receipt{padding:5px 15px;line-height:16px;}
.panel-section-play {
    background-color: #ffffff;
    border-radius: 0 6px 6px 6px;
    margin-top: 5px;
    min-height: 420px;
    padding: 15px 0 10px 10px;
    position: relative;
    width: 605px;
}
.panel-section-receipt {
    background-color:#dddddd; /*none repeat scroll 0 0 rgb(217, 217, 217);*/
    width: 595px;
    height: 56px;
    position: absolute;
    top: 376px;
    border-radius: 6px;
}
.text-option {color:#818181;font-size:11px;padding:0 0 0 7px;display:block;}
a.type-play, a.type-play:active{background:url("../../../layer-view-image/game/tinka/subscription/btn-off.png") no-repeat top left;width:248px;height:18px;text-decoration:none;text-align:center;color:#666666;padding:4px 0 0 0;display:block;font-size:10px;font-weight:bold;margin:0 auto;}
a.type-play:hover, a.btn-active{background-image:url("../../../layer-view-image/game/tinka/subscription/btn-on.png");color:#ffffff;}
.pnl-mask{background-color:#FFFFFF;opacity:0.6;filter:alpha(opacity=60);position:absolute;/*top:40px;left:8px;*/z-index:99;}
#panel-disable1{width:276px;height:240px;}
#panel-disable2{width:296px;height:226px;}
#panel-same-play{padding:5px 0 0 0;}
#panel-random-play{padding:3px 0 0 0;}
#panel-buy{float:left;margin:8px 0 0 0;padding:0;border:0}
#panel-buy .button-buy{background:#d9d9d9 url("../../../layer-view-image/common/comprar.png") no-repeat top left;float:left;font-size:0;width:109px;height:30px;text-decoration:none;margin:0;padding:0;border:0}
#panel-buy .button-buy:hover{background-position:bottom left}
.number-textarea-button2 a.btn-discount10, a.btn-discount10:active{background:url("../../../layer-view-image/game/tinka/subscription/img-10dscto-off.gif") no-repeat top left;width:220px;height:28px;}
.number-textarea-button2 a.btn-discount10:hover, .number-textarea-button2 a.discount10-active{background-image:url("../../../layer-view-image/game/tinka/subscription/img-10dscto-on.gif");}
.number-textarea-button2 a.btn-discount20, a.btn-discount20:active{background:url("../../../layer-view-image/game/tinka/subscription/img-20dscto-off.gif") no-repeat top left;width:220px;height:28px;}
.number-textarea-button2 a.btn-discount20:hover, .number-textarea-button2 a.discount20-active{background-image:url("../../../layer-view-image/game/tinka/subscription/img-20dscto-on.gif");}
.number-textarea-button2 a.btn-discount30, a.btn-discount30:active{background:url("../../../layer-view-image/game/tinka/subscription/img-30dscto-off.gif") no-repeat top left;width:220px;height:28px;}
.number-textarea-button2 a.btn-discount30:hover, .number-textarea-button2 a.discount30-active{background-image:url("../../../layer-view-image/game/tinka/subscription/img-30dscto-on.gif");}
.number-textarea-button2 input{float:left;margin:9px 0 0 10px}
.number-textarea-button2 ul li{display:block;}
.number-textarea-button2 ul li:before{display:block;left:-0.4em;top:.4em;position:relative;text-indent:-18px;}
.number-textarea-button2 ul{list-style:none;}
.number-textarea-button2 span{font-size:11px;color: #818181;padding:3px 0 0 42px;display:block;text-align:justify;width:224px;}
.number-textarea-button2 span.text-mini{font-size:10px;padding:10px 0 0 42px;width:230px;}
.number-textarea-button2 span a{color:#818181;font-size:10px;}
.number-textarea-button2 .text-input{margin:0;padding:2px 0 0 13px;position:relative;vertical-align:top;line-height:30px;}
.number-textarea-button2 div a{color:#0681bc;font-size:11px;font-weight:bold;text-decoration:none;float:left;margin:0 0 0 5px;padding:0 0 0 5px;}
.number-textarea-button2 div.text-input{display:inline-block;}
.btn-help, .btn-help:active{background:url(../../../layer-view-image/common/ayuda.png) no-repeat 0 0;width:60px;height:30px;display:block;margin:-36px 0 0 550px;}
.btn-help:hover{background-position:0 -36px;}
.ui-input{position:relative;display:inline-block;}
/*.ui-block{display:none;}*/
.ui-title{padding:5px 10px;text-align:left;color:#FF6A24;font-family:Arial;font-size:14px;font-weight:bold;/*top left no-repeat;*/}
