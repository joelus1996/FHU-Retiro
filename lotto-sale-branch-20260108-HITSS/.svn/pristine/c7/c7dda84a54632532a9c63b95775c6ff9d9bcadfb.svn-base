/*Style ComboBox 2 - cotejo Tinka*/
div.selectBoxCotejo {
    position: relative;
    width: 48px;
    height: 18px;
    border: 1px solid #949494;
    background: #e4e4e2 url(../../../layer-view-image/common/flecha-combo.png) no-repeat 35px 8px;
    border-radius: 5px;
    font-family: Arial;
    font-size: 10px;
    top: -2px;
}

div.selectBoxCotejo div.box {
    position: absolute;
    left: 6px;
    top: 1px;
    width: 48px;
    height: 18px;
    line-height: 17px;
    font-family: arial;
    font-size: 10px;
    color: #4e4e4d;
    overflow: hidden;
}

div.selectBoxCotejo select {
    background: #e4e4e2;
    width: 48px;
    height: 20px;
    font-size: 10px;
    border: 1px solid #949494;
    opacity: 0;
    filter: alpha(Opacity = 0);
    -moz-opacity: 0;
    cursor: pointer;
    font-size: 10px;
    z-index: 1;
    
}

div.selectBoxCotejo select option {
    font-size: 10px;
    color: #4e4e4d;
    border-bottom: 1px solid #e4e4e2;
    cursor: pointer;
}

div.selectBoxCotejo select option.ultimo {
    border-bottom: 0px none;
}


/* Style boton cotejador */
div.BotonCotejo {
    position: relative;
    width: 48px;
    height: 18px;
    border: 1px solid #949494;
    background: #e4e4e2 no-repeat 35px 8px;
    border-radius: 5px;
    font-family: Arial;
    font-size: 10px;
    top: -2px;
}
