.separate-bottun { padding: 1px }
.attribute-texarea {
    background: #ffffff;
    border: 1px solid #e1e1e1;
    border-radius: 10px;
    resize: none;
    overflow: hidden;
    height: 38px;
    padding: 7px;
    width: 87px;
    font-size: 10px;
    color: #818181;
}
.attribute-button {
    background: #dde8c7;
    border: 1px solid #dde8c7;
    height: 14.5px;
    width: 100px;
    cursor: pointer
}
.attribute-button:hover {
    background: #d0dfb1;
    border: 1px solid #d0dfb1;
    height: 14.5px;
    width: 100px;
    cursor: pointer
}
.linear {float:left;}
.separate-textarea-bottuns { padding: 85px 0 0 0 }
.separate-textarea-number { padding-left: 165px }
.icon { padding: 4px 6px 6px 5px }
.height-div { height: 59px }
.text-play {
    background-image: linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);
    background-image: -o-linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);
    background-image: -moz-linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);
    background-image: -webkit-gradient(linear, 100% 100%, 100% 0, color-stop(0.09, #80ad25), color-stop(0.69, #a0cd47));
    background-image: -webkit-linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);
    background-image: -ms-linear-gradient(bottom, #80ad25 9%, #a0cd47 69%);
    border-radius: 5px 5px 0 0;
    border-color: #007bb6;
    height: 18px;
    width: 279px;
    text-align: center;
    font-size: 11px;
    font-weight: bold;
    color: #384a13;
    padding: 4px 0 0 0;
    margin-bottom: 5px;
}
.number-textarea-button {
    /*padding: 5px 0px 0px 0px;*/
    padding: 0 0 8px 0;
    border-top: 0;
    border-left: 2px dotted #e0e0e0;
    border-right: 2px dotted #e0e0e0;
    border-bottom: 2px dotted #e0e0e0;
    /*border-style: dotted;
    border-color: #e0e0e0;*/
    width: 275px;
    /*height: 225px;*/
    /*padding-top: 0*/
}
