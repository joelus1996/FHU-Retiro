package pe.com.intralot.loto.layer.dto.client;

import pe.com.intralot.loto.layer.model.domain.ClientGetCollectionType;

public class ClientInformationResponseDTO {
	private String status;
	private String message;
	private ClientGetCollectionType clientInformation;

	public String getStatus() {
		return status;
	}

	public void setStatus(String status) {
		this.status = status;
	}

	public String getMessage() {
		return message;
	}

	public void setMessage(String message) {
		this.message = message;
	}

	public ClientGetCollectionType getClientInformation() {
		return clientInformation;
	}

	public void setClientInformation(ClientGetCollectionType clientInformation) {
		this.clientInformation = clientInformation;
	}
	
}
