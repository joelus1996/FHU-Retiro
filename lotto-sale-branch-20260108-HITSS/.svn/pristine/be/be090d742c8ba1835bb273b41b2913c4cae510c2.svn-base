#primer-part input[name=check]{
    left: 8px;
    position: absolute;
    top: 5px;
    z-index: -999;
    /*display:none*/
}
#primer-part label { 
    -pie-background: linear-gradient(top,  #f9f9f9 0%, #c7c6c2 100%);
    background: -moz-linear-gradient(top,  #f9f9f9 0%, #c7c6c2 100%);
	background: -webkit-gradient(linear, 0% 0%, 0% 100%, from(#f9f9f9), to(#c7c6c2));
	background: -webkit-linear-gradient(top,  #f9f9f9 0%, #c7c6c2 100%);
	background: -o-linear-gradient(top,  #f9f9f9 0%, #c7c6c2 100%);
	background: -ms-linear-gradient(top,  #f9f9f9 0%, #c7c6c2 100%);
	display: inline-block; 
	width: 20px; 
	height: 20px;
	color: #646462;
	cursor: pointer; 
	font-family:Arial;
	font-size:10px;
	border-color:#c0bcb9;
	border-radius:5px;
	text-align:center;
	line-height:2;
	font-weight:bold;
	border: 1px double #c0bcb9;
	behavior:url(layer-view-script/common/PIE/PIE.htc);	
}
#primer-part .colorChecked { 
background: #ef5103;
 -pie-background: #ef5103;
 color:#FFF ;
 border: 1px solid #ef5103; 
behavior:url(layer-view-script/common/PIE/PIE.htc)}

.align-image{
margin-top: 12px;
position: absolute;
}
