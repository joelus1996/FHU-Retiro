#consecutive-draws {
	color: #818181;
	font-family: arial;
	font-size: 11px;
	margin: 30px 0 0 39px;
}

#message-draws {
	float: left;
	margin: 0 8px 0 0;
}

#abs-selectBox {
	float: left;
}

.selectBox {
	position: relative;
	width: 169px;
	height: 18px;
	border: 1px solid #949494;
	background: #e4e4e2 url("../../../layer-view-image/game/kinelo/flecha-combo.png") no-repeat 151px 8px;
	border-radius: 5px;
	font-family: Arial;
	font-size: 10px;
	top: -2px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

.box {
	position: absolute;
	left: 6px;
	top: 1px;
	width: 157px;
	height: 18px;
	line-height: 17px;
	font-family: arial;
	font-size: 10px;
	color: #4e4e4d;
	overflow: hidden;
}

div.selectBox select {
	background: none repeat scroll 0 0 #E4E4E2;
	border: 1px solid #949494;
	cursor: pointer;
	font-size: 10px;
	height: 18px;
	opacity: 0;
	width: 169px;
	z-index: 1;
	filter: alpha(opacity = 0);
}

div.selectBox select option {
	font-size: 10px;
	color: #4e4e4d;
	border-bottom: 1px solid #e4e4e2;
	cursor: pointer;
}

div.selectBox select option.ultimo {
	border-bottom: 0px none;
}

.your-bet {
	-pie-background: linear-gradient(right, #007CB6 95%, #0E8BC9 100%, #007CB6 100%);
	float: left;
	height: 213px;
	width: 140px;
	color: #818181;
	font-family: arial;
	font-size: 10px;
	background-image: linear-gradient(top, #bde6f0 0%, #ffffff 100%);
	background-image: -moz-linear-gradient(top, #bde6f0 0%, #ffffff 100%);
	background-image: -o-linear-gradient(top, #bde6f0 0%, #ffffff 100%);
	background-image: -webkit-gradient(top, #bde6f0 0%, #ffffff 100%);
	background-image: -webkit-linear-gradient(top, #bde6f0 0%, #ffffff 100%);
	background-image: -ms-linear-gradient(top, #bde6f0 0%, #ffffff 100%);
	filter: progid:DXImageTransform.Microsoft.gradient(startColorstr=#bde6f0, endColorstr=#ffffff, gradientType='0');
	margin: 4px 0 0 3px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

.your-numbers {
	float: left;
	height: 216px;
	width: 253px;
	margin: 12px 0 0 5px;
}

.your-numbers-are {
	float: left;
	height: 216px;
	width: 114px;
	color: #818181;
	font-family: arial;
	font-size: 11px;
	font-weight: bold;
}

.play {
	height: 216px;
	margin: 0 auto;
}

.margin {
	height: 25px;
	padding-left: 5px;
}

.margin-top {
	margin: 1px 0 0 0;
}

.your-bet-a {
	margin: 15px 0 0 8px;
}

.your-bet-b {
	margin: 40px 0 0 8px;
}

.margin-II {
	margin: 0 0 7px 7px;
	line-height: 10px
}

.attribute-texarea {
	background: #FFF;
	border: 1px solid #e1e1e1;
	border-radius: 10px;
	resize: none;
	overflow: hidden;
	height: 35px;
	width: 89px;
	font-size: 10px;
	font-family: Arial;
	color: #818181;
	margin: 20px 0 0 3px;
	padding: 6px;
	/*behavior: url(layer-view-script/common/PIE/PIE.htc);*/
	margin: 4px 0 0 5px;
}

.separate-textarea-bottuns {
	padding: 57px 0px 0px 0px;
}

.attribute-button {
	background: #e9e6ed;
	border: 1px solid #e9e6ed;
	height: 15px;
	width: 100px;
	cursor: pointer;
	margin: 0 auto;
}

.attribute-button:hover {
	background: #ffd7d8;
	border: 1px solid #ffd7d8;
	height: 15px;
	width: 100px;
	cursor: pointer;
	margin: 0 auto;
}

.separate-bottun {
	padding: 1px;
}

.icon {
	padding: 4px 6px 4px 5px;
}

.text {
	color: #ac1280;
	font-family: Arial;
	font-size: 10px;
	font-weight: bold;
	vertical-align: top;
}

.top-message {
	margin: 11px 0 0 5px;
}

#right-arrow {
	left: 562px;
	position: absolute;
	top: 104px;
	width: 25px;
}

.arrow-next {
	background-image: url("../../../layer-view-image/game/kinelo/btn_jugadas.png");
	background-repeat: no-repeat;
	background-position: -35px 0;
	width: 25px;
	height: 22px;
	cursor: pointer;
}

.arrow-next:hover {
	background-image: url("../../../layer-view-image/game/kinelo/btn_jugadas.png");
	background-repeat: no-repeat;
	background-position: -35px -28px;
}

.arrow-back {
	background-image: url("../../../layer-view-image/game/kinelo/btn_jugadas.png");
	background-repeat: no-repeat;
	background-position: 0 0px;
	width: 25px;
	height: 22px;
	cursor: pointer;
}

.arrow-back:hover {
	background-image: url("../../../layer-view-image/game/kinelo/btn_jugadas.png");
	background-repeat: no-repeat;
	background-position: 0 -28px;
}

.warning-next {
	background-image: url("../../../layer-view-image/game/kinelo/ir_jugada.png");
	background-repeat: no-repeat;
	background-position: -26px 0;
	width: 21px;
	height: 98px;
}

.warning-back {
	background-image: url("../../../layer-view-image/game/kinelo/ir_jugada.png");
	background-repeat: no-repeat;
	background-position: 0 0;
	width: 21px;
	height: 98px;
}

#arrow-warning {
	margin: 0 auto;
}

#message-discount {
	color: #818181;
	font-family: arial;
	font-size: 9px;
}

#div-message-discount {
	margin: 10px 0 0 25px;
}

.visible {
	height: 0;
	position: absolute;
	visibility: hidden;
	width: 0;
}

.check_ {
	margin-left: 0;
	margin-right: -1px;
}

.hide_play {
	display: none;
}

.show_play {
	display: block;
}

#prize {
	color: #0268A6;
	font-family: 'Myriad Pro', sans-serif;
	font-weight: bold;
	font-size: 18px;
	left: 156px;
	position: absolute;
	text-align: center;
	top: 3px;
	width: 200px;
}

#horary {
	color: #ffffff;
	font-family: 'Myriad Pro', sans-serif;
	font-size: 12px;
	font-weight: bold;
	left: 420px;
	position: absolute;
	text-align: center;
	top: 3px;
	width: 150px
}

#prize_table_kinelo {
	background-color: #FFFFFF;
	padding: 10px 20px;
	width: 597px;
}

#title-prize {
	font-family: arial, sans-serif;
	font-size: 12px;
	font-weight: bold;
	margin: 0 0 10px;
	color: #444444;
}

.message-prize {
	font-family: arial, sans-serif;
	font-size: 10px;
	color: #444444;
	margin: 0;
}

