#kinelo {
	float: left;
	margin: 0 0 0 32px;
	position: relative;
	width: 614px;
}

#banner {
	background: url("../../../layer-view-image/game/kinelo/banner_kinelo.png") no-repeat top left;
	border-radius: 0 0 6px 6px;
	height: 60px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

.transition-one {
	background-color: #FFF;
	background-image: url("../../../layer-view-image/game/kinelo/transition-one-two.png");
	background-position: center 0;
	background-repeat: no-repeat;
	border-radius: 5px 5px 0 0;
	height: 31px;
	margin-top: 6px;
	padding-right: 7px;
	width: 328px;
}

.transition-two {
	background-color: #FFF;
	background-image: url("../../../layer-view-image/game/kinelo/transition-one-two.png");
	background-position: center -29px;
	background-repeat: no-repeat;
	border-radius: 5px 5px 0 0;
	height: 31px;
	margin-top: 6px;
	padding-right: 7px;
	width: 328px;
}

#table-of-prize {
	background-color: #D9D9D9;
	background-image: url("../../../layer-view-image/game/kinelo/btn-ver-tabla-premios.png");
	background-repeat: no-repeat;
	background-position: 0 0;
	border-radius: 6px 6px 6px 6px;
	height: 26px;
	width: 58px;
	right: 80px;
	position: absolute;
	top: 65px;
	cursor: pointer;
}

#table-of-prize:hover {
	background-position: 0 -31px;
}

#help {
	background-image: url("../../../layer-view-image/common/ayuda-off.png");
	background-repeat: no-repeat;
	font-size: 0;
	height: 18px;
	position: absolute;
	right: 7px;
	top: 70px;
	width: 54px;
	cursor: pointer;
	display: block;
}

#help:hover {
	background-image: url("../../../layer-view-image/common/ayuda-on.png");
}

#transition { /*
    background-color: #FFF;
    margin: 7px 0 0 0;
    width: 342px;*/	
}

#content {
	background-color: #FFFFFF;
	border-radius: 0 6px 6px 6px;
	font-family: arial;
	font-size: 11px;
	padding-bottom: 10px;
}
#back-cont{
	background: #FFFFFFF;
}
.finalize-purchase {
	background-color: #ffffff;
	border-radius: 0 6px 6px 6px;
	font-family: arial;
	font-size: 11px;
	height: 403px;
	padding: 18px 0 20px 10px
}

.text-play {
	background: #0168a6;
	-pie-background: linear-gradient(bottom, #0168a6 9%, #1983c3 69%);
	background: -o-linear-gradient(bottom, #0168a6 9%, #1983c3 69%);
	background: -moz-linear-gradient(bottom, #0168a6 9%, #1983c3 69%);
	background: -webkit-gradient(linear, 100% 100%, 100% 0%, color-stop(0.09, #0168a6), color-stop(0.69, #1983c3));
	background: -webkit-linear-gradient(bottom, #0168a6 9%, #1983c3 69%);
	background: -ms-linear-gradient(bottom, #0168a6 9%, #1983c3 69%);
	filter: progid:DXImageTransform.Microsoft.gradient(startColorstr=#0168a6, endColorstr=#1983c3, gradientType=0);
	border-radius: 5px 5px 0px 0px;
	border-color: #1983c3;
	height: 22px;
	width: 518px;
	text-align: center;
	font-family: Arial;
	font-size: 11px;
	font-weight: bold;
	color: #FFF;
	line-height: 22px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

.plays {
	height: 270px;
	left: 38px;
	/*position: relative;*/
	top: 10px;
}

.dotted-border {
	padding: 5px 0px 0px 0px;
	border-top: 0px;
	border-left: 2px;
	border-right: 2px;
	border-bottom: 2px;
	border-style: dotted;
	border-color: #e0e0e0;
	width: 515px;
	height: 250px;
	padding-top: 0px;
}

.banner-play {
	background-image: url("../../../layer-view-image/game/kinelo/pasos-seleccion.png");
	background-repeat: no-repeat;
	width: 509px;
	height: 32px;
	margin: 0 auto;
}

.font {
	background: none repeat scroll 0% 0% rgb(217, 217, 217);
	width: 595px;
	height: 56px;
	border-radius: 6px;
	margin: 60px auto 0;
	/*behavior: url(layer-view-script/common/PIE/PIE.htc)*/
}

.center {
	padding: 13px 15px;
}

.color-text {
	float: left;
	font-size: 11px;
	font-family: arial;
	color: #000000;
	width: 420px;
}

.bold-type {
	font-weight: bold;
}

.text-distance {
	float: right;
	width: 125px;
}
