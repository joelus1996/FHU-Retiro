.tab-bono{/*display:block;position:relative;*/background-color:#636363;/*height:35px;margin-bottom:7px;margin-left:15px;margin-right:15px;border-radius:8px;border-style:solid;border-width:1px;border-color:#acaeae;cursor:pointer;*/background:-moz-linear-gradient(top, #858585 0%, #414141 100%);background:-webkit-gradient(linear, 0% 0%, 0% 100%, from(#858585), to(#414141));background:-webkit-linear-gradient(top, #858585 20%, #414141 100%);background:-o-linear-gradient(top, #858585 0%, #414141 100%);background:-ms-linear-gradient(top, #858585 0%, #414141 100%);filter:progid:DXImageTransform.Microsoft.gradient(startColorstr='#858585', endColorstr='#414141', gradientType='0')}
.tab-content-bono{background-color:#636363;color:#ffffff;margin:0 0 15px 0;padding:0 10px;width:553px;border:0;border-radius:8px 8px 0 0;background:-moz-linear-gradient(top, #858585 0%, #414141 100%);background:-webkit-gradient(linear, 0% 0%, 0% 100%, from(#858585), to(#414141));background:-webkit-linear-gradient(top, #858585 20%, #414141 100%);background:-o-linear-gradient(top, #858585 0%, #414141 100%);background:-ms-linear-gradient(top, #858585 0%, #414141 100%);filter:progid:DXImageTransform.Microsoft.gradient(startColorstr='#858585', endColorstr='#414141', gradientType='0')}
.item-bono-off{background-position:-6px -580px;}
.item-bono-on{background-position:-29px -580px;}
#btn-actept-culqi, #btn-clean-culqi{background-color:#FFFFFF;background-image:url(../../layer-view-image/client/btn-register.png);background-position:0 1px;background-repeat:no-repeat;border:1px solid #FFFFFF;border-radius:8px 8px 8px 8px;color:#FFFFFF;display:inline-block;font-size:11px;font-weight:bold;height:32px;margin:0 0 0 auto;padding:0;text-transform:uppercase;width:92px}
#btn-actept-culqi:hover, #btn-clean-culqi:hover{background-position:0 -35px}
#btn-actept-culqi:active, #btn-clean-culqi:active{top:1px}
#frm-culqi-register{position:relative}
#frm-culqi-register table{width:100%}
#frm-culqi-register table td{font-size:0;padding:0;white-space-collapse:discard}
#frm-culqi-register table .clabel{width:70px}
#frm-culqi-register table .clabel.aloft{vertical-align:top}
#frm-culqi-register table .cinputs .gread-box{width:98px}
#frm-culqi-register table .cinputs .gread-box td{height:18px}
#frm-culqi-register .personal-data-fields{padding:0 0 0 10px;width:320px}
#frm-culqi-register .personal-data-fields .cinputs{width:245px}
#frm-culqi-register .personal-data-fields{display:inline-block;margin:15px 0 0 0;vertical-align:top}
#frm-culqi-register .personal-data-fields label{color:#5f5e5e;font-weight:bold;vertical-align:middle}
#frm-culqi-register .personal-data-fields label{font-size:11px;line-height:11px}
#frm-culqi-register .large{width:152px}
#frm-culqi-register .max{width:99.5%}
#frm-culqi-register .min{width:75px}
#frm-culqi-register .medium{width:111px}
#frm-culqi-register .small{width:76px}
#frm-culqi-register .short{margin-left:2%;width:70px}
#frm-culqi-register .half{width:49%}
#frm-culqi-register .half:first-child{margin-right:2%!important}
#frm-culqi-register input{font-size:11px;margin:2px 0;vertical-align:middle}
#frm-culqi-register .select{left:-9999px;position:absolute}
#frm-culqi-register .value-in{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}