#options-title{font-size:13px;color:#f99631;font-weight:bold;}
#content-collect-prize{width:484px;color:#5e5e5e;height:411px;padding:12px 12px;width:484px;}
.instructions{font-size:13px;}
.option-title{top:-2px;color:#0681bc;display:inline-block;font-size:13px;font-weight:bold;left:2px;position:relative;}
#option1{background-image:-moz-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-o-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-webkit-gradient(linear, bottom, #dddddd 9%, #fcfbfb 69%);background-image:linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-webkit-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-ms-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);filter:progid:DXImageTransform.Microsoft.gradient(endColorstr=#dddddd, startColorstr=#fcfbfb, gradientType=0);border-radius:10px;border:1px solid #c0bcb9;display:inline-block;float:left;height:180px;width:227px;}
#option2{background-image:-moz-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-o-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-webkit-gradient(linear, bottom, #dddddd 9%, #fcfbfb 69%);background:linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-webkit-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-ms-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);filter:progid:DXImageTransform.Microsoft.gradient(endColorstr=#dddddd, startColorstr=#fcfbfb, gradientType=0);border:1px solid #c0bcb9;border-radius:10px 10px 10px 10px;display:inline-block;float:left;height:180px;margin-left:16px;width:237px;}
#option3{background-image:-moz-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-o-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-webkit-gradient(linear, bottom, #dddddd 9%, #fcfbfb 69%);background-image:linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-webkit-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);background-image:-ms-linear-gradient(bottom, #dddddd 9%, #fcfbfb 69%);filter:progid:DXImageTransform.Microsoft.gradient(endColorstr=#dddddd, startColorstr=#fcfbfb, gradientType=0);height:138px;margin:12px 0 0;border-radius:10px;border:1px solid #c0bcb9;position:relative;float:left;width:484px;}
#options{margin:12px 0 10px;}
#message-final-color1{font-weight:bold;color:#f99631;font-size:11px;}
#message-final-color2{font-weight:bold;color:#0681bb;font-size:11px;}
#image-number1{background-image:url(../../layer-view-image/client/img-cobrar-premio.png);background-position:0 -27px;background-repeat:no-repeat;display:inline-block;height:18px;margin:6px 0 0 10px;width:20px;}
#image-number2{background-image:url(../../layer-view-image/client/img-cobrar-premio.png);background-position:0 -55px;background-repeat:no-repeat;display:inline-block;height:18px;margin:6px 0 0 10px;width:20px;}
#image-number3{background-image:url(../../layer-view-image/client/img-cobrar-premio.png);background-position:0 -83px;background-repeat:no-repeat;display:inline-block;height:18px;margin:6px 0 0 10px;width:20px;}
#option1-description{margin:0 20px 0 33px;width:174px;}
#option2-description{margin:0 16px 0 29px;width:192px;}
#option3-description{margin-left:33px;width:255px;float:left;}
#option1-image,
#option2-image,
#option3-image{background-image:url(../../layer-view-image/client/img-cobrar-premio.png);background-repeat:no-repeat;}
#option1-image{background-position:-43px 2px;height:54px;left:56px;position:relative;top:22px;width:122px;}
#option2-image{background-position:-43px -59px;height:52px;left:25px;position:relative;top:14px;width:190px;}
#option3-image{background-position:-44px -117px;height:129px;position:absolute;right:20px;top:5px;width:158px;}
#option2-message{font-size:10px;height:26px;left:27px;position:relative;top:9px;width:198px;}
#body-collect-prize{background:#ffffff;}
.liquidate-info-img{background-image:url(../../layer-view-image/common/img_flecha_up.png);background-repeat:no-repeat;bottom:35px;display:none;height:8px;left:475px;position:absolute;top:19px;width:15px;z-index:2}
.liquidate-info{background-color:#FFFFFF;border-color:#919191;border-radius:4px 4px 4px 4px;border-style:solid;border-width:1px;box-shadow:0 0 0.25em #CCCCCC;color:#5E5E5E;display:none;float:left;left:383px;padding:4px;position:absolute;text-align:center;top:26px;width:202px;z-index:1}
#window-liquidate-1{background-color:#f99631;height:284px;left:50%;margin:-162px 0 0 -267px;padding:30px 8px 8px;position:fixed;top:50%;width:514px;z-index:999}
.title-window{color:#ffffff;font-size:13px;font-weight:bold;position:absolute;text-align:left;top:7px}
.close{background-color:#f99631;background-image:url(../../layer-view-image/common/btn-cerrar-off.png?v=2);background-repeat:no-repeat;cursor:pointer;border:0 none;height:20px;left:463px;padding:0;position:absolute;top:4px;width:58px}
.close:hover{background-image:url(../../layer-view-image/common/btn-cerrar-over.png?v=2)}
.resize{background-image:url(../../layer-view-image/common/resize.gif);background-repeat:no-repeat;display:block;height:13px;left:511px;position:absolute;top:307px;width:13px}
#content-liquidate-accumulated-prize-1{background:#ffffff;width:515px;font-size:13px;color:#5e5e5e}
#back{background-color:#000000;height:100%;opacity:0.7;position:fixed;width:100%;z-index:500}
.no-scroll{overflow:hidden}
.image-cyg {background-color:#ffffff;background-image:url(../../layer-view-image/client/logos-juegos-liquidar.png);background-repeat:no-repeat;float:left;font-size:0;height:80px;margin:11px 0 0 14px;width:103px}
.image-cyg {background-position:-8px -3px}
.image-dv {background-color:#ffffff;background-image:url(../../layer-view-image/client/imgTeapuesto.jpg);background-size: 100%;background-repeat:no-repeat;float:left;font-size:0;height:70px;margin:11px 0 0 12px;width:137px}
#right-panel{float:left;margin:11px 0 0 18px;width:352px}
#message-title{color:#f99631;font-weight:bold}
#amount-message{color:#0681bb;font-weight:bold}
#right-panel p{margin:5px 0}
.p-top{margin:12px 0 0 0 !important}
#frm-charge{margin:10px 0 0 0}
