fieldset{border:0;margin:0;padding:0}
.hidden{display:none}
.group:after{content:'';display:table;clear:both}
.ico-search{background-image:url(../../layer-view-image/common/grid-icons.png);background-repeat:no-repeat;background-position:-180px -109px;cursor:pointer;height:16px;width:17px}
.ico-search:hover{background-position:-180px -70px}
.ico-collate{background-image:url(../../layer-view-image/common/grid-icons.png);background-position:-379px -110px;background-repeat:no-repeat;cursor:pointer;height:16px;width:17px}
.ico-collate:hover{background-position:-379px -70px}
.draw-paginator{font-size:10px;color:#818181;margin-left:4px;margin-top:10px}
#grilla_price{margin-top:8px}
.columns-grid{position:relative;height:19px;background-color:#0681bc;font-size:11px;color:#ffffff;font-weight:bold}
#x-comMovil{width:100px}
.columns-grid .column{top:4px;position:absolute}
.row-grid{cursor:default;position:relative;height:18px;font-size:11px;border-bottom-style:solid;border-width:1px;border-bottom-color:#75bce5;padding-bottom:2px;color:#5e5e5e;-pie-background:linear-gradient(top, #f9f9f9 0%, #e5e8e9 100%);background:-moz-linear-gradient(top, #f9f9f9 0%, #e5e8e9 100%);background:-webkit-gradient(linear, 0% 0%, 0% 100%, from(#f9f9f9), to(#e5e8e9));background:-webkit-linear-gradient(top, #f9f9f9 0%, #e5e8e9 100%);background:-o-linear-gradient(top, #f9f9f9 0%, #e5e8e9 100%);background:-ms-linear-gradient(top, #f9f9f9 0%, #e5e8e9 100%);behavior:url(layer-view-script/common/PIE/PIE.htc)}
.row-grid2{position:relative;height:18px;font-size:11px;border-bottom-style:solid;border-width:1px;border-bottom-color:#46b9ed;padding-bottom:2px;color:#666666;cursor:default;-pie-background:linear-gradient(top, #eff5f7 0%, #dcf0f6 100%);background:-moz-linear-gradient(top, #eff5f7 0%, #dcf0f6 100%);background:-webkit-gradient(linear, 0% 0%, 0% 100%, from(#eff5f7), to(#dcf0f6));background:-webkit-linear-gradient(top, #eff5f7 0%, #dcf0f6 100%);background:-o-linear-gradient(top, #eff5f7 0%, #dcf0f6 100%);background:-ms-linear-gradient(top, #eff5f7 0%, #dcf0f6 100%);behavior:url(layer-view-script/common/PIE/PIE.htc)}
.row-grid .row{position:absolute;top:4px;height:17px;overflow:hidden;white-space: nowrap;}
.row-grid2 .row{position:absolute;top:4px;height:17px;overflow:hidden;white-space: nowrap;}
.row-acu{position:relative;height:30px;font-size:11px;border-bottom-style:solid;border-width:1px;border-bottom-color:#acaeae;padding-bottom:2px;color:#5e5e5e;font-family:arial;-pie-background:linear-gradient(top, #e5e8e9 0%, #cccccc 100%);background:-moz-linear-gradient(top, #e5e8e9 0%, #cccccc 100%);background:-webkit-gradient(linear, 0% 0%, 0% 100%, from(#e5e8e9), to(#cccccc));background:-webkit-linear-gradient(top, #e5e8e9 0%, #cccccc 100%);background:-o-linear-gradient(top, #e5e8e9 0%, #cccccc 100%);background:-ms-linear-gradient(top, #e5e8e9 0%, #cccccc 100%);behavior:url(layer-view-script/common/PIE/PIE.htc)}
.row-acu .acu-item{color:#0681bc;position:absolute;top:4px}
.tab-intro{margin:0 10px 0 10px;min-height:172px;/*212px;*/padding:0 0 10px 0;/*4px 0 10px 0;*/width:553px}
.tab-intro .enlace{font-size:11px;font-weight:bold;color:#0681bc}
.price-info{cursor:pointer}
#num_link_cc{margin-top:5px;margin-left:32px;font-size:10px;color:#818181}
.num_page_on{cursor:pointer;text-decoration:underline;color:#818181}
.num_page_off{cursor:pointer;text-decoration:none;color:#818181}
.row_null{display:none}
#scroll-grid{overflow-x:scroll;width:552px;/*height:200px;*/margin:6px 0 0 0;}
#grilla_result{width:650px}
