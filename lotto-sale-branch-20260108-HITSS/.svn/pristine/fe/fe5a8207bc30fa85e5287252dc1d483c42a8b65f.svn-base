#window-liquidate-2{background-color:#f99631;left:50%;margin:-74px 0 0 -263px;padding:30px 5px 10px;position:fixed;top:40%;width:516px;z-index:999}
#content-liquidate-accumulated-prize-2{background-color:#ffffff;color:#5e5e5e;font-size:13px;height:108px;width:515px}
#resize-2{top:144px}
#message-result{float:left;height:64px;margin:18px 0 0 12px;width:354px}
#message-result-sl{float:left;height:64px;margin:18px 0 0 87px;width:345px;text-align: center;}
#frm-update-client .other-fields{margin:15px 0 0}
#panel_transaccion span a{color:#ffa951;font-weight:bold;display:inline-block;margin:0 0 5px 0;}
#panel_transaccion span a:hover{color:#ffffff;}
