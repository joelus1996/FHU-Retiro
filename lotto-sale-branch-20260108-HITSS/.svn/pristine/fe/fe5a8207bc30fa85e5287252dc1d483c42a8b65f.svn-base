#content-client-balance{float:left;margin-left:33px;margin-top:8px}
#content-my_account{width:605px;min-height:446px;background-color:#ffffff;padding-top:10px;padding-bottom:10px;border-radius:0 0 5px 5px;behavior:url(layer-view-script/common/PIE/PIE.htc)}
.tab-item{display:block;position:relative;background-color:#ccffff;height:35px;margin-bottom:7px;margin-left:15px;margin-right:15px;border-radius:8px;border-style:solid;border-width:1px;border-color:#acaeae;cursor:pointer;background:-moz-linear-gradient(top, #fdfdfd 0%, #d4d4d4 100%);background:-webkit-gradient(linear, 0% 0%, 0% 100%, from(#d4d4d4), to(#d4d4d4));background:-webkit-linear-gradient(top, #fdfdfd 20%, #d4d4d4 100%);background:-o-linear-gradient(top, #fdfdfd 0%, #d4d4d4 100%);background:-ms-linear-gradient(top, #fdfdfd 0%, #d4d4d4 100%);filter:progid:DXImageTransform.Microsoft.gradient(startColorstr='#fdfdfd', endColorstr='#d4d4d4', gradientType='0')}
.text-item-1{min-width:100px;text-transform:uppercase}
.text-item-2{text-align:right;width:390px}
.text-item-3{text-align:right;width:340px}
.text-item-1, .text-item-2, .text-item-3{color:#666666;float:left;font-size:13px;font-weight:bold;margin:10px 0 0 0;padding:0;overflow:hidden;height:15px;}
.balance-available{color:#818181;height:auto;margin: 0px 0px 5px 30px;width:529px;font-weight:normal;text-align: left;}
.color-title-balance{color:#000000;font-weight:bold}
.text-item-1 .user-name,
.item-title-1 .user-name{text-transform:capitalize!important}
#tab-item_1 .text-item-1{color:#ff6600!important}
#tab-account{background:#ffffff;width:100px;color:#f9710f;font-weight:bold;font-size:18px;padding:6px 30px 0 18px;border-radius:5px 5px 0 0;behavior:url(layer-view-script/common/PIE/PIE.htc)}
.tab-content{display:none;border-radius:8px;border:1px solid #ff6600;margin-left:15px;margin-right:15px;margin-bottom:7px;position:relative;behavior:url(layer-view-script/common/PIE/PIE.htc)}
.head-tab-content{width:553px;border-color:#ff6600;border-style:solid;border-width:0 0 1px 0;margin-left:10px;margin-right:10px;color:#ff6600;cursor:pointer}
.head-tab-content .item-title-1{min-width:100px;margin:10px 0 0 0;text-transform:uppercase;}
.head-tab-content .item-title-2{margin:10px 0 0 0;text-align:right;width:390px;}
.head-tab-content .item-title-3{margin:10px 0 0 0;text-align:right;width:340px;}
.head-tab-content .item-title-1, .head-tab-content .item-title-2{color:#ff6600;float:left;font-size:13px;font-weight:bold;padding:0}
.head-tab-content .item-title-3{color:#ffffff;float:left;font-size:13px;font-weight:bold;padding:0}
.head-tab-content .item-title3 span{font-weight:normal;}
.item_ico1_off, .item_ico2_off, .item_ico3_off, .item_ico4_off, .item_ico5_off{background-image:url(../../layer-view-image/common/img-micuenta.png);background-repeat:no-repeat;float:left;height:24px;margin:8px 6px 0 10px;padding:0;width:24px}
.item_ico1_off{background-position:0 0;}
.item_ico2_off{background-position:0 -44px;}
.item_ico3_off{background-position:0 -88px;}
.item_ico4_off{background-position:0 -131px;}
.item_ico5_off{background-position:0 -173px;}
.item_ico6_off{background-image:url(../../layer-view-image/common/img-micuenta.png);background-repeat:no-repeat;float:left;height:27px;margin:4px 6px 4px 10px;padding:0;width:27px;}
.item_ico6_off{background-position:-32px -545px;/*0 -546px*/}
.item_off{float:right;margin:8px 9px 0 8px;padding:0;width:24px;height:14px;background:url(../../layer-view-image/common/img-micuenta.png) no-repeat 0 -210px;}
.item_ico1_on, .item_ico2_on, .item_ico3_on, .item_ico4_on, .item_ico5_on{background-image:url(../../layer-view-image/common/img-micuenta.png);background-repeat:no-repeat;float:left;height:24px;margin:8px 6px 0 0;padding:0;width:24px;}
.item_ico1_on{background-position:0 0;}
.item_ico2_on{background-position:-23px -44px;}
.item_ico3_on{background-position:-23px -88px;}
.item_ico4_on{background-position:-23px -131px;}
.item_ico5_on{background-position:-23px -173px;}
.item_ico6_on{background-image:url(../../layer-view-image/common/img-micuenta.png);background-repeat:no-repeat;float:left;height:27px;margin:4px 6px 4px 0;padding:0;width:27px;}
.item_ico6_on{background-position:-32px -545px;}
.item_on{float:right;margin:8px 0 0 0;padding:0;width:24px;height:14px;background:url(../../layer-view-image/common/img-micuenta.png) no-repeat -23px -210px;}
.it_on_balance{margin-top:-17px;}
.tooltip-info{z-index:1;display:none;position:relative;padding:3px 3px 3px 3px;width:97px;background-color:#ffffff;border-style:solid;border-color:#919191;border-width:1px;border-radius:4px;box-shadow:0 0 .25em #cccccc;font-size:11px;font-weight:bold;color:#5e5e5e;text-align:center;behavior:url(layer-view-script/common/PIE/PIE.htc)}
.tooltip-info2{z-index:1;display:none;position:absolute;padding:4px 6px 3px 7px;background-color:#ffffff;border-style:solid;border-color:#919191;border-width:1px;border-radius:4px;box-shadow:0 0 .25em #cccccc;font-size:11px;color:#5e5e5e;text-align:left;behavior:url(layer-view-script/common/PIE/PIE.htc)}
.tooltip-info-arrow-img{display:none;position:absolute;width:15px;height:8px;background:url(../../layer-view-image/common/img_flecha.png) no-repeat;z-index:2;behavior:url(layer-view-script/common/PIE/PIE.htc)}
.ajax-loader{background-color:transparent;background-image:url(../../layer-view-image/common/ajax-loader.gif);background-position:50%;background-repeat:no-repeat;display:none;height:16px;left:50%;margin:0 0 0 -8px;position:absolute;top:110px;width:16px}
.btn-verificar{background-image:url(../../layer-view-image/common/img-micuenta.png);background-position:2px -299px;background-repeat:no-repeat;cursor:pointer;height:19px;left:453px;position:absolute;width:74px;top:0 !important}
.btn-verificar:hover{background-position:2px -321px}
*{outline:none}
#content-tab-item_1 fieldset{float:left}
#content-tab-item_1 fieldset.account-data-field{width:240px}
#content-tab-item_1 fieldset.personal-data-field{padding:0 0 0 10px;width:300px}
#content-tab-item_1 fieldset.other-fields label{vertical-align:middle}
#content-tab-item_1 label,
#content-tab-item_1 .question-mark{color:#666666;font-size:11px;font-weight:bold;line-height:11px}
#content-tab-item_1 .question-mark{cursor:pointer;margin:0 4px 0 0}
#content-tab-item_1 table{width:100%}
#content-tab-item_1 table td{font-size:0;padding:0;white-space-collapse:discard}
#content-tab-item_1 table .clabel{width:64px}
#content-tab-item_1 table .aloft{vertical-align:top!important}
#content-tab-item_1 table .cinputs .gread-box{width:98px}
#content-tab-item_1 table .cinputs .gread-box td{height:18px}
#frm-update-client input{font-size:12px;margin:2px 0;vertical-align:middle}
#frm-update-client .internal-label{font-weight:normal !important;margin:0 10px 0 5px;text-transform:capitalize;vertical-align:middle}
#frm-update-client .small{width:106px}
#frm-update-client .medium{width:106px}
.select{display:none}
.max{width:99.5%}
.min{width:106px}
.movil{position:absolute;display:block;margin-top:-4px;/*-24px*/}
#cinputs{padding-top:3px !important}
.option-list{background-color:#f4f9ff;border:1px solid #b9dbff;border-radius:0 0 5px 5px;box-shadow:1px 2px 5px 0 #c4c4c4;display:none;font-size:12px;left:0;list-style:none outside none;margin:0;max-height:200px;overflow-x:hidden;overflow-y:auto;padding:0;position:absolute;top:28px;width:195px;z-index:10}
.option-list.open{display:block}
.option-list .option-item{cursor:default;padding:1px 20px 1px 5px;white-space:nowrap}
.option-list .option-item:hover{background-color:#b9dbff}
.option-list .option-item.on{background-color:#a8d7ff}
.text-out{color:#818181;display:block;float:left;font-size:12px;font-weight:bold;line-height:16px;min-height:16px;min-width:30px;padding:6px 5px;vertical-align:middle}
.custom-select{cursor:default;font-size:12px;margin:2px 2% 2px 0;padding-right:20px!important;position:relative}
.custom-select:after{background:transparent;border-color:#000000 transparent transparent transparent;border-style:solid;border-width:4px;content:'';height:0;position:absolute;top:12px;right:6px;width:0}
.custom-select:focus{border:1px solid red}
.text-in,
.custom-select{background-color:#f4f9ff;border:1px solid #b9dbff;box-sizing:border-box;border-radius:5px;display:block;float:left;line-height:16px;min-height:16px;min-width:30px;padding:6px 5px;vertical-align:middle;transition:all .3s ease}
.text-in:hover, .custom-select:hover{border:1px solid #abcff4}
.text-in:focus, .custom-select:focus{border:1px solid #89d4ff;box-shadow:0 0 5px 0 rgba(0, 0, 0, .2) inset, 0 0 5px 0 #ffffff}
.text-in{width:180px}
.text-in.max{display:block;margin:0 0 10px 0;width:100%}
.icon{background-repeat:no-repeat;display:inline-block;font-size:0 !important}
.icon.lucky{background-image:url(../../layer-view-image/client/lucky.png);margin:0 0 0 5px;vertical-align:middle}
.icon.lucky.clover{background-position:0 -5px;height:19px;width:18px}
.icon.lucky.rabbits-foot{background-position:-2px -25px;height:24px;width:22px}
.icon.lucky.horse{background-position:-2px -53px;height:22px;width:30px}
.icon.lucky.horseshoe{background-position:-2px -80px;height:20px;width:20px}
.icon.lucky.soccer-ball{background-position:-7px -103px;height:20px;width:20px}
.icon.lucky.pink-elephant{background-position:-1px -124px;height:23px;width:27px}
#btn-save-changes{background-color:#ffffff;background-image:url(../../layer-view-image/client/btn-save-changes.png);background-position:center top;background-repeat:no-repeat;border:0;font-size:0;font-weight:bold;height:24px;padding:0;position:absolute;top:4px;right:36px;width:112px}
#btn-save-changes:hover{background-position:center bottom}
#btn-edit{background-color:transparent;background-image:url(../../layer-view-image/common/btn-editar.png);background-position:center top;background-repeat:no-repeat;border:0;font-size:0;font-weight:bold;height:24px;padding:0;position:absolute;top:5px;right:36px;width:54px;}
#btn-edit:hover{background-position:center bottom;}
#btn-activate{background-color:transparent;background-image:url(../../layer-view-image/common/btn-activar.png);background-position:center top;background-repeat:no-repeat;border:0;display:none;font-size:0;font-weight:bold;height:24px;padding:0;position:absolute;top:5px;right:100px;width:64px;}
#btn-activate:hover{background-position:center bottom;}
#txt-activate{font-weight:bold;color:#F60 !important;font-size:13px;margin-top:10px;margin-left:210px;}
