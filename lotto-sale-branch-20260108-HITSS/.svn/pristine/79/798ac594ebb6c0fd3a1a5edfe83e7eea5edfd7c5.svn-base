;
var $ie = function () {
    var a = $('#game-list');
    var b = a.find('.body-list .content-options');
    var c = $('#exact-maker');
    a.find('.body-list .row:nth-child(odd)').css('background-color', '#ffffff');
    a.find('.body-list .row:nth-child(even)').css('background-color', '#eeeeee');
    b.find('.row:nth-child(even) .cell.op:nth-child(6n+1)').css('background-color', '#dadada');
    b.find('.row:nth-child(even) .cell.op:nth-child(6n+2)').css('background-color', '#dadada');
    b.find('.row:nth-child(even) .cell.op:nth-child(6n+3)').css('background-color', '#dadada');
    b.find('.row:nth-child(even) .cell.op:nth-last-child(3)').css('background-color', '#eeeeee');
    b.find('.row:nth-child(odd) .cell.op:nth-child(6n+1)').css('background-color', '#e9e9e9');
    b.find('.row:nth-child(odd) .cell.op:nth-child(6n+2)').css('background-color', '#e9e9e9');
    b.find('.row:nth-child(odd) .cell.op:nth-child(6n+3)').css('background-color', '#e9e9e9');
    b.find('.row:nth-child(odd) .cell.op:nth-last-child(3)').css('background-color', '#ffffff');
    c.find('.game-maker .header-list .row .cell.op:nth-child(odd)').css('font-weight', 'normal');
    c.find('.game-maker .body-list .row:nth-child(odd)').css('background-color', '#ffffff');
    c.find('.game-maker .body-list .row:nth-child(even)').css('background-color', '#eeeeee');
    c.find('.game-maker .body-list .row:nth-child(odd) .cell:odd').css('background-color', '#e9e9e9');
    c.find('.game-maker .body-list .row:nth-child(even) .cell:odd').css('background-color', '#dadada');
    $('#content').roundOff('bottom 10px');
    $('#nav-bar').roundOff('top 10px');
    $('.top-panel').roundOff('top 10px');
    $('.bottom-bar').roundOff('10px');
    $('.bottom-panel').roundOff('bottom 10px');
    $('#game-list .head-list .header-events .row:last-child').roundOff('top 7px')
};
$($ie)