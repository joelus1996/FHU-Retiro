.body{
	font-family: Arial;
    font-size: 12px;
	padding: 34px 24px 24px 24px;
}
.iframe-reclama {
    background-attachment: scroll;
    background-clip: border-box;
    background-color: transparent;
    background-image: none;
    background-origin: padding-box;
    background-position: 0 0;
    background-repeat: repeat;
    background-size: auto auto;
}
.iframe-reclama .content {
    background-attachment: scroll;
    background-clip: border-box;
    background-color: transparent;
    background-image: none;
    background-origin: padding-box;
    background-position: 0 0;
    background-repeat: repeat;
    background-size: auto auto;
}
.iframe-reclama .content .text {
    color: #5F5E5E;
    text-align: justify;
}
.iframe-reclama .content .text .title {
    font-size: 14px;
    font-weight: bold;
    margin-top: 0;
}
.iframe-reclama .content .text .subtitle {
    color: #F78F1E;
    font-size: 14px;
    font-weight: bold;
    margin-top: 0;
}