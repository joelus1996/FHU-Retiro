package pe.com.intralot.loto.layer.model.domain;

import java.io.Serializable;
import javax.persistence.*;
import java.math.BigDecimal;
import java.util.Date;


/**
 * The persistent class for the CLIENT_TICKET_LOTOS5_ITEM database table.
 * 
 */
@Entity
@Table(name="LOTOCARD.CLIENT_TICKET_LOTOS5_ITEM")
public class ClientTicketLotos5Item implements Serializable {
	
	private static final long serialVersionUID = 1L;
	
	@Id
	@Column(name="CTI_APUETXT")
	private String ctiApuetxt;

	@Column(name="CTI_BET")
	private String ctiBet;

	@Temporal(TemporalType.DATE)
	@Column(name="CTI_CLOSE_DATE")
	private Date ctiCloseDate;

	@Column(name="CTI_CLOSE_HOUR")
	private BigDecimal ctiCloseHour;

	@Column(name="CTI_CLOSE_MINUTE")
	private BigDecimal ctiCloseMinute;

	@Column(name="CTI_DESCRIPTION")
	private String ctiDescription;

	@Column(name="CTI_DRAW_ID")
	private BigDecimal ctiDrawId;

	@Column(name="CTI_EVENT_ID")
	private BigDecimal ctiEventId;

	@Column(name="CTI_FACTOR")
	private BigDecimal ctiFactor;

	@Column(name="CTI_HNDTXT")
	private String ctiHndtxt;

	@Column(name="CTI_LEAGUE_ID")
	private BigDecimal ctiLeagueId;

	@Column(name="CTI_MINIMUM")
	private BigDecimal ctiMinimum;

	@Column(name="CTI_RESULT")
	private String ctiResult;

	@Column(name="CTI_STATUS")
	private String ctiStatus;

	@Column(name="CTI_SUBDESCRIPTION")
	private String ctiSubdescription;

	@Column(name="CTI_TICKET_ID")
	private BigDecimal ctiTicketId;

	@Column(name="CTI_WINNER_FLAG")
	private BigDecimal ctiWinnerFlag;

	public String getCtiApuetxt() {
		return this.ctiApuetxt;
	}

	public void setCtiApuetxt(String ctiApuetxt) {
		this.ctiApuetxt = ctiApuetxt;
	}

	public String getCtiBet() {
		return this.ctiBet;
	}

	public void setCtiBet(String ctiBet) {
		this.ctiBet = ctiBet;
	}

	public Date getCtiCloseDate() {
		return this.ctiCloseDate;
	}

	public void setCtiCloseDate(Date ctiCloseDate) {
		this.ctiCloseDate = ctiCloseDate;
	}

	public BigDecimal getCtiCloseHour() {
		return this.ctiCloseHour;
	}

	public void setCtiCloseHour(BigDecimal ctiCloseHour) {
		this.ctiCloseHour = ctiCloseHour;
	}

	public BigDecimal getCtiCloseMinute() {
		return this.ctiCloseMinute;
	}

	public void setCtiCloseMinute(BigDecimal ctiCloseMinute) {
		this.ctiCloseMinute = ctiCloseMinute;
	}

	public String getCtiDescription() {
		return this.ctiDescription;
	}

	public void setCtiDescription(String ctiDescription) {
		this.ctiDescription = ctiDescription;
	}

	public BigDecimal getCtiDrawId() {
		return this.ctiDrawId;
	}

	public void setCtiDrawId(BigDecimal ctiDrawId) {
		this.ctiDrawId = ctiDrawId;
	}

	public BigDecimal getCtiEventId() {
		return this.ctiEventId;
	}

	public void setCtiEventId(BigDecimal ctiEventId) {
		this.ctiEventId = ctiEventId;
	}

	public BigDecimal getCtiFactor() {
		return this.ctiFactor;
	}

	public void setCtiFactor(BigDecimal ctiFactor) {
		this.ctiFactor = ctiFactor;
	}

	public String getCtiHndtxt() {
		return this.ctiHndtxt;
	}

	public void setCtiHndtxt(String ctiHndtxt) {
		this.ctiHndtxt = ctiHndtxt;
	}

	public BigDecimal getCtiLeagueId() {
		return this.ctiLeagueId;
	}

	public void setCtiLeagueId(BigDecimal ctiLeagueId) {
		this.ctiLeagueId = ctiLeagueId;
	}

	public BigDecimal getCtiMinimum() {
		return this.ctiMinimum;
	}

	public void setCtiMinimum(BigDecimal ctiMinimum) {
		this.ctiMinimum = ctiMinimum;
	}

	public String getCtiResult() {
		return this.ctiResult;
	}

	public void setCtiResult(String ctiResult) {
		this.ctiResult = ctiResult;
	}

	public String getCtiStatus() {
		return this.ctiStatus;
	}

	public void setCtiStatus(String ctiStatus) {
		this.ctiStatus = ctiStatus;
	}

	public String getCtiSubdescription() {
		return this.ctiSubdescription;
	}

	public void setCtiSubdescription(String ctiSubdescription) {
		this.ctiSubdescription = ctiSubdescription;
	}

	public BigDecimal getCtiTicketId() {
		return this.ctiTicketId;
	}

	public void setCtiTicketId(BigDecimal ctiTicketId) {
		this.ctiTicketId = ctiTicketId;
	}

	public BigDecimal getCtiWinnerFlag() {
		return this.ctiWinnerFlag;
	}

	public void setCtiWinnerFlag(BigDecimal ctiWinnerFlag) {
		this.ctiWinnerFlag = ctiWinnerFlag;
	}

}