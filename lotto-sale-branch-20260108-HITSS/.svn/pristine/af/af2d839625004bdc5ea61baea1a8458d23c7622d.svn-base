<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ include file="../../include/taglibs.jspf"%>
<!DOCTYPE html>
<html lang="es">
<head>
<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-PWF5XVX');</script>
<!-- End Google Tag Manager -->

    <meta charset="UTF-8">
    <script type='text/javascript' src='../../../layer-view-script/common/jquery-3.6.3.min.js'></script>
    <script type="text/javascript" src="../../../layer-view-script/common/jquery.alerts.js"></script>
    <script type="text/javascript" src="../../../layer-view-script/common/utils.js?v=<%=Constants.utils_js%>"></script>
    <link media="screen" rel="stylesheet" href="../../../layer-view-style/common/normalize.css">
    <link media="screen" rel="stylesheet" href="../../../layer-view-style/common/style.css?v=<%=Constants.common_style_css%>">
    <link rel="stylesheet" type="text/css" href="../../../layer-view-style/common/jquery.alerts.css"/>
    <link rel="stylesheet" type="text/css" href="../../../layer-view-style/game/giromagico/theme.css"/>
    <link rel="stylesheet" type="text/css" href="../../../layer-view-style/game/giromagico/themeGiromagico.css"/>
    <title>Giromagico</title>
    <link rel="shortcut icon" href="layer-view-image/common/favicon.ico?v=4">
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PWF5XVX"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<div id="background">
<div id="giromagico">
<div id="banner"></div>
<div id="transition" class="transition-one"></div>
<div id="buttons">
    <a id="roulette" href="#"></a>
    <a id="table-of-prize" href="#"></a>
    <a id="help" href="#" ></a>
</div>
<div id="content">
<div id="J1">
    <div class="text-play">JUGADA 1</div>
    <div class="dotted-border">
        <div class="banner-play"></div>
        <div id="play">
            <div id="your-bet" class="inline">
                <div id="mark">
                    <p id="info-mark">Marca una casilla o más, c/u S/.1</p>

                    <div id="button-mark">
                        <input id="ma-btn1" type="button" value="Número Exacto" class="btn-mark">
                        <input id="ma-btn2" type="button" value="Una Zona" class="btn-mark">
                        <input id="ma-btn3" type="button" value="Dos Zonas" class="btn-mark">
                        <input id="ma-btn4" type="button" value="Dígito Final" class="btn-mark">
                    </div>

                </div>
                <div id="multiplies">
                    <p id="info-multiplies">Multiplica tu premio por: (opcional)</p>

                    <div id="button-multiplies">
                        <input id="mu-btn2" type="button" value="2" class="btn-multiplies">
                        <input id="mu-btn3" type="button" value="3" class="btn-multiplies">
                        <input id="mu-btn4" type="button" value="4" class="btn-multiplies">
                        <input id="mu-btn5" type="button" value="5" class="btn-multiplies">
                        <input id="mu-btn10" type="button" value="10" class="btn-multiplies">
                        <input id="mu-btn20" type="button" value="20" class="btn-multiplies">
                        <input id="mu-btn30" type="button" value="30" class="btn-multiplies">
                        <input id="mu-btn40" type="button" value="40" class="btn-multiplies">
                        <input id="mu-btn50" type="button" value="50" class="btn-multiplies">
                    </div>
                </div>
            </div>
            <div id="bets" class="inline">
                <div id="b1">
                    <div id="text-play-b1" class="text-play-b">APUESTA 1: NÚMERO EXACTO (Marca una casilla o
                        más)
                    </div>
                    <div id="content-b1">
                        <div id="z1-b1" class="b1 group">
                            <span class="zone-text-b1">ZONA 1 (Z1)</span>

                            <div id="numbers-z1-b1" class="numbers-b1">
                                <input id="b1-btn1" type="button" value="1" class="btn">
                                <input id="b1-btn2" type="button" value="2" class="btn">
                                <input id="b1-btn3" type="button" value="3" class="btn">
                                <input id="b1-btn4" type="button" value="4" class="btn">
                                <input id="b1-btn5" type="button" value="5" class="btn">
                                <input id="b1-btn6" type="button" value="6" class="btn">
                                <input id="b1-btn7" type="button" value="7" class="btn">
                            </div>
                        </div>
                        <div id="z2-b1" class="b1 group">
                            <span class="zone-text-b1">ZONA 2 (Z2)</span>

                            <div id="numbers-z2-b1" class="numbers-b1">
                                <input id="b1-btn8" type="button" value="8" class="btn">
                                <input id="b1-btn9" type="button" value="9" class="btn">
                                <input id="b1-btn10" type="button" value="10" class="btn">
                                <input id="b1-btn11" type="button" value="11" class="btn">
                                <input id="b1-btn12" type="button" value="12" class="btn">
                                <input id="b1-btn13" type="button" value="13" class="btn">
                            </div>
                        </div>
                        <div id="z3-b1" class="b1 group">
                            <span class="zone-text-b1">ZONA 3 (Z3)</span>

                            <div id="numbers-z3-b1" class="numbers-b1">
                                <input id="b1-btn14" type="button" value="14" class="btn">
                                <input id="b1-btn15" type="button" value="15" class="btn">
                                <input id="b1-btn16" type="button" value="16" class="btn">
                                <input id="b1-btn17" type="button" value="17" class="btn">
                                <input id="b1-btn18" type="button" value="18" class="btn">
                            </div>
                        </div>
                        <div id="z4-b1" class="b1 group">
                            <span class="zone-text-b1">ZONA 4 (Z4)</span>

                            <div id="numbers-z4-b1" class="numbers-b1">
                                <input id="b1-btn19" type="button" value="19" class="btn">
                                <input id="b1-btn20" type="button" value="20" class="btn">
                                <input id="b1-btn21" type="button" value="21" class="btn">
                                <input id="b1-btn22" type="button" value="22" class="btn">
                            </div>
                        </div>
                        <div id="z5-b1" class="b1 group">
                            <span class="zone-text-b1">ZONA 5 (Z5)</span>

                            <div id="numbers-z5-b1" class="numbers-b1">
                                <input id="b1-btn23" type="button" value="23" class="btn">
                                <input id="b1-btn24" type="button" value="24" class="btn">
                            </div>
                        </div>
                    </div>
                </div>
                <div id="b2">
                    <div id="text-play-b2" class="text-play-b">APUESTA 2: UNA ZONA (Marca una casilla o
                        más)
                    </div>
                    <div id="content-b2" class="content-b">
                        <div id="zones-b2">
                            <input id="b2-btnZ1" type="button" value="Z1" class="btn">
                            <input id="b2-btnZ2" type="button" value="Z2" class="btn">
                            <input id="b2-btnZ3" type="button" value="Z3" class="btn">
                            <input id="b2-btnZ4" type="button" value="Z4" class="btn">
                            <input id="b2-btnZ5" type="button" value="Z5" class="btn">
                        </div>
                    </div>
                </div>
                <div id="b3">
                    <div id="text-play-b3" class="text-play-b">APUESTA 3: DOS ZONAS (Marca dos casillas o
                        más)
                    </div>
                    <div id="content-b3" class="content-b">
                        <div id="zones-b3">
                            <input id="b3-btnZ1" type="button" value="Z1" class="btn">
                            <input id="b3-btnZ2" type="button" value="Z2" class="btn">
                            <input id="b3-btnZ3" type="button" value="Z3" class="btn">
                            <input id="b3-btnZ4" type="button" value="Z4" class="btn">
                            <input id="b3-btnZ5" type="button" value="Z5" class="btn">
                        </div>
                    </div>
                </div>
                <div id="b4">
                    <div id="text-play-b4" class="text-play-b">APUESTA 4: DÍGITO FINAL (Marca una casilla o
                        más)
                    </div>
                    <div id="content-b4" class="content-b">
                        <div id="digit-b4">
                            <input id="b4-btn1" type="button" value="1" class="btn">
                            <input id="b4-btn2" type="button" value="2" class="btn">
                            <input id="b4-btn3" type="button" value="3" class="btn">
                            <input id="b4-btn4" type="button" value="4" class="btn">
                            <input id="b4-btn5" type="button" value="5" class="btn">
                            <input id="b4-btn6" type="button" value="6" class="btn">
                            <input id="b4-btn7" type="button" value="7" class="btn">
                            <input id="b4-btn8" type="button" value="8" class="btn">
                            <input id="b4-btn9" type="button" value="9" class="btn">
                        </div>
                    </div>
                </div>
            </div>
            <div id="your-numbers-are" class="inline">
                <div class="top-message">
                    <span class="your-numbers-are-msg">Tus n&uacute;meros son:</span>
                </div>
                <div class="attribute-area" id="numbers-area" disabled="disabled"></div>

                <div class="separate-textarea-bottuns">
                    <div class="attribute-button">
                        <div id="J1random" class="random">
                            <img src="../../../layer-view-image/game/giromagico/flecha-gm.gif" height="5" width="5" class="icon"/><span class="text">Al azar</span>
                        </div>
                    </div>
                    <div class="separate-bottun"></div>
                    <div class="attribute-button">
                        <div id="J1clear" class="clear">
                            <img src="../../../layer-view-image/game/giromagico/flecha-gm.gif" height="5" width="5" class="icon"/><span class="text">Limpiar</span>
                        </div>
                    </div>
                    <div class="separate-bottun"></div>
                    <div class="attribute-button">
                        <div id="J1more" class="more">
                            <img src="../../../layer-view-image/game/giromagico/flecha-gm.gif" height="5" width="5" class="icon"/><span class="text">M&#225;s salieron</span>
                        </div>
                    </div>
                    <div class="separate-bottun"></div>
                    <div class="attribute-button">
                        <div id="J1less" class="less">
                            <img src="../../../layer-view-image/game/giromagico/flecha-gm.gif" height="5" width="5" class="icon"/><span class="text">Menos salieron</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="consecutive-draws">
    <div id="message-draws" class="linear">Elige en cu&aacute;ntos sorteos consecutivos jugar&aacute;s:
    </div>
    <div id="abs-selectBox">
        <div class="selectBox">
            <!-- <c:forEach items="${kineloSaleList}" var="kineloDrawData" begin="0" end="0">
                 <div class="box" id="box">${kineloDrawData.messageDraw}</div>
             </c:forEach>
             <select name="model" id="mySelectBox"
                     onChange="this.parentNode.getElementsByTagName('div')[0].innerHTML=this.options[this.selectedIndex].text">
                 <c:forEach items="${kineloSaleList}" var="kineloDrawData">
                     <option value="${kineloDrawData.numDraws}">${kineloDrawData.messageDraw}</option>
                 </c:forEach>
             </select>-->
        </div>
    </div>
</div>
<div class="font">
    <div class="center">
        <div class="color-text">
            <div>
                <span id="price-message">Costo por tipo de apuesta: S/ .1</span> | Total de Apuestas:
                <span id="total_bet">0</span> | Multiplicador:
                <span id="multiplier">0</span>
            </div>
            <div class="bold-type">
                Total: S/.<span id="total_apagar">0</span> | Gana Hasta S/. <span id="earn_up">0</span>
            </div>
        </div>
        <div id="buy-panel" class="text-distance">
            <a href="#" class="button-buy" id='buy' onclick="return false;"></a>
        </div>
    </div>
</div>
<div id="div-message-discount">
    <span id="message-discount">Todos los premios estar&aacute;n afectos al 10% de dscto. por concepto impuestos y deducciones de ley municipal.</span>
</div>
</div>
</div>
</div>

</body>
</html>