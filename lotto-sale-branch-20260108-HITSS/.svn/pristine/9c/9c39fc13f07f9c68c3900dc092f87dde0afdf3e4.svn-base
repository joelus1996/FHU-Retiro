package pe.com.intralot.loto.layer.dto.img;

public class ImgDto {
	
	private byte[] contenidoImg;
	private String tipoImg;
	private String fileName;
	
	public String getFileName() {
		return fileName;
	}
	public void setFileName(String fileName) {
		this.fileName = fileName;
	}
	
	public byte[] getContenidoImg() {
		return contenidoImg;
	}
	public void setContenidoImg(byte[] contenidoImg) {
		this.contenidoImg = contenidoImg;
	}
	public String getTipoImg() {
		return tipoImg;
	}
	public void setTipoImg(String tipoImg) {
		this.tipoImg = tipoImg;
	}
	
	

}
