.text-play{
	-pie-background: linear-gradient(right , #007CB6 95%, #0E8BC9 100%, #007CB6 100%);
	background-image: -o-linear-gradient(right , #007CB6 95%, #0E8BC9 100%, #007CB6 100%);
	background-image: -moz-linear-gradient(right , #007CB6 95%, #0E8BC9 100%, #007CB6 100%);
	background-image: -webkit-gradient(linear,right top,left top,color-stop(0.95, #007CB6),color-stop(1, #0E8BC9),color-stop(1, #007CB6));
	background-image: -webkit-linear-gradient(right , #007CB6 95%, #0E8BC9 100%, #007CB6 100%);
 	background: -ms-linear-gradient(right , #007CB6 95%, #0E8BC9 100%, #007CB6 100%);
    border-radius: 5px 5px 0px 0px ;
    border-color:#007bb6;
    height: 18px; 
	width: 279px;
	text-align:center;
	font-family:Arial;
	font-size:11px;
	font-weight:bold;
	color:#FFF;
	padding: 4px 0px 0px 0px;
	margin-bottom: 5px;
	behavior:url(layer-view-script/common/PIE/PIE.htc);	
	}
