package pe.com.intralot.loto.layer.model.domain;

import java.io.Serializable;
import java.util.ArrayList;

/**
 * @author:   Felipe Rodriguez
 * @rol:	  Desarrollador
 * @proyecto: lotto-playerweb-ws-tyc-pdp
 *
 */
public class TYCPDPProcedureConsultPendingDocumentsTemplate implements Serializable{
	
	private static final long serialVersionUID = 1L;
	private String state;
	private String status;
	private String error; 
	private String message;
	private String resp_title;
	private String resp_message;
	private String resp_button;
	private ArrayList<TYCPDPProcedureConsultPendingDocuments> documents;
	
	public String getState() {
		return state;
	}
	public void setState(String state) {
		this.state = state;
	}
	public String getStatus() {
		return status;
	}
	public void setStatus(String status) {
		this.status = status;
	}
	public String getError() {
		return error;
	}
	public void setError(String error) {
		this.error = error;
	}
	public String getMessage() {
		return message;
	}
	public void setMessage(String message) {
		this.message = message;
	}
	public String getResp_title() {
		return resp_title;
	}
	public void setResp_title(String resp_title) {
		this.resp_title = resp_title;
	}
	public String getResp_message() {
		return resp_message;
	}
	public void setResp_message(String resp_message) {
		this.resp_message = resp_message;
	}
	public String getResp_button() {
		return resp_button;
	}
	public void setResp_button(String resp_button) {
		this.resp_button = resp_button;
	}
	public ArrayList<TYCPDPProcedureConsultPendingDocuments> getDocuments() {
		return documents;
	}
	public void setDocuments(ArrayList<TYCPDPProcedureConsultPendingDocuments> documents) {
		this.documents = documents;
	}

}
