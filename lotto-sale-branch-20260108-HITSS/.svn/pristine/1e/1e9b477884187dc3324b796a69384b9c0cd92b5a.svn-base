#fechaza {
	float: left;
	margin-left: 33px;
	margin-top: 8px;
	width: 614px
}

.separate-bottun {
	padding: 1px;
}

.attribute-textarea {
	background: #FFF;
	border: 1px solid #e1e1e1;
	border-radius: 10px;
	resize: none;
	overflow: hidden;
	height: 36px;
	padding: 7px;
	width: 85px;
	font-size: 10px;
	font-family: Arial;
	color: #818181;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

.attribute-button {
	background-color: #E5DEEE;
	border: 1px solid #E5DEEE;
	height: 15px;
	width: 97px;
	cursor: pointer
}

.attribute-button:hover {
	background: #C9A5F7;
	border: 1px solid #C9A5F7;
	height: 15px;
	width: 97px;
	cursor: pointer
}

.linear {
	float: left
}

.choose-number-top {
	margin-left: 15px;
	height: 185px;
	width: 335px
}

.day-area {
	width: 202px;
	float: left
}

.month-area {
	float: left;
	margin-left: 12px;
	width: 90px
}

.year-area {
	margin-left: 15px;
	height: 93px;
	width: 304px
}

.title-number {
	background-color: #9873A6;
	height: 20px;
	float: left;
	font-weight: bold;
	font-family: Arial;
	color: white;
	padding-left: 5px;
	font-size: 11px;
}

.title-number2 {
	background-color: #d5c7db
}

.separate-textarea-bottuns {
	padding: 145px 0px 0px 0px
}

.separate-textarea-number {
	float: left;
	height: auto;
	width: auto
}

.icon {
	padding: 4px 6px 5px 5px
}

.height-div {
	height: 59px;
	padding: 7px 0 0;
	width: 110px
}

.text-play {
	-pie-background: linear-gradient(right, #F93711 95%, #ED360E 100%, #007CB6 100%);
	background-image: -o-linear-gradient(right, #F93711 95%, #ED360E 100%, #007CB6 100%);
	background-image: -moz-linear-gradient(right, #F93711 95%, #ED360E 100%, #007CB6 100%);
	background-image: -webkit-gradient(linear, right top, left top, color-stop(0.95, #007CB6), color-stop(1, #0E8BC9), color-stop(1, #007CB6));
	background-image: -webkit-linear-gradient(right, #F93711 95%, #ED360E 100%, #007CB6 100%);
	background: -ms-linear-gradient(right, #F93711 95%, #ED360E 100%, #007CB6 100%);
	border-radius: 5px 5px 0px 0px;
	border-color: #007bb6;
	height: 18px;
	width: 598px;
	text-align: center;
	font-family: Arial;
	font-size: 11px;
	font-weight: bold;
	color: #FFF;
	padding: 4px 0px 0px 0px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

.play-content {
	padding: 5px 0px 0px 0px;
	border-top: 0px;
	border-left: 2px;
	border-right: 2px;
	border-bottom: 2px;
	border-style: dotted;
	border-color: #e0e0e0;
	width: 594px;
	height: 324px;
	padding-top: 0px
}

.choose-top {
	background: #FFF url(../../../layer-view-image/game/fechaza/pasos-seleccion.jpg) no-repeat;
	float: left;
	width: 594px;
	height: 36px;
}

.choose-apuesta {
	float: left;
	width: 139px;
	height: 270px;
	background: #FFF url(../../../layer-view-image/game/fechaza/px-background.gif) repeat-x;
	margin-left: 3px;
	margin-top: 2px;
	position: relative;
	z-index: 0;
}

.choose-numeros {
	float: left;
	width: 450px;
	height: 269px;
}

.choose-numeros-left {
	float: left;
	height: 284px;
	width: 335px;
}

.botton-con {
	width: 90px;
	padding-left: 22px;
	padding-top: 5px;
}

.margin {
	height: 25px;
	padding-left: 5px;
}

.text-number {
	color: #818181;
	font-family: arial;
	font-size: 10px;
	padding-left: 7px;
}

.text-number2 {
	color: #cdcdcd;
}

.text-number-marcado {
	color: #818181;
	font-family: arial;
	font-size: 11px;
	font-weight: bold;
}

.container {
	padding: 5px 0 0;
	float: left;
}

.check_ {
	margin-left: 0;
	margin-right: -1px;
}

.text {
	color: #9574ad;
	font-size: 10px;
	font-weight: bold;
	vertical-align: top
}

.left {
	float: left
}

.right {
	padding-left: 287px
}

.flecha_next {
	background-image: url(../../../layer-view-image/game/fechaza/CORTES/jugada_sig_kb.gif);
	background-repeat: no-repeat;
	background-position: 0px 0px;
	height: 22px;
	width: 25px;
	cursor: pointer;
}

.right_flecha {
	padding: 0px 571px 102px
}

.flecha-next-on {
	background-image: url(../../../layer-view-image/game/fechaza/CORTES/jugada_sig_kb.gif);
	background-repeat: no-repeat;
	background-position: 0px -28px;
	height: 22px;
	width: 25px;
	cursor: pointer;
}

.color-text {
	float: left;
	font-size: 11px;
	font-family: arial;
	color: #000000;
	width: 420px;
}

.bold-type {
	font-weight: bold;
}

.center {
	padding: 13px 15px;
}

.font {
	background: none repeat scroll 0% 0% rgb(217, 217, 217);
	width: 595px;
	height: 56px;
	position: absolute;
	top: 410px;
	border-radius: 6px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

.font-play {
	position: relative;
	padding-left: 7px;
	background: #FFF;
	padding-top: 18px;
	width: 604px;
	height: 497px; /*390px;*/
	margin-top: 5px;
	/*z-index: 1;*/
	border-radius: 0px 6px 6px 6px;
	/*behavior: url(layer-view-script/common/PIE/PIE.htc);*/
}

.font-play-total {
	/*background:#FFF;*/
	/*width: 615px; height: 435px;*/
	
}

/*******/
/*imagen de paso*/
.transition-one {
	background: #FFF url(../../../layer-view-image/game/fechaza/transition-one.png) no-repeat 7px;
	background-position: 10px 4px;
	width: 320px;
	height: 23px;
	border-radius: 5px 5px 0px 0px;
	padding-right: 7px;
	padding-top: 5px;
	margin-top: 5px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

.transition-two {
	background: #FFF url(../../../layer-view-image/game/fechaza/transition-two.png) no-repeat 7px;
	width: 320px;
	height: 23px;
	border-radius: 5px 5px 0px 0px;
	padding-right: 7px;
	padding-top: 5px;
	margin-top: 5px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

/****/
/*style de combobox*/
div.selectBox {
	position: relative;
	width: 161px;
	height: 18px;
	border: 1px solid #949494;
	background: #e4e4e2 url(../../../layer-view-image/common/flecha-combo.png) no-repeat 147px 8px;
	border-radius: 5px;
	font-family: Arial;
	font-size: 10px;
	top: -2px;
	behavior: url(layer-view-script/common/PIE/PIE.htc);
}

div.selectBox div.box {
	position: absolute;
	left: 6px;
	top: 1px;
	width: 154px;
	height: 18px;
	line-height: 17px;
	font-family: arial;
	font-size: 10px;
	color: #4e4e4d;
	overflow: hidden;
}

div.selectBox select {
	background: #e4e4e2;
	width: 160px;
	height: 18px;
	font-size: 10px;
	border: 1px solid #949494;
	opacity: 0;
	filter: alpha(Opacity =       0);
	-moz-opacity: 0;
	cursor: pointer;
	font-size: 10px;
	z-index: 1;
}

div.selectBox select option {
	font-size: 10px;
	color: #4e4e4d;
	border-bottom: 1px solid #e4e4e2;
	cursor: pointer;
}

div.selectBox select option.ultimo {
	border-bottom: 0px none;
}

#help {
	background: url(../../../layer-view-image/common/ayuda.png);
	background-position: 0 0;
	cursor: pointer;
	height: 30px;
	margin-left: 550px;
	margin-top: -35px;
	width: 60px;
	display: block;
}

#help:hover {
	background-position: 0 -36px;
}

#premio {
