}

#table-of-prize {
	background-color: #D9D9D9;
    background-image: url("http://localhost:8080/lotto-sale/layer-view-style/game/fechaza/../../../layer-view-image/game/fechaza/btn-ver-tabla-premios.png");
    background-position: 0 0;
    background-repeat: no-repeat;
    border-radius: 6px 6px 6px 6px;
    cursor: pointer;
    display: block;
    height: 26px;
    left: 473px;
    position: relative;
    top: -5px;
    width: 58px;
}

#table-of-prize:hover {
