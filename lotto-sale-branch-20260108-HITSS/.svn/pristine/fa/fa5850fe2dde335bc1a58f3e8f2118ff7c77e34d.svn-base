#grid_ganagol { font-family: Arial; width: 383px }
.head_0 { height: 12px; width: 566px }
#program { color: #236914; float: left; font-family: arial; font-size: 11px; font-weight: bold; position: absolute; top: 12px; margin-left: 10px; top: 13px }
#allocations { color: #236914; float: left; font-family: arial; font-size: 10px; font-weight: bold; left: 87px; margin-left: 220px; position: absolute; top: 16px; cursor: pointer; text-decoration: underline }
#marca { float: left; background-image: url(../../../layer-view-image/game/ganagol/img-marca-tu-apuesta.png); background-repeat: no-repeat; width: 176px; height: 32px; position: absolute; top: 0; left: 396px }
.head { position: relative; height: 19px; width: 383px; background-color: #4c8d3c; font-size: 11px; color: #ffffff; font-weight: bold; background: -moz-linear-gradient(top, #5e9e4e 0%, #377a27 100%); background: -webkit-gradient(linear, 0% 0%, 0% 100%, from(#5e9e4e), to(#377a27)); background: -webkit-linear-gradient(top, #5e9e4e 0%, #377a27 100%); background: -o-linear-gradient(top, #5e9e4e 0%, #377a27 100%); background: -ms-linear-gradient(top, #5e9e4e 0%, #377a27 100%); filter: progid:DXImageTransform.Microsoft.gradient(startColorstr='#5e9e4e', endColorstr='#377a27', gradientType='0') }
.head div { line-height: 11px }
#grid_ganagol .head_title_1 { position: absolute; left: 0; top: 4px; text-align: center; width: 20px }
#grid_ganagol .head_title_2 { position: absolute; left: 20px; top: 4px; text-align: right; width: 110px }
#grid_ganagol .head_title_3 { position: absolute; left: 210px; top: 4px }
#grid_ganagol .head_title_4 { position: absolute; left: 160px; top: 4px; text-align: center; width: 30px }
#grid_ganagol .head_title_5 { position: absolute; left: 190px; top: 4px; text-align: left; width: 110px }
#grid_ganagol .head_title_6 { position: absolute; left: 300px; top: 4px; text-align: center; width: 50px }
#grid_ganagol .head_title_7 { position: absolute; left: 350px; top: 4px; text-align: center; width: 33px }
.body { }
.row1, .row2 { border-bottom: 1px solid #b2cdab; color: #000000; font-size: 11px; height: 19px; line-height: 11px; position: relative; width: 383px }
.row1 { background-color: #ceddd1; -pie-background: linear-gradient(top, #e1e9e2 0%, #bcd1c0 100%); background: -moz-linear-gradient(top, #e1e9e2 0%, #bcd1c0 100%); background: -webkit-gradient(linear, 0% 0%, 0% 100%, from(#e1e9e2), to(#bcd1c0)); background: -webkit-linear-gradient(top, #e1e9e2 0%, #bcd1c0 100%); background: -o-linear-gradient(top, #e1e9e2 0%, #bcd1c0 100%); background: -ms-linear-gradient(top, #e1e9e2 0%, #bcd1c0 100%) }
.row2 { background-color: #f2eeee; background: -moz-linear-gradient(top, #ffffff 0%, #e2d9d9 100%); background: -webkit-gradient(linear, 0% 0%, 0% 100%, from(#ffffff), to(#e2d9d9)); background: -webkit-linear-gradient(top, #ffffff 0%, #e2d9d9 100%); background: -o-linear-gradient(top, #ffffff 0%, #e2d9d9 100%); background: -ms-linear-gradient(top, #ffffff 0%, #e2d9d9 100%); filter: progid:DXImageTransform.Microsoft.gradient(startColorstr='#ffffff', endColorstr='#e2d9d9', gradientType='0') }
.col1 { position: absolute; left: 0; top: 4px; text-align: center; width: 20px }
.col2 { position: absolute; left: 20px; top: 4px; text-align: right; width: 110px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap }
.col3 { background-image: url(../../../layer-view-image/game/ganagol/shields.png); background-position: no-repeat; height: 26.73076923076923px; left: 135px; position: absolute; text-align: center; top: -4px; width: 26.73076923076923px }
.col4 { background-image: url(../../../layer-view-image/game/ganagol/shields.png); background-position: no-repeat; height: 26.73076923076923px; left: 163px; position: absolute; text-align: center; top: -4px; width: 26.73076923076923px }
.col5 { position: absolute; left: 190px; top: 4px; text-align: left; width: 110px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap }
.col6 { font-size: 10px; left: 300px; line-height: 20px; position: absolute; text-align: center; width: 50px }
.col7 { position: absolute; left: 350px; top: 4px; text-align: center; width: 33px }
.separate-bottun { padding: 1px }
.attribute-texarea { background: #ffffff; border: 1px solid #e1e1e1; border-radius: 10px; resize: none; overflow: hidden; height: 121px; padding: 7px; width: 71px; font-size: 10px; font-family: Arial; color: #818181 }
.attribute-button { background: #e1e9e2; margin: 0 0 1px 0; height: 15px; width: 89px; cursor: pointer }
