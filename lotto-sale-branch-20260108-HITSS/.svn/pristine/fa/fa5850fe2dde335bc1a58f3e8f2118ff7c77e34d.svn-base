.font-play { background-color: #ffffff; border-radius: 0 6px 6px 6px; margin-top: 4px; min-height: 426px; padding: 18px 0 10px 10px; width: 605px; /*z-index: 1; behavior: url(layer-view-script/common/PIE/PIE.htc)*/ }
div.BotonCotejo { position: relative; width: 48px; height: 18px; border: 1px solid #949494; background: #e4e4e2 no-repeat 35px 8px; border-radius: 5px; font-family: Arial; font-size: 10px; top: -2px; behavior: url(layer-view-script/common/PIE/PIE.htc) }
.align-clear-btn { margin-top: 91px }
.align-title-cotejador { margin-top: 17px; position: absolute }
.align-fecha-cotejador { margin-left: 314px }
