.ganagol { background: url(../../../layer-view-image/game/ganagol/banner_ganagol.png) no-repeat top left; border-radius: 0 0 6px 6px; float: left; margin-left: 32px; width: 614px; behavior: url(layer-view-script/common/PIE/PIE.htc) }
.color-text { float: left; font-size: 11px; font-family: arial; color: #000000; width: 420px }
