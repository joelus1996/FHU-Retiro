.WebContentContainer .WebContentInformation { padding:0!important }
.HomeNavigationMenu { float:left }
.HomeNavigationMenu div#menu-content { background-color:#f00;background:transparent }
.HomeNavigationMenu div#menu-content div#main-nav { padding:0;overflow:hidden }
.HomeNavigationMenu div#menu-content div#main-nav a { text-decoration:none; padding:5px 0 1px }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list { line-height:12px;margin-top:23px;margin-bottom:0;margin-left:32px;padding:0;overflow:hidden }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item { list-style:none;display:block;float:left;margin-right:2px }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item a { text-decoration:none;display:block;cursor:pointer;padding:5px 0 5px 0;text-align:center;text-transform:uppercase;color:#333335;font-family:Arial;font-size:10px;background:url(../../layer-view-image/common/bg_off.png) top left no-repeat #bfbfc0 }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item a img { margin:3px 5px 0 0;padding:0;float:right;background:transparent;border:0 }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item:hover a { background:url(../../layer-view-image/common/bg_over.gif) top left no-repeat #4d4d4d;color:#fff }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item:hover ul.subnav-list { display:block;position:absolute;z-index:50;width:inherit }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item ul.subnav-list { margin:0;padding:0;display:none }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item ul.subnav-list li.subnav-list-item { list-style:none }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item ul.subnav-list li.subnav-list-item a { text-decoration:none;background:#4d4d4d;color:#fff }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.main-nav-list-item ul.subnav-list li.subnav-list-item:hover a { background:#777777 }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.current-menu-item a,
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li.current-menu-item:hover a { background:url(../../layer-view-image/common/bg_on.gif) top left no-repeat #f7901f;color:#fff }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-1,
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-1 a { width:107px }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-2,
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-2 a { width:92px }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-3,
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-3 a { width:100px }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-4,
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-4 a { width:92px }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-5,
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-5 a { width:90px }
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-6,
.HomeNavigationMenu div#menu-content div#main-nav ul.main-nav-list li#menu-item-6 a { width:90px }
.HomeNavigationMenu li#border-inf-menu-item-2 { background:url(../../img/home/basemenu_loterias.png) top left no-repeat }
.HomeNavigationMenu li#border-int-menu-item-2 { background:url(../../img/home/px_sep_loterias.gif) top left no-repeat #4d4d4d }
.HomeNavigationMenu li#border-inf-menu-item-3 { background:url(../../img/home/basemenu_apuestasdepor.png) top left no-repeat }
.HomeNavigationMenu li#border-int-menu-item-3 { background:url(../../img/home/px_sep_apuestas.gif) top left no-repeat #4d4d4d }
.HomeNavigationMenu li#border-inf-menu-item-4 { background:url(../../img/home/basemenu_raspa.png) top left no-repeat }
.HomeNavigationMenu li#border-int-menu-item-4 { background:url(../../img/home/px_sep_raspa.gif) top left no-repeat #4d4d4d }
.HomeNavigationMenu li#border-inf-menu-item-5 { background:url(../../img/home/basemenu_juegoenlinea.png) top left no-repeat }
.HomeNavigationMenu li#border-int-menu-item-5 { background:url(../../img/home/px_sep_juegosenlinea.gif) top left no-repeat #4d4d4d }
.HomeNavigationMenu li#border-inf-menu-item-6 { background:url(../../img/home/basemenu_juegoenlinea.png) top left no-repeat }
.HomeNavigationMenu li#border-int-menu-item-6 { background:url(../../img/home/px_sep_juegosenlinea.gif) top left no-repeat #4d4d4d }
.HomeNavigationMenu li.border-int-menu-item { height:1px;display:block }
.HomeNavigationMenu li.border-inf-menu-item { height:12px;display:block }
.insuranceGame { float:right;margin:0;padding:0;border:0;background:url(../../img/home/ic_18.gif) no-repeat center center;width:43px;height:40px }
.main-nav-list li { padding-bottom:0px;padding-top:0px }
