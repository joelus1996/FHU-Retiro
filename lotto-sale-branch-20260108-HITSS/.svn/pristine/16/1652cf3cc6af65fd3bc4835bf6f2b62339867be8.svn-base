.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-03 .ganadiario-html-print-instruction-compare textarea,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-04 .ganadiario-html-print-instruction-compare textarea {			
	display: block;
	float: left;
	width: 158px;
	height: 40px;
	padding: 0;
	border: 0;
	background: #FFFFFF;
	font-family: Arial;
	font-size: 10px;
	font-weight: normal;
	text-align: justify;
	color: #454545;
	overflow: auto;
}
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-01 .ganadiario-html-print-number-compare textarea,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-02 .ganadiario-html-print-number-compare textarea,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-03 .ganadiario-html-print-number-compare textarea,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-04 .ganadiario-html-print-number-compare textarea {			
