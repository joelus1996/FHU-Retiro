body {
	line-height: 1;
	/*background:url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-pxbg.gif) repeat-x;*/
	  background:url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-pxbg.gif) repeat-x;
	
}
.content-box-body {
	display: block;
	padding: 0;
	margin: 0;
	border: 0;
}
.grid-header {
	float: left;
	width: 725px;
	height: 34px;
	padding: 0;
	margin: 0;
	border: 0;
	background: #FFED00;
}
.grid-header .ganadiario-html-logo { 	
	display: inline;
	float: left; 
	background-image: url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-tit.gif); 	
    background-repeat: no-repeat;
	width: 287px;
	height: 34px;
}
.grid-footer {
	float: left;
	width: 697px;
	height: 30px;
	padding: 0;
	margin: 0;
	border: 0;
	background: #FFED00;
}
.grid-footer a.link-text-compare {
	float: left;
	display: inline;
	width: 108px;
	height: 21px;
	padding: 3px 0px 3px 0px;
	border: 0;
	background: url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-button-cotejar.gif) no-repeat top left;
	font-family: Arial, Helvetica, sans-serif;
	font-size: 11px;
	font-weight: normal; 
	text-align: center;
	text-decoration: none;
	color: #7D7D7D;
}
.grid-footer a.link-text-back {
	float: left;
	display: inline;
	width: 108px;
	height: 21px;
	padding: 3px 0px 3px 0px;
	border: 0;
	background: url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-button-regresar.gif) no-repeat top left;
	font-family: Arial, Helvetica, sans-serif;
	font-size: 11px;
	font-weight: normal; 
	text-align: center;
	text-decoration: none;
	color: #7D7D7D;
}
.grid-footer a.link-text-print {
	float: left;
	display: inline;
	width: 108px;
	height: 21px;
	padding: 3px 0px 3px 0px;
	border: 0;
	background: url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-button-imprimir.gif) no-repeat top left;
	font-family: Arial, Helvetica, sans-serif;
	font-size: 11px;
	font-weight: normal; 
	text-align: center;
	text-decoration: none;
	color: #7D7D7D;
}
/*Inicio de Estilos de Apuestas */
.spacer-content {
	display: block;
	clear: both;
	height: 1px;
	padding: 0;
	margin: 0;
	border: 0;
}
.grid-criterion {
	float: left;
	width: 697px;
	height: 30px;
	padding: 0;
	margin: 0;
	border: 0;
	background: #CEEDFB;
}
