	height: 21px;
	border: 0;
	background-image: url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-button-deactive.gif);
	background-repeat: no-repeat;
	text-decoration: none;
	padding-top: 0px;
	font-family: Arial;
	font-size: 11px;
	font-weight: bold;
	text-align: center;
	color: #0091D7;
	overflow: auto;
}
.ganadiario-html-unique-number-active-compare .ganadiario-html-button-number-compare {
	display: block;
	float: left;
	width: 21px;
	height: 21px;
	border: 0;
	background-image: url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-button-active.gif);
	background-repeat: no-repeat;
	text-decoration: none;
	padding-top: 2px;
	font-family: Arial;
	font-size: 11px;
	font-weight: bold;
	text-align: center;
	color: #FFFFFF;
}
.ganadiario-html-unique-number-deactive-compare .ganadiario-html-button-number-compare {
	display: block;
	float: left;
	width: 21px;
	height: 21px;
	border: 0;
	background-image: url(../../../../layer-view-image/game/ganadiario/compare/ganadiario-button-deactive.gif);
	background-repeat: no-repeat;
	text-decoration: none;				
	padding-top: 2px;
	font-family: Arial;
	font-size: 11px;
	font-weight: bold;
	text-align: center;
	color: #0091D7;
}
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-01 .ganadiario-html-unique-option-clean-compare .ganadiario-html-button-option-clean-compare,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-02 .ganadiario-html-unique-option-clean-compare .ganadiario-html-button-option-clean-compare,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-03 .ganadiario-html-unique-option-clean-compare .ganadiario-html-button-option-clean-compare,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-04 .ganadiario-html-unique-option-clean-compare .ganadiario-html-button-option-clean-compare { 
	display: block;
