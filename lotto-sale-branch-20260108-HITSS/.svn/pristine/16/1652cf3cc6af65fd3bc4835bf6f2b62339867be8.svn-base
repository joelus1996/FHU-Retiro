	float: left;
	width: 40px;
	height: 12px;
	background: #CEEDFB;
	padding: 0;
	margin: 0;
	border: 0;
}
.grid-cell-input input {
	float: left;
	display: inline;
	width: 38px;
	height: 18px;
	padding: 0;
	margin: 0;
	border: 0;
	background: #FFFFFF;
	font-family: Arial, Helvetica, sans-serif;
	font-size: 11px;
	font-weight: normal;
	text-align: right;
	color: #454545;
}
.type-select-01 { 
	border:1px solid #9F9F9F;
	background-color:#FFFFFF;
	color:#000000; 
	font-family: Arial, Helvetica, sans-serif; 
	font-size:11px;
	width:40px;
}
.type-select-02 { 
	border:1px solid #9F9F9F;
	background-color:#FFFFFF;
	color:#000000; 
	font-family: Arial, Helvetica, sans-serif; 
	font-size:11px;
	width:130px;
}
