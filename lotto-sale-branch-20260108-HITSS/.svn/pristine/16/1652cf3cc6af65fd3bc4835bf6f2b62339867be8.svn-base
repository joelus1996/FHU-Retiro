	float: left;
	width: 158px;
	height: 28px;
	padding: 0;
	border: 0;
	background: #FFFFFF;
	font-family: Arial;
	font-size: 10px;
	font-weight: normal;
	text-align: left;
	color: #454545;
	overflow: auto;	
}
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-01 .ganadiario-html-unique-number-compare .ganadiario-html-button-number-compare,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-02 .ganadiario-html-unique-number-compare .ganadiario-html-button-number-compare,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-03 .ganadiario-html-unique-number-compare .ganadiario-html-button-number-compare,
.ganadiario-html-jugada-element-compare .ganadiario-html-body-smallcard-compare-04 .ganadiario-html-unique-number-compare .ganadiario-html-button-number-compare { 
	display: block;
	float: left;
