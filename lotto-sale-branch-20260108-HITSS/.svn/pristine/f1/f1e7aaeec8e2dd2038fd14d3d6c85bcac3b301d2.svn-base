.elige {
	color:#605e5f;
	background-color:#ece8ec;
	font-size:11px;
	width: 595px;	
	height:50px;
	border-radius:8px;
	position:relative;
	behavior:url(layer-view-script/common/PIE/PIE.htc)
}
.hide { z-index: -100 }
.show { z-index:1 }
.contenido{
	-pie-background: linear-gradient(top,  #fff 0%, #ece8ec 100%);
    background: -moz-linear-gradient(top,  #fff 0%, #ece8ec 100%);
	background: -webkit-gradient(linear, 0% 0%, 0% 100%, from(#fff), to(#ece8ec));
	background: -webkit-linear-gradient(top,  #fff 0%, #ece8ec 100%);
	background: -o-linear-gradient(top,  #fff 0%, #ece8ec 100%);
	background: -ms-linear-gradient(top,  #fff 0%, #ece8ec 100%);
	border-radius:8px;
	margin-top:10px;
	width: 590px;	
	height: 310px;
	color:#605e5f;
	behavior:url(layer-view-script/common/PIE/PIE.htc);
	border: 3px solid  #f0e3f1
}

.imgs{
	border-radius:7px;
	behavior:url(layer-view-script/common/PIE/PIE.htc);	
	margin-left:30px;
	}

.msg_title{
	font-size:14px;
	font-weight:bold;
	color:#8d2d92;
	}


div.elegir {
    position: relative;
    width: 90px;
    height: 18px;
	margin-left:250px;
    border: 1px solid #949494;
    background: #e4e4e2 url(../../../layer-view-image/common/flecha-combo.png) no-repeat 75px 8px; 
    border-radius: 5px;
    font-family:Arial;
    font-size:10px;
    top: 13px;
    behavior:url(layer-view-script/common/PIE/PIE.htc);}

div.elegir div.box {
    position: absolute;
    left: 6px;
    top: 1px;
    width: 80px;
    height: 18px;
    line-height: 17px;
    font-size: 10px;
    color:#4e4e4d;
    overflow: hidden
}
div.elegir select{
    background: #e4e4e2;
    width: 80px;
    height: 18px;
    font-size: 10px;
    border: 1px solid #949494;
    opacity: 0;
    filter: alpha(Opacity=0);
    -moz-opacity: 0;
    cursor: pointer;
    font-size:10px;
    z-index:1;}
div.elegir select option{
    font-size: 10px;
    color: #4e4e4d;
    border-bottom: 1px solid #e4e4e2;
    cursor: pointer;}
div.elegir select option.ultimo{
    border-bottom: 0px none
}
/*PASO 2: Confirma tu Compra*/
#reload-balanace {margin: 10px 0 0 0px}
#content-purchase .right-panel .result_purchase {height: 40px}
#content-purchase .left-panel {	height: 96px }
#content-purchase #sub_purchase {padding-top: 20px}
#play-panel {
	border: 0 none;
	display: none;
	float: right;
	margin: 10px 37px 0 0;
	padding: 0
}

#play-panel #play:hover {	background-position: 0 -42px}
#game_grid .row_grid{	height: 60px}
#name_game{	bottom: 22px;	margin: 0 0 0 20px;    position: relative}
#game_grid .column_2 img{	 margin-top: 3px}
#game_grid .row_grid .column_1 {    line-height: 50px}
.row_grid .column_2 {    height: 60px;    text-align: center;    top: 3px}
#game_grid .column3 {    top: 21px;    position: relative}
#grilla_boleto{ font-family: Arial }
.boleto_cabecera{
    position: relative;
    height: 19px;
    background-color: #0681BC; 
    font-size: 11px;
    color:#ffffff;
    font-weight: bold;
}
.head_title_1 {    position: absolute;    left: 10px;    top:4px}
.head_title_2{    position: absolute;    left: 100px;    top:4px}
.head_title_3{    position: absolute;    left: 210px;    top:4px}
.column3 {    left: 246px;    position: absolute;    vertical-align: middle}
.column3 .delete {
    background: url("../../../layer-view-image/common/iconostabla.png") no-repeat scroll -223px -70px transparent;
    height: 16px;
    width: 17px;
}
.row_grid{
    cursor: pointer;
    position: relative;
    height: 18px; 
    font-size: 11px;
    border-bottom-style: solid;
    border-width: thin;
    border-bottom-color: #75bce5;
    padding-bottom: 2px;
    color:#5E5E5E;
    font-family: arial;
    -pie-background: linear-gradient(top,  #f9f9f9 0%, #e5e8e9 100%);
    background: -moz-linear-gradient(top,  #f9f9f9 0%, #e5e8e9 100%);
    background: -webkit-gradient(linear, 0% 0%, 0% 100%, from(#f9f9f9), to(#e5e8e9));
    background: -webkit-linear-gradient(top,  #f9f9f9 0%, #e5e8e9 100%);
    background: -o-linear-gradient(top,  #f9f9f9 0%, #e5e8e9 100%);
    background: -ms-linear-gradient(top,  #f9f9f9 0%, #e5e8e9 100%);
    behavior:url(layer-view-script/common/PIE/PIE.htc);
}
#login_section input.button-sign-in {
    float:left;
    width:109px;
    height:30px;
    text-decoration:none;
    background: url(../../../layer-view-image/common/ingresar.png) top left no-repeat;
    margin: 0;
    padding: 0;
    border: 0;
    font-size: 0
}
#login_section input.button-sign-in:hover {
    background: url(../../../layer-view-image/common/ingresar.png) bottom left no-repeat
}


