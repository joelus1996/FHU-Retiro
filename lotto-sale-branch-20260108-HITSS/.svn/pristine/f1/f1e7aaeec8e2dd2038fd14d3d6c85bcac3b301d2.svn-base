.help-off:hover{
	background:url(../../../layer-view-image/common/ayuda-on.png);
	cursor:pointer;
	width:55px;
	margin-left:550px;
	margin-top: -25px;
	height: 19px;
	display: block;}



.help-off {
    background: url(../../../layer-view-image/common/ayuda-off.png);
    cursor: pointer;
    margin-top: -25px;
    width: 55px;
    margin-left: 550px;
    height: 19px;
    display: block;
}

