package pe.com.intralot.loto.layer.model.domain;

import java.sql.Date;

import javax.persistence.Column;
import javax.persistence.Entity;
import javax.persistence.Id;
import javax.persistence.Table;

@Entity
@Table(name = "LOTOCARD.CLIENT_BALANCE")
public class ClientBalance {
	
	@Id
	@Column(name = "CLIENT_ID")
	private Integer idClient;
	
	@Column(name = "BALANCE_ITEM")
	private Integer balaceItem;	
	
	@Column(name = "CB_DESCRIPTION")
    private String cbDescription;

	@Column(name = "CB_BALANCE_NUM")
	private Integer cbBalaceNum;	

	@Column(name = "CB_BALANCE_DATE")
	private Date cbBalanceDate;	

	@Column(name = "CB_PREV_AMOUNT")
	private Double cbPrevAmount;	

	@Column(name = "CB_LOAD_AMOUNT")
	private Double cbLoadAmount;	

	@Column(name = "CB_NEW_AMOUNT")
	private Double cbNewAmount;	

	@Column(name = "CB_MOVIL_COMPANY")
	private String cbMovilCompany;	

	@Column(name = "CB_CLIENT_CARRIER")
	private String cbClientCarrier;	

	@Column(name = "CB_CLIENT_PHONE")
	private String cbClientPhone;	

	@Column(name = "CB_CLIENT_IP" )
	private String cbClientIp;	

	@Column(name = "CB_NEOPRIZE_AMOUNT")
	private Double cbNeoprizeAmount;	

	@Column(name = "CB_SUPER_DATE")
	private Date cbSuperDate;	
		
	@Column(name = "CB_SUPER_USER")
	private String cbSuperUser;	
	
	@Column(name = "CB_KIRONPRIZE_AMOUNT")
    private Double cbKironprizeAmount;

	public Integer getIdClient() {
		return idClient;
	}

	public void setIdClient(Integer idClient) {
		this.idClient = idClient;
	}

	public Integer getBalaceItem() {
		return balaceItem;
	}

	public void setBalaceItem(Integer balaceItem) {
		this.balaceItem = balaceItem;
	}

	public String getCbDescription() {
		return cbDescription;
	}

	public void setCbDescription(String cbDescription) {
		this.cbDescription = cbDescription;
	}

	public Integer getCbBalaceNum() {
		return cbBalaceNum;
	}

	public void setCbBalaceNum(Integer cbBalaceNum) {
		this.cbBalaceNum = cbBalaceNum;
	}

	public Date getCbBalanceDate() {
		return cbBalanceDate;
	}

	public void setCbBalanceDate(Date cbBalanceDate) {
		this.cbBalanceDate = cbBalanceDate;
	}

	public Double getCbPrevAmount() {
		return cbPrevAmount;
	}

	public void setCbPrevAmount(Double cbPrevAmount) {
		this.cbPrevAmount = cbPrevAmount;
	}

	public Double getCbLoadAmount() {
		return cbLoadAmount;
	}

	public void setCbLoadAmount(Double cbLoadAmount) {
		this.cbLoadAmount = cbLoadAmount;
	}

	public Double getCbNewAmount() {
		return cbNewAmount;
	}

	public void setCbNewAmount(Double cbNewAmount) {
		this.cbNewAmount = cbNewAmount;
	}

	public String getCbMovilCompany() {
		return cbMovilCompany;
	}

	public void setCbMovilCompany(String cbMovilCompany) {
		this.cbMovilCompany = cbMovilCompany;
	}

	public String getCbClientCarrier() {
		return cbClientCarrier;
	}

	public void setCbClientCarrier(String cbClientCarrier) {
		this.cbClientCarrier = cbClientCarrier;
	}

	public String getCbClientPhone() {
		return cbClientPhone;
	}

	public void setCbClientPhone(String cbClientPhone) {
		this.cbClientPhone = cbClientPhone;
	}

	public String getCbClientIp() {
		return cbClientIp;
	}

	public void setCbClientIp(String cbClientIp) {
		this.cbClientIp = cbClientIp;
	}

	public Double getCbNeoprizeAmount() {
		return cbNeoprizeAmount;
	}

	public void setCbNeoprizeAmount(Double cbNeoprizeAmount) {
		this.cbNeoprizeAmount = cbNeoprizeAmount;
	}

	public Date getCbSuperDate() {
		return cbSuperDate;
	}

	public void setCbSuperDate(Date cbSuperDate) {
		this.cbSuperDate = cbSuperDate;
	}

	public String getCbSuperUser() {
		return cbSuperUser;
	}

	public void setCbSuperUser(String cbSuperUser) {
		this.cbSuperUser = cbSuperUser;
	}

	public Double getCbKironprizeAmount() {
		return cbKironprizeAmount;
	}

	public void setCbKironprizeAmount(Double cbKironprizeAmount) {
		this.cbKironprizeAmount = cbKironprizeAmount;
	}
	
	

}
