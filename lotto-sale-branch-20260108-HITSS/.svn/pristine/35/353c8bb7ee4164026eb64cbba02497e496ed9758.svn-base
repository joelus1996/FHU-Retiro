	 				<h2 style="margin-top: 0px">O ingresa con tu cuenta:</h2>
	 				
	 				<div class="fixeds-input marginbottom1rem login-tinka">
                   		<input name="user-client" id="user-client" type="text" autocomplete="off">
                   		<label for="user-client" id="user-client-label">Usuario o N° de documento de identidad</label>
                   		<div class="errorTxt onlyuser"></div>
                   	</div>

                   	<div class="fixeds-input login-tinka">
                   		<input name="password-client" id="password-client" type="password" autocomplete="off">
                   		<label for="password-client" id="password-client-label">Contraseña</label>
                   		<div class="errorTxt onlypass" id="errorTxt-onlypass"></div>
                   		<button class="view-password" type="button" id="toglePassword" style="right: 30px; top: 8px;"></button>
                   	</div>

					<div class="box-login-section high-box-login box-no-margin" style="margin-top: 30px">
						<input type="submit" value="INGRESAR" class="button button-dark-green" id="home-btnlogin" 
						style="height: 35px; line-height: 35px; box-shadow: none;">
					</div>			      							


					<div style="text-align: center; margin-top: 15px; margin-bottom: 15px;">
