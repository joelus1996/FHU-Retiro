@font-face {
    font-family: AllerLight;
    src: url(../fonts/Aller-Light.8b33c48f37.eot);
    src: local("\263A"), url(../fonts/Aller-Light.228e1d828d.woff) format("woff"), url(../fonts/Aller-Light.d784daa2c2.ttf) format("truetype"), url(../fonts/Aller-Light.af0d63f714.svg) format("svg");
    font-weight: 400;
    font-style: normal
}

@font-face {
    font-family: AllerRegular;
    src: url(../fonts/Aller-Regular.d2812137ac.eot);
    src: local("\263A"), url(../fonts/Aller-Regular.c8d6b0735e.woff) format("woff"), url(../fonts/Aller-Regular.785388a9e6.ttf) format("truetype"), url(../fonts/Aller-Regular.42ffbc2cf9.svg) format("svg");
    font-weight: 400;
    font-style: normal
}

@font-face {
    font-family: AllerBold;
    src: url(../fonts/Aller-Bold.5ac183d252.eot);
    src: local("\263A"), url(../fonts/Aller-Bold.ab02f64b82.woff) format("woff"), url(../fonts/Aller-Bold.ec478fc737.ttf) format("truetype"), url(../fonts/Aller-Bold.8ee51c74fd.svg) format("svg");
    font-weight: 400;
    font-style: normal
}

.juego-responsable,
.responsabilidad-social,
.responsabilidad-social-single {
    margin: 0 auto 60px
}

.juego-responsable>div,
.responsabilidad-social-single>div,
.responsabilidad-social>div {
    border-top: 1px solid #ebebeb;
    margin-left: -30px;
    margin-right: -30px;
    padding: 60px 0
}

.juego-responsable>div:first-of-type,
.responsabilidad-social-single>div:first-of-type,
.responsabilidad-social>div:first-of-type {
    border-top: none
}

.juego-responsable .il-rs-container,
.responsabilidad-social-single .il-rs-container,
.responsabilidad-social .il-rs-container {
    max-width: 835px;
    margin: 0 auto
}

.juego-responsable .il-rs-section-title-row>:first-child,
.responsabilidad-social-single .il-rs-section-title-row>:first-child,
.responsabilidad-social .il-rs-section-title-row>:first-child {
    float: left
}

.juego-responsable .il-rs-section-title-row>:last-child,
.responsabilidad-social-single .il-rs-section-title-row>:last-child,
.responsabilidad-social .il-rs-section-title-row>:last-child {
    float: right
}

.juego-responsable .il-juega-fixed-link,
.responsabilidad-social-single .il-juega-fixed-link,
.responsabilidad-social .il-juega-fixed-link {
    display: block;
    width: 74px;
    height: 74px;
    font-weight: 700;
    font-size: 14px;
    color: #fff;
    text-align: center;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 50%;
    background-color: #d78031;
    -webkit-transition: .4s ease;
    -o-transition: .4s ease;
    transition: .4s ease;
    -webkit-transform: translate3d(-50px, -50%, 0);
    transform: translate3d(-50px, -50%, 0);
    position: fixed;
    top: 50%;
    right: 0
}

.juego-responsable .il-juega-fixed-link:hover,
.responsabilidad-social-single .il-juega-fixed-link:hover,
.responsabilidad-social .il-juega-fixed-link:hover {
    opacity: .8
}

.juego-responsable .il-juega-fixed-link:before,
.responsabilidad-social-single .il-juega-fixed-link:before,
.responsabilidad-social .il-juega-fixed-link:before {
    content: "";
    display: inline-block;
    width: 0;
    height: 100%;
    vertical-align: middle
}

.juego-responsable .il-juega-fixed-link i,
.responsabilidad-social-single .il-juega-fixed-link i,
.responsabilidad-social .il-juega-fixed-link i {
    display: block;
    width: 20px;
    height: 20px;
    margin: 0 auto 5px
}

.juego-responsable .il-juega-fixed-link svg,
.responsabilidad-social-single .il-juega-fixed-link svg,
.responsabilidad-social .il-juega-fixed-link svg {
    display: block;
    width: 100%;
    height: 100%
}

.juego-responsable .il-juega-fixed-link span,
.responsabilidad-social-single .il-juega-fixed-link span,
.responsabilidad-social .il-juega-fixed-link span {
    display: inline-block;
    vertical-align: middle
}

.md-wrapper {
    width: 100%;
    height: 100%;
    font-size: 0;
    text-align: center;
    background-color: rgba(0, 0, 0, .6);
    background-size: cover;
    background-repeat: no-repeat;
    background-position: 50%;
    pointer-events: none;
    -webkit-transition: all .3s;
    -o-transition: all .3s;
    transition: all .3s;
    position: fixed;
    top: 0;
    left: 0;
    opacity: 0;
    z-index: 8080
}

.md-wrapper:before {
    content: "";
    display: inline-block;
    vertical-align: middle;
    width: 0;
    height: 100%
}

.md-wrapper.is-active {
    pointer-events: all;
    opacity: 1
}

.md-wrapper.is-active~.md-wrapper {
    z-index: 8090
}

.md-wrapper .md-close {
    display: block;
    width: 28px;
    height: 28px;
    cursor: pointer;
    background-color: #d78031;
    border-radius: 50%;
    -webkit-box-shadow: 0 5px 15px 0 rgba(0, 0, 0, .6);
    box-shadow: 0 5px 15px 0 rgba(0, 0, 0, .6);
    -webkit-transform: translate(-20px, 20px);
    -ms-transform: translate(-20px, 20px);
    transform: translate(-20px, 20px);
    -webkit-transition: .2s linear;
    -o-transition: .2s linear;
    transition: .2s linear;
    padding: 7px;
    position: absolute;
    top: 0;
    right: 0;
    z-index: 1
}

.md-wrapper .md-close:hover {
    opacity: .8
}

.md-wrapper .md-close svg {
    display: block;
    width: 100%;
    height: 100%
}

.md-wrapper .md-content {
    display: inline-block;
    max-width: 950px;
    width: 100%;
    background-color: #fff;
    border-radius: 20px;
    padding: 60px;
    vertical-align: middle;
    position: relative
}

.md-wrapper .md-caption {
    font-weight: 300;
    font-size: 14px;
    color: #4d4d4d;
    text-align: left;
    line-height: 24px
}

.md-wrapper .md-caption p {
    margin: 0 0 15px
}

.md-wrapper .md-caption p:last-of-type {
    margin: 0
}

.md-hidden {
    overflow: hidden
}

.video-js {
    width: 100%;
    height: 460px
}

.video-js .vjs-big-play-button {
    width: 94px!important;
    height: 94px!important;
    border-radius: 50%!important;
    top: 50%;
    left: 50%
}

.video-js .vjs-big-play-button,
.video-js .vjs-big-play-button .vjs-icon-placeholder:before {
    -webkit-transform: translate(-50%, -50%);
    -ms-transform: translate(-50%, -50%);
    transform: translate(-50%, -50%)
}

.video-js .vjs-big-play-button .vjs-icon-placeholder:before {
    font-size: 58px;
    position: absolute;
    top: 75%;
    left: 52%
}

.il-clearfix {
    *zoom: 1
}

.il-clearfix:after,
.il-clearfix:before {
    content: "";
    display: table;
    line-height: 0;
    clear: both
}

.responsabilidad-social .il-rs-section-title {
    font-weight: 300;
    font-size: 28px;
    color: #07663a;
    margin: 0 0 60px
}

.responsabilidad-social .il-rs-link {
    display: inline-block;
    font-size: 16px;
    color: #fff;
    text-decoration: none;
    -webkit-box-shadow: 0 5px 15px 0 rgba(0, 0, 0, .6);
    box-shadow: 0 5px 15px 0 rgba(0, 0, 0, .6);
    background: #d10613;
    background: -webkit-linear-gradient(top, #d10613, #980d18);
    background: -webkit-gradient(linear, left top, left bottom, from(#d10613), to(#980d18));
    background: -o-linear-gradient(top, #d10613 0, #980d18 100%);
    background: linear-gradient(180deg, #d10613 0, #980d18);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr="#d10613", endColorstr="#980d18", GradientType=0);
    border-radius: 50px;
    margin: 15px 0 0;
    padding: 12px 80px;
    -webkit-transition: .4s ease;
    -o-transition: .4s ease;
    transition: .4s ease
}

.responsabilidad-social .il-rs-link:hover {
    opacity: .85
}

.il-rs-contribution-betefits {
    text-align: center
}

.il-rs-contribution-betefits h1 {
    font-weight: 700;
    font-size: 38px;
    color: #07663a;
    text-transform: uppercase;
    margin: 0
}

.il-rs-contribution-betefits h2 {
    display: inline-block;
    font-weight: 700;
    font-size: 56px;
    color: #006b2d;
    text-transform: uppercase;
    background: #ffdb00;
    background: -webkit-linear-gradient(top, #ffdb00, #ffa800);
    background: -webkit-gradient(linear, left top, left bottom, from(#ffdb00), to(#ffa800));
    background: -o-linear-gradient(top, #ffdb00 0, #ffa800 100%);
    background: linear-gradient(180deg, #ffdb00 0, #ffa800);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr="#ffdb00", endColorstr="#ffa800", GradientType=0);
    border-radius: 50px;
    -webkit-box-shadow: 0 5px 15px 0 rgba(0, 0, 0, .6);
    box-shadow: 0 5px 15px 0 rgba(0, 0, 0, .6);
    margin: 50px 0 15px;
    padding: 10px 60px
}

.il-rs-contribution-betefits .il-caption {
    font-weight: 300;
    font-size: 14px;
    color: #888;
    line-height: 24px
}

.il-rs-article .il-caption {
    font-weight: 300;
    font-size: 16px;
    color: #4d4d4d;
    line-height: 26px
}

.il-rs-social-items>div {
    max-width: 360px;
    border: 1px solid #ebebeb;
    margin: 0 0 30px
}

.il-rs-social-items>div:nth-of-type(1n) {
    float: left
}

.il-rs-social-items>div:nth-of-type(2n) {
    float: right
}

.il-rs-social-items .il-rs-item-image {
    width: 100%;
    height: 0;
    padding-top: 60%;
    position: relative;
    overflow: hidden
}

.il-rs-social-items .il-rs-item-image:hover span {
    -webkit-transform: scale(1.1);
    -ms-transform: scale(1.1);
    transform: scale(1.1)
}

.il-rs-social-items .il-rs-item-image span {
    display: block;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: 50%;
    background-repeat: no-repeat;
    -webkit-transition: .3s ease;
    -o-transition: .3s ease;
    transition: .3s ease;
    position: absolute;
    top: 0;
    left: 0
}

.il-rs-social-items .il-rs-item-caption {
    padding: 15px
}

.il-rs-social-items .il-rs-item-caption div {
    text-align: right;
    border-top: 1px solid #ebebeb;
    margin: 15px 0 0;
    padding: 25px 0 10px
}

.il-rs-social-items .il-rs-item-title {
    display: block;
    width: 100%;
    font-weight: 300;
    font-size: 14px;
    color: #4d4d4d;
    text-decoration: none;
    margin: 0 0 5px
}

.il-rs-social-items .il-rs-item-title:hover {
    text-decoration: underline
}

.il-rs-social-items small {
    font-weight: 300;
    font-size: 10px;
    color: #888
}

.il-rs-social-items .il-rs-item-link {
    display: inline-block;
    font-weight: 300;
    font-size: 12px;
    color: #df802f;
    text-decoration: none;
    -webkit-transition: .4s ease;
    -o-transition: .4s ease;
    transition: .4s ease
}

.il-rs-social-items .il-rs-item-link:hover {
    opacity: .7
}

.il-rs-social-items .il-rs-item-link i {
    display: inline-block;
    width: 14px;
    height: 14px;
    vertical-align: middle
}

.il-rs-social-items .il-rs-item-link svg {
    display: block;
    width: 100%;
    height: 100%
}

.il-rs-social-items .il-rs-item-link span {
    display: inline-block;
    vertical-align: middle
}

.il-rs-video-controls {
    margin: 5px 0 0;
    opacity: 0;
    pointer-events: none
}

.il-rs-video-controls li {
    display: inline-block;
    vertical-align: middle
}

.il-rs-video-controls li:last-of-type {
    margin: 0 0 0 30px
}

.il-rs-video-controls a {
    display: inline-block;
    width: 20px;
    height: 20px;
    -webkit-transition: .4s ease;
    -o-transition: .4s ease;
    transition: .4s ease
}

.il-rs-video-controls a:hover {
    opacity: .7
}

.il-rs-video-controls svg {
    display: block;
    width: 100%;
    height: 100%
}

.il-rs-video-list {
    min-height: 260px;
    position: relative
}

.il-rs-video-list>div {
    width: 350px;
    height: 0;
    padding-top: 30%;
    -webkit-transition: -webkit-transform .3s ease;
    transition: -webkit-transform .3s ease;
    -o-transition: transform .3s ease;
    transition: transform .3s ease;
    transition: transform .3s ease, -webkit-transform .3s ease;
    -webkit-perspective: 600px;
    perspective: 600px;
    opacity: 0;
    pointer-events: none;
    cursor: pointer;
    position: absolute;
    top: 0;
    left: 50%;
    z-index: 1
}

.il-rs-video-list>div.is-prev {
    opacity: .8;
    -webkit-transform: translate3d(-119%, 0, 0) scale(.85);
    transform: translate3d(-119%, 0, 0) scale(.85);
    pointer-events: all
}

.il-rs-video-list>div.is-active {
    opacity: 1;
    -webkit-transform: translate3d(-50%, 0, 0);
    transform: translate3d(-50%, 0, 0);
    z-index: 5;
    pointer-events: all
}

.il-rs-video-list>div.is-next {
    opacity: .8;
    -webkit-transform: translate3d(19%, 0, 0) scale(.85);
    transform: translate3d(19%, 0, 0) scale(.85);
    pointer-events: all
}

.il-rs-video-list>div:before {
    content: "";
    display: block;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, .4);
    -webkit-transition: .3s ease;
    -o-transition: .3s ease;
    transition: .3s ease;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1
}

.il-rs-video-list>div:hover:before {
    background-color: rgba(0, 0, 0, .3)
}

.il-rs-video-list span {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: 50%;
    background-repeat: no-repeat;
    position: absolute;
    top: 0;
    left: 0
}

.il-rs-video-list ul {
    width: 100%;
    font-size: 0;
    padding: 0 0 20px;
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2
}

.il-rs-video-list ul:before {
    content: "";
    width: 0;
    height: 100%
}

.il-rs-video-list ul:before,
.il-rs-video-list ul li {
    display: inline-block;
    vertical-align: middle
}

.il-rs-video-list ul li:first-of-type {
    width: 15%;
    text-align: center
}

.il-rs-video-list ul li:last-of-type {
    width: 85%
}

.il-rs-video-list ul a {
    display: inline-block;
    width: 24px;
    height: 24px;
    -webkit-transition: .3s ease;
    -o-transition: .3s ease;
    transition: .3s ease
}

.il-rs-video-list ul a:hover {
    opacity: .8
}

.il-rs-video-list ul svg {
    display: block;
    width: 100%;
    height: 100%
}

.il-rs-video-list ul h5 {
    font-weight: 300;
    font-size: 16px;
    color: #fff;
    margin: 0
}

.il-rs-video-list ul p {
    font-weight: 300;
    font-size: 10px;
    color: #fff;
    margin: 0
}

.il-rs-social-campaigns ul {
    text-align: center
}

.il-rs-social-campaigns li {
    font-size: 0
}

.il-rs-social-campaigns li:before {
    content: "";
    width: 0;
    height: 100%
}

.il-rs-social-campaigns img,
.il-rs-social-campaigns li:before {
    display: inline-block;
    vertical-align: middle
}

.responsabilidad-social-single>div {
    padding: 60px 115px
}

.responsabilidad-social-single>div img {
    display: block;
    margin: 0 -115px 60px
}

.responsabilidad-social-single h1 {
    font-weight: 700;
    font-size: 32px;
    color: #eb872f;
    margin: 0 0 50px
}

.responsabilidad-social-single h1 span {
    color: #333
}

.responsabilidad-social-single p {
    font-weight: 300;
    font-size: 14px;
    color: #4d4d4d;
    line-height: 24px;
    margin: 0 0 15px
}

.responsabilidad-social-single p:last-of-type {
    margin: 0
}

.responsabilidad-social-single hr {
    display: block;
    border-top: 1px solid #ebebeb;
    border-bottom: none;
    margin: 60px -115px
}

.responsabilidad-social-single .video-js {
    height: 380px
}

.juego-responsable>div {
    max-width: 835px;
    border-top: none;
    text-align: center;
    margin: 0 auto;
    padding: 60px 0 0
}

.juego-responsable h3 {
    min-width: 480px;
    color: #fff;
    background-color: #464646;
    border-radius: 50px;
    margin: 0 auto 60px;
    padding: 14px 46px
}

.juego-responsable h3,
.juego-responsable h4 {
    display: inline-block;
    font-weight: 700;
    font-size: 20px;
    text-transform: uppercase
}

.juego-responsable h4 {
    color: #959595;
    border-bottom: 1px solid #909090;
    margin: 30px 0 15px;
    padding: 0 0 30px
}

.il-jr-responsibility {
    position: relative
}

.il-jr-responsibility .il-rs-juego-responsable {
    position: absolute;
    top: 30px;
    right: 0
}

.il-jr-responsibility img {
    display: block;
    margin: 0 auto 60px
}

.il-jr-responsibility .il-js-responsibility-list {
    font-size: 0;
    border-radius: 10px;
    border: 1px solid #909090;
    padding: 20px
}

.il-jr-responsibility .il-js-responsibility-list:before {
    content: "";
    display: inline-block;
    width: 0;
    height: 100%;
    vertical-align: middle
}

.il-jr-responsibility .il-js-responsibility-list>div {
    display: inline-block;
    width: 80%;
    vertical-align: middle
}

.il-jr-responsibility .il-js-responsibility-list>div:first-of-type {
    width: 20%
}

.il-jr-responsibility ol {
    text-align: left
}

.il-jr-responsibility ol li {
    display: list-item;
    font-weight: 700;
    font-size: 15px;
    color: #959595;
    line-height: 25px;
    list-style-type: disc
}

.myth-and-reality {
    font-size: 0;
    border-radius: 10px;
    border: 1px solid #909090;
    margin: 0 0 15px;
    padding: 20px;
    position: relative
}

.myth-and-reality:last-child {
    margin: 0
}

.myth-and-reality:before {
    content: "";
    display: inline-block;
    width: 0;
    height: 100%;
    vertical-align: top
}

.myth-and-reality:after {
    content: "";
    display: block;
    width: 1px;
    height: 100px;
    background-color: #909090;
    -webkit-transform: translateY(-50%);
    -ms-transform: translateY(-50%);
    transform: translateY(-50%);
    position: absolute;
    top: 50%;
    right: 50%
}

.myth-and-reality>div {
    display: inline-block;
    width: 50%;
    vertical-align: top;
    text-align: left;
    padding-left: 30px
}

.myth-and-reality>div:first-of-type {
    width: 50%;
    padding-left: 0;
    padding-right: 30px;
    position: relative
}

.myth-and-reality h5 {
    font-weight: 700;
    font-size: 32px;
    color: #07663a;
    text-transform: uppercase;
    margin: 0 0 20px
}

.myth-and-reality p {
    font-weight: 700;
    font-size: 13px;
    color: #959595;
    line-height: 23px;
    padding: 0 0 10px
}

.myth-and-reality p:last-of-type {
    margin: 0
}

.the-signs-withproblems ol {
    text-align: left;
    border: 1px solid #909090;
    border-radius: 10px;
    padding: 30px 20px 30px 60px
}

.the-signs-withproblems ol li {
    display: list-item;
    font-weight: 700;
    font-size: 15px;
    color: #959595;
    line-height: 25px;
    list-style-type: disc
}

.the-signs-withproblems p {
    font-weight: 700;
    font-size: 16px;
    color: #464646;
    line-height: 26px
}

.the-signs-withproblems a {
    color: #464646;
    -webkit-transition: .4s ease;
    -o-transition: .4s ease;
    transition: .4s ease
}

.the-signs-withproblems a:hover {
    color: #eb872f
}

.inversionistas {
    padding-top: 120px;
    position: relative
}

.inversionistas .il-r-page-nav {
    width: 100%;
    font-size: 0;
    padding: 0;
    position: absolute;
    top: 0;
    left: 0;
    right: 0
}

.inversionistas .il-r-page-nav:before {
    content: "";
    display: inline-block;
    width: 0;
    height: 100%;
    vertical-align: middle
}

.inversionistas .il-r-page-nav li {
    display: inline-block;
    width: 25%;
    vertical-align: middle
}

.inversionistas .il-r-page-nav a {
    display: inline-block;
    width: 100%;
    font-weight: 700;
    font-size: 17px;
    color: #fff;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    background-color: #565656;
    padding: 24px 0;
    -webkit-transition: .4s ease;
    -o-transition: .4s ease;
    transition: .4s ease
}

.inversionistas .il-r-page-nav a.is-active,
.inversionistas .il-r-page-nav a:hover {
    background-color: #333
}

.inversionistas h3 {
    width: 100%;
    min-width: 480px;
    color: #fff;
    background-color: #464646;
    border-radius: 50px;
    margin: 0 auto 30px;
    padding: 14px 46px
}

.inversionistas h3,
.inversionistas h4 {
    display: inline-block;
    font-weight: 700;
    font-size: 20px;
    text-transform: uppercase
}

.inversionistas h4 {
    color: #959595;
    margin: 0 0 15px
}

.inversionistas>div {
    text-align: center;
    border: 1px solid #eff1f1;
    border-radius: 10px;
    margin: 0 0 30px;
    padding: 30px
}

.inversionistas .il-r-table {
    display: table;
    width: 100%;
    -webkit-box-shadow: 0 0 10px rgba(0, 0, 0, .4);
    box-shadow: 0 0 10px rgba(0, 0, 0, .4);
    border-radius: 10px;
    margin: 30px 0 0;
    padding: 0 0 10px;
    overflow: hidden;
    position: relative
}

.inversionistas .il-r-table:before {
    left: 20%
}

.inversionistas .il-r-table:after,
.inversionistas .il-r-table:before {
    content: "";
    display: block;
    width: 1px;
    height: 100%;
    background-color: #eff1f1;
    position: absolute;
    top: 0
}

.inversionistas .il-r-table:after {
    left: 80%
}

.inversionistas .il-r-table-col {
    display: inline-block;
    font-weight: 300;
    font-size: 15px;
    color: gray;
    vertical-align: middle
}

.inversionistas .il-r-table-col:first-child {
    width: 20%;
    text-align: center
}

.inversionistas .il-r-table-col:nth-child(2) {
    width: 60%;
    text-align: left;
    padding: 0 30px
}

.inversionistas .il-r-table-col:nth-child(3) {
    width: 20%
}

.inversionistas .il-r-table-row {
    display: inline-block;
    width: 100%;
    vertical-align: middle;
    font-size: 0;
    padding: 4px 0;
    cursor: pointer
}

.inversionistas .il-r-table-row:hover .il-r-table-col {
    color: #e98631
}

.inversionistas .il-r-table-row:hover .il-r-table-col path,
.inversionistas .il-r-table-row:hover .il-r-table-col polygon {
    fill: #e98631!important
}

.inversionistas .il-r-table-row:before {
    content: "";
    width: 0;
    height: 100%;
    vertical-align: middle
}

.inversionistas .il-r-table-row:first-child {
    background-color: #959595;
    margin: 0 0 10px;
    padding: 14px
}

.inversionistas .il-r-table-row:first-child .il-r-table-col {
    font-weight: 700;
    color: #fff;
    text-align: center!important;
    text-transform: uppercase
}

.inversionistas .il-r-btn {
    display: inline-block;
    font-size: 0;
    background-color: #07663a;
    border-radius: 50px;
    border: none;
    padding: 14px 28px;
    -webkit-transition: .4s ease;
    -o-transition: .4s ease;
    transition: .4s ease
}

.inversionistas .il-r-btn:before {
    content: "";
    display: inline-block;
    width: 0;
    height: 100%;
    vertical-align: middle
}

.inversionistas .il-r-btn:hover {
    opacity: .8
}

.inversionistas .il-r-btn i {
    display: inline-block;
    width: 24px;
    vertical-align: middle;
    margin: 0 0 0 20px
}

.inversionistas .il-r-btn svg {
    display: block;
    width: 100%
}

.inversionistas .il-r-btn span {
    display: inline-block;
    font-weight: 700;
    font-size: 16px;
    color: #fff;
    text-transform: uppercase;
    vertical-align: middle
}

.inversionistas .facts-of-importance-inner>div,
.inversionistas .memories-inner>div {
    width: 60%;
    float: left;
    text-align: center
}

.inversionistas .facts-of-importance-inner>div:last-of-type,
.inversionistas .memories-inner>div:last-of-type {
    width: 40%;
    text-align: right
}

.inversionistas .facts-of-importance-inner img,
.inversionistas .memories-inner img {
    display: inline-block;
    border-radius: 10px
}

.inversionistas form h4 {
    font-size: 16px;
    margin: 0 0 30px
}

.inversionistas form .il-r-row-input {
    font-size: 0;
    margin: 0 0 30px
}

.inversionistas form .il-r-row-input:before {
    content: "";
    display: inline-block;
    width: 0;
    height: 100%;
    vertical-align: middle
}

.inversionistas form input {
    font-size: 14px
}

.inversionistas #financial-information {
    max-width: 340px;
    margin: 0 auto 60px
}

.inversionistas #financial-information .il-r-btn span {
    padding: 0 57px 0 102px
}

.il-r-dropdown {
    display: inline-block;
    width: 45%;
    text-align: left;
    vertical-align: middle;
    position: relative
}

.il-r-dropdown+.il-r-dropdown {
    margin: 0 0 0 15px
}

.il-r-dropdown>a {
    display: inline-block;
    width: 100%;
    font-size: 16px;
    font-weight: 700;
    color: #959595;
    text-transform: uppercase;
    text-align: left;
    text-decoration: none;
    border: 1px solid #eff1f1;
    border-radius: 50px;
    padding: 12px 24px;
    position: relative
}

.il-r-dropdown>a.is-active i {
    -webkit-transform: translate(-16px, -50%) rotate(180deg);
    -ms-transform: translate(-16px, -50%) rotate(180deg);
    transform: translate(-16px, -50%) rotate(180deg)
}

.il-r-dropdown>a.is-active+.dropdown-select {
    display: block
}

.il-r-dropdown>a.is-active+.dropdown-select+span {
    width: 100%
}

.il-r-dropdown>a.is-empty {
    color: red;
    border-color: red
}

.il-r-dropdown>a i {
    display: block;
    width: 15px;
    height: 8px;
    -webkit-transform: translate(-16px, -50%);
    -ms-transform: translate(-16px, -50%);
    transform: translate(-16px, -50%);
    position: absolute;
    top: 50%;
    right: 0
}

.il-r-dropdown>a svg {
    display: block;
    width: 100%;
    height: 100%
}

.il-r-dropdown .dropdown-select {
    display: none;
    width: 100%;
    text-align: center;
    border: 1px solid #eff1f1;
    border-radius: 10px;
    -webkit-box-shadow: 0 5px 10px rgba(0, 0, 0, .2);
    box-shadow: 0 5px 10px rgba(0, 0, 0, .2);
    background-color: #fff;
    padding: 12px 18px;
    position: absolute;
    top: -webkit-calc(100% + 15px);
    top: calc(100% + 15px);
    z-index: 2
}

.il-r-dropdown .dropdown-select:before {
    content: "";
    display: block;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 14px 12px;
    border-color: transparent transparent #eff1f1;
    -webkit-transform: translate(-50%, -12px);
    -ms-transform: translate(-50%, -12px);
    transform: translate(-50%, -12px);
    position: absolute;
    top: 0;
    left: 50%
}

.il-r-dropdown .dropdown-select li {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: #959595;
    padding: 5px 0;
    cursor: pointer;
    -webkit-transition: .4s ease;
    -o-transition: .4s ease;
    transition: .4s ease
}

.il-r-dropdown .dropdown-select li:hover {
    color: #e98631
}

.il-r-dropdown .dropdown-select i {
    font-style: normal
}

.date-picker-wrapper {
    font-family: inherit;
    border: none;
    background-color: transparent
}

#date-range-both {
    font-size: 0
}

#date-range-both:before {
    content: "";
    display: inline-block;
    width: 0;
    height: 100%;
    vertical-align: middle
}

#date-range-both>.input-row {
    display: inline-block;
    width: 50%;
    text-align: left;
    vertical-align: middle
}

#date-range-both label {
    font-size: 13px;
    margin: 0 10px 0 0
}

#date-range-both input,
#date-range-both label {
    display: inline-block;
    font-weight: 700;
    color: #959595;
    vertical-align: middle
}

#date-range-both input {
    width: 160px;
    font-size: 16px;
    text-transform: uppercase;
    text-align: left;
    text-decoration: none;
    border: 1px solid #eff1f1;
    border-radius: 50px;
    padding: 12px 24px;
    position: relative
}

#date-range-both input::-webkit-input-placeholder {
    color: #c9c9c9
}

#date-range-both input:-ms-input-placeholder,
#date-range-both input::-ms-input-placeholder {
    color: #c9c9c9
}

#date-range-both input::placeholder {
    color: #c9c9c9
}

#date-range-both input.is-empty {
    color: red;
    border-color: red
}